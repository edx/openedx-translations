#: models.py:25
msgid "Display Name"
msgstr "Nazwa wyświetlana"

#: models.py:28
msgid "This is the XBlock's display name"
msgstr "To jest nazwa wyświetlana XBlocka"

#: models.py:32
msgid "Image URL"
msgstr "Adres URL obrazu"

#: models.py:41
msgid "This is the location of the full-screen image to be displayed."
msgstr ""
"To jest lokalizacja obrazu w trybie pełnoekranowym, który zostanie "
"wyświetlony."

#: models.py:46
msgid "Thumbnail URL"
msgstr "Adres URL miniaturki"

#: models.py:50
msgid ""
"This is the (optional) location of a thumbnail image to be displayed before "
"the main image has been enlarged."
msgstr ""
"To jest (opcjonalna) lokalizacja obrazu miniaturki, który zostanie "
"wyświetlony przed powiększeniem głównego obrazu."

#: models.py:56
msgid "Description"
msgstr "Opis"

#: models.py:59
msgid "Description text, displayed to screen readers"
msgstr "Tekst opisu, wyświetlany dla czytników ekranu"

#: models.py:64
msgid "Alt Text"
msgstr "Tekst alternatywny"

#: models.py:68
msgid ""
"This field allows you to add alternate or descriptive text that pertains to "
"your image."
msgstr ""
"To pole umożliwia dodanie alternatywnego lub opisowego tekstu odnoszącego "
"się do Twojego obrazu."

#: templates/view.html:15
msgid "Fullscreen"
msgstr "Pełny ekran"

#: templates/view.html:25
msgid "Zoom In"
msgstr "Powiększ"

#: templates/view.html:29
msgid "Close"
msgstr "Zamknij"
