#: models.py:25
msgid "Display Name"
msgstr "Nombre a mostrar"

#: models.py:28
msgid "This is the XBlock's display name"
msgstr "Este es el nombre para mostrar del XBlock"

#: models.py:32
msgid "Image URL"
msgstr "URL de la imagen"

#: models.py:41
msgid "This is the location of the full-screen image to be displayed."
msgstr ""
"Esta es la ubicación de la imagen de pantalla completa que se mostrará."

#: models.py:46
msgid "Thumbnail URL"
msgstr "URL en miniatura"

#: models.py:50
msgid ""
"This is the (optional) location of a thumbnail image to be displayed before "
"the main image has been enlarged."
msgstr ""
"Esta es la ubicación (opcional) de una imagen en miniatura que se mostrará "
"antes de ampliar la imagen principal."

#: models.py:56
msgid "Description"
msgstr "Descripción"

#: models.py:59
msgid "Description text, displayed to screen readers"
msgstr "Texto de descripción que se muestra a los lectores de pantalla."

#: models.py:64
msgid "Alt Text"
msgstr "Texto alternativo"

#: models.py:68
msgid ""
"This field allows you to add alternate or descriptive text that pertains to "
"your image."
msgstr ""
"Este campo le permite agregar texto alternativo o descriptivo que pertenezca"
" a su imagen."

#: templates/view.html:15
msgid "Fullscreen"
msgstr "Pantalla completa"

#: templates/view.html:25
msgid "Zoom In"
msgstr "Acercar"

#: templates/view.html:29
msgid "Close"
msgstr "Cerrar"
