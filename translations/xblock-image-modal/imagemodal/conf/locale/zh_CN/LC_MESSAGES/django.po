#: models.py:25
msgid "Display Name"
msgstr "显示名称"

#: models.py:28
msgid "This is the XBlock's display name"
msgstr "这是 XBlock 的显示名称"

#: models.py:32
msgid "Image URL"
msgstr "图片 URL"

#: models.py:41
msgid "This is the location of the full-screen image to be displayed."
msgstr "这是要显示的全屏图片的位置。"

#: models.py:46
msgid "Thumbnail URL"
msgstr "缩略图 URL"

#: models.py:50
msgid ""
"This is the (optional) location of a thumbnail image to be displayed before "
"the main image has been enlarged."
msgstr "这是在主图放大之前显示的缩略图的（可选）位置。"

#: models.py:56
msgid "Description"
msgstr "描述"

#: models.py:59
msgid "Description text, displayed to screen readers"
msgstr "描述文本，供屏幕阅读器使用"

#: models.py:64
msgid "Alt Text"
msgstr "替代文本"

#: models.py:68
msgid ""
"This field allows you to add alternate or descriptive text that pertains to "
"your image."
msgstr "此字段允许您添加与您的图片相关的备用或说明性文本。"

#: templates/view.html:15
msgid "Fullscreen"
msgstr "全屏"

#: templates/view.html:25
msgid "Zoom In"
msgstr "放大"

#: templates/view.html:29
msgid "Close"
msgstr "关闭"
