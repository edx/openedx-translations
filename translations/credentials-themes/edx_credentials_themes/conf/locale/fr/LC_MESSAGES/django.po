#: templates/edx.org/credentials/programs/base.html:30
msgid "About edX"
msgstr "À propos d'edX"

#: templates/edx.org/credentials/programs/base.html:33
#, python-brace-format
msgid ""
"{link_start} edX{link_end} offers interactive online classes and MOOCs from "
"the world’s best universities, including MIT, Harvard, Berkeley, University "
"of Texas, and many others. edX is an online initiative created by founding "
"partners Harvard and MIT."
msgstr ""
"{link_start} edX{link_end} offre des cours en ligne interactifs et des MOOCs"
" proposés par les meilleures universités du monde, y compris le MIT, "
"Harvard, Berkeley, l'Université du Texas et bien d'autres. edX est une "
"initiative en ligne créée par les partenaires fondateurs Harvard et MIT."

