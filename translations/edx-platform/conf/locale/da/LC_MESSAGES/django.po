msgstr "Der findes allerede en slug med navnet \"%s\"."

#: wiki/forms.py:246
msgid "Yes, I am sure"
msgstr "Ja, jeg er sikker"

#: wiki/forms.py:248 wiki/templates/wiki/deleted.html:46
