#: cms/templates/course_outline.html:168
#, python-brace-format
msgid ""
"To update these settings go to the {link_start}Proctored Exam Settings "
"page{link_end}."
msgstr ""
"For at opdatere disse indstillinger, gå til {link_start}siden for overvågede"
" eksamensindstillinger{link_end}."

#: cms/templates/course_outline.html:175
#, python-brace-format
