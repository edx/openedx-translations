#: xmodule/graders.py:441
#, python-brace-format
msgid "{short_label} Avg"
msgstr "{short_label} Gns"

#: xmodule/hidden_block.py:38
#, python-brace-format
msgid ""
"ERROR: \"{block_type}\" is an unknown component type. This component will be"
" hidden in LMS."
msgstr ""
"FEJL: \"{block_type}\"er en ukendt komponenttype. Denne komponent vil være "
"skjult i LMS."

#: xmodule/html_block.py:63 xmodule/html_block.py:387
#: xmodule/html_block.py:447
msgid "Html contents to display for this block"
msgstr "Html-indhold, der skal vises for denne blok"

#: xmodule/html_block.py:65
msgid "Upstream html contents to store upstream data field"
msgstr "Opstrøms HTML-indhold til at gemme opstrøms datafelt"

#: xmodule/html_block.py:72
msgid "Source code for LaTeX documents. This feature is not well-supported."
msgstr ""
"Kildekode til LaTeX-dokumenter. Denne funktion er ikke godt understøttet."

#: xmodule/html_block.py:82
msgid ""
"Select Visual to enter content and have the editor automatically create the "
"HTML. Select Raw to edit HTML directly. If you change this setting, you must"
" save the component and then re-open it for editing."
msgstr ""
"Vælg Visual for at indtaste indhold og få editoren til automatisk at oprette"
" en HTML-fil. Vælg Raw for at redigere direkte i HTML. Hvis du ændrer denne "
"indstilling, skal du gemme komponenten og derefter genåbne for at kunne "
"redigere."

#: xmodule/html_block.py:85
msgid "Editor"
msgstr "Editor"

#: xmodule/html_block.py:88
msgid "Visual"
msgstr "Visuel"

#: xmodule/html_block.py:89
msgid "Raw"
msgstr "Rå"

#: xmodule/html_block.py:413
msgid "Hide Page From Learners"
msgstr "Skjul side for elever"

#: xmodule/html_block.py:414
msgid ""
"If you select this option, only course team members with the Staff or Admin "
"role see this page."
msgstr ""
"Hvis du vælger denne mulighed, er det kun kursusholdsmedlemmer med rollen "
"medarbejder eller administrator, der ser denne side."

#: xmodule/html_block.py:424
msgid "HTML for the additional pages"
msgstr "HTML til de ekstra sider"

#: xmodule/html_block.py:442
msgid "List of course update items"
msgstr "Liste over kursusopdateringer"

#: xmodule/item_bank_block.py:67 xmodule/library_content_block.py:94
msgid "Count"
msgstr "Tæl"

#: xmodule/item_bank_block.py:68 xmodule/library_content_block.py:95
msgid ""
"Enter the number of components to display to each student. Set it to -1 to "
"display all components."
msgstr ""
"Indtast antallet af komponenter, der skal vises for hver elev. Indstil den "
"til -1 for at vise alle komponenter."

#: xmodule/item_bank_block.py:81
msgid ""
"Determines whether a 'Reset Problems' button is shown, so users may reset "
"their answers and reshuffle selected items."
msgstr ""
"Bestemmer, om knappen &#39;Nulstil problemer&#39; vises, så brugere kan "
"nulstille deres svar og blande valgte elementer."

#: xmodule/item_bank_block.py:474
#, python-brace-format
msgid ""
"The problem bank has been configured to show {count} problems. Please "
"specify a positive number of problems, or specify -1 to show all problems."
msgstr ""
"Problembanken er blevet konfigureret til at vise {count} problemer. Angiv "
"venligst et positivt antal problemer, eller angiv -1 for at vise alle "
"problemer."

#: xmodule/item_bank_block.py:478 xmodule/item_bank_block.py:490
msgid "Edit the problem bank configuration."
msgstr "Rediger problembankens konfiguration."

#: xmodule/item_bank_block.py:486
#, python-brace-format
msgid ""
"The problem bank has been configured to show {count} problems, but only "
"{actual} have been selected."
msgstr ""
"Problembanken er blevet konfigureret til at vise {count} problemer, men kun "
"{actual} er blevet valgt."

#: xmodule/library_content_block.py:51
msgid "Any Type"
msgstr "Enhver type"

#: xmodule/library_content_block.py:83 cms/templates/widgets/header.html:297
msgid "Library"
msgstr "Bibliotek"

#: xmodule/library_content_block.py:84
msgid "Select the library from which you want to draw content."
msgstr "Vælg det bibliotek, hvorfra du ønsker at hente indhold."

#: xmodule/library_content_block.py:90
msgid "Library Version"
msgstr "Bibliotek version"

#: xmodule/library_content_block.py:100
msgid "Problem Type"
msgstr "Opgavetype"

#: xmodule/library_content_block.py:101
msgid ""
"Choose a problem type to fetch from the library. If \"Any Type\" is selected"
" no filtering is applied."
msgstr ""
"Vælg en opgavetype fra biblioteket. Hvis der er valgt \"Enhver Type\", "
"anvendes ingen filtrering."

#: xmodule/library_content_block.py:200
msgid "Source content library has not been specified."
msgstr "Kildeindholdsbiblioteket er ikke specificeret."

#: xmodule/library_content_block.py:204
msgid "Content libraries are not available in the current runtime."
msgstr "Indholdsbiblioteker er ikke tilgængelige i den aktuelle kørsel."

#: xmodule/library_content_block.py:207
#, python-brace-format
msgid "Source content library does not exist: {source_library_id}"
msgstr "Kildeindholdsbiblioteket findes ikke: {source_library_id}"

#: xmodule/library_content_block.py:273
msgid "This component is out of date. The library has new content."
msgstr "Denne komponent er forældet. Biblioteket har nyt indhold."

#. Translators: {refresh_icon} placeholder is substituted to "↻" (without
#. double quotes)
#: xmodule/library_content_block.py:278
#, python-brace-format
msgid "{refresh_icon} Update now."
msgstr "{refresh_icon} Opdater nu."

#: xmodule/library_content_block.py:286
msgid "Library is invalid, corrupt, or has been deleted."
msgstr "Bibliotek er ugyldigt, beskadiget, eller er blevet slettet."

#: xmodule/library_content_block.py:288
msgid "Edit Library List."
msgstr "Rediger Bibliotek Liste."

#: xmodule/library_content_block.py:315
msgid ""
"This course does not support content libraries. Contact your system "
"administrator for more information."
msgstr ""
"Dette kursus understøtter ikke indholdsbiblioteker. Kontakt din "
"systemadministrator for mere information."

#: xmodule/library_content_block.py:325
msgid "A library has not yet been selected."
msgstr "Bibliotek er endnu ikke blevet valgt."

#: xmodule/library_content_block.py:327
msgid "Select a Library."
msgstr "Vælg et bibliotek"

#: xmodule/library_content_block.py:341
#, python-brace-format
msgid "There are no problems in the specified library of type {capa_type}."
msgstr ""
"Der er ingen problemer i det specificerede bibliotek af typen {capa_type}."

#: xmodule/library_content_block.py:344
msgid "Select another problem type."
msgstr "Vælg en anden opgavetype."

#: xmodule/library_content_block.py:355
#, python-brace-format
msgid "The specified library is configured to fetch {count} problem, "
msgid_plural "The specified library is configured to fetch {count} problems, "
msgstr[0] ""
"Det specificerede bibliotek er konfigureret til at hente {count} problem, "
msgstr[1] ""
"Det specificerede bibliotek er konfigureret til at hente {count} problemer, "

#: xmodule/library_content_block.py:360
#, python-brace-format
msgid "but there is only {actual} matching problem."
msgid_plural "but there are only {actual} matching problems."
msgstr[0] "men der er kun {actual} matchende problem."
msgstr[1] "men der er kun {actual} matchende problemer."

#: xmodule/library_content_block.py:366
msgid "Edit the library configuration."
msgstr "Rediger konfiguration for biblioteket."

#: xmodule/library_content_block.py:384
msgid "Invalid Library"
msgstr "Ugyldigt bibliotek"

#: xmodule/library_content_block.py:385
msgid "No Library Selected"
msgstr "Intet bibliotek valgt"

#: xmodule/library_root_xblock.py:32
msgid "Library Display Name"
msgstr "Bibliotek visningsnavn"

#: xmodule/library_root_xblock.py:37
msgid "Enter the names of the advanced components to use in your library."
msgstr "Indtast navnene på de avancerede komponenter til brug i biblioteket."

#: xmodule/lti_block.py:133
msgid ""
"The display name for this component. Analytics reports may also use the "
"display name to identify this component."
msgstr ""
"Visningsnavnet for denne komponent. Analytics-rapporter kan også bruge det "
"viste navn til at identificere denne komponent."

#: xmodule/lti_block.py:140
msgid "LTI ID"
msgstr "LTI-ID"

#: xmodule/lti_block.py:142
#, python-brace-format
msgid ""
"Enter the LTI ID for the external LTI provider.  This value must be the same"
" LTI ID that you entered in the LTI Passports setting on the Advanced "
"Settings page.{break_tag}See {docs_anchor_open}the edX LTI "
"documentation{anchor_close} for more details on this setting."
msgstr ""
"Indtast LTI-id'et for den eksterne LTI-udbyder. Denne værdi skal være det "
"samme LTI ID, som du indtastede i LTI Passports-indstillingen på siden "
"Avancerede indstillinger.{break_tag}Se {docs_anchor_open}edX LTI-"
"dokumentationen{anchor_close} for at få flere oplysninger om denne "
"indstilling."

#: xmodule/lti_block.py:155
msgid "LTI URL"
msgstr "LTI-URL"

#: xmodule/lti_block.py:157
#, python-brace-format
msgid ""
"Enter the URL of the external tool that this component launches. This "
"setting is only used when Hide External Tool is set to False.{break_tag}See "
"{docs_anchor_open}the edX LTI documentation{anchor_close} for more details "
"on this setting."
msgstr ""
"Indtast URL'en på det eksterne værktøj, som denne komponent starter. Denne "
"indstilling bruges kun, når Skjul eksternt værktøj er indstillet til "
"False.{break_tag}Se {docs_anchor_open}edX LTI-dokumentationen{anchor_close} "
"for flere detaljer om denne indstilling."

#: xmodule/lti_block.py:168
msgid "Custom Parameters"
msgstr "tilpassede parametre"

#: xmodule/lti_block.py:170
#, python-brace-format
msgid ""
"Add the key/value pair for any custom parameters, such as the page your "
"e-book should open to or the background color for this "
"component.{break_tag}See {docs_anchor_open}the edX LTI "
"documentation{anchor_close} for more details on this setting."
msgstr ""
"Tilføj nøgle/værdi-parret for eventuelle tilpassede parametre, såsom den "
"side, din e-bog skal åbne til, eller baggrundsfarven for denne "
"komponent.{break_tag}Se {docs_anchor_open}edX LTI-"
"dokumentationen{anchor_close} for flere detaljer om denne indstilling. ."

#: xmodule/lti_block.py:180
msgid "Open in New Page"
msgstr "Åbn i Ny side"

#: xmodule/lti_block.py:182
msgid ""
"Select True if you want students to click a link that opens the LTI tool in "
"a new window. Select False if you want the LTI content to open in an IFrame "
"in the current page. This setting is only used when Hide External Tool is "
"set to False.  "
msgstr ""
"Vælg Sand, hvis du vil have kursisterne til at klikke på et link, der åbner "
"LTI-værktøjet i et nyt vindue. Vælg Falsk, hvis du vil have LTI-indholdet "
"til at åbne i en IFrame på den aktuelle side. Denne indstilling anvendes "
"kun, når Hide Ekstern Tool er sat til Falsk."

#: xmodule/lti_block.py:190
msgid "Scored"
msgstr "Opnåede point"

#: xmodule/lti_block.py:192
msgid ""
"Select True if this component will receive a numerical score from the "
"external LTI system."
msgstr ""
"Vælg Sand, hvis denne komponent skal modtage en numerisk score fra det "
"eksterne LTI-system."

#: xmodule/lti_block.py:198
msgid "Weight"
msgstr "Vægt"

#: xmodule/lti_block.py:200
msgid ""
"Enter the number of points possible for this component.  The default value "
"is 1.0.  This setting is only used when Scored is set to True."
msgstr ""
"Indtast antallet af mulige points for denne komponent. Standardværdien er "
"1,0. Denne indstilling anvendes kun, når Scorede er indstillet til Sand."

#: xmodule/lti_block.py:209
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Scoren indeholdt i xblock KVS - kopiér den offentliggjorte score i/til "
"Django DB"

#: xmodule/lti_block.py:214
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Kommentar som returneret fra grader, LTI2.0 spec"

#: xmodule/lti_block.py:219
msgid "Hide External Tool"
msgstr "Skjul eksternt værktøj"

#: xmodule/lti_block.py:221
msgid ""
"Select True if you want to use this component as a placeholder for syncing "
"with an external grading  system rather than launch an external tool.  This "
"setting hides the Launch button and any IFrames for this component."
msgstr ""
"Vælg Sand, hvis du ønsker at bruge denne komponent som en pladsholder for "
"synkronisering med et ekstern gradueringssystem i stedet for at starte et "
"eksternt værktøj. Denne indstilling skjuler Launch- knappen og eventuelle "
"IFrames til denne komponent."

#: xmodule/lti_block.py:232
msgid "Request user's username"
msgstr "Anmod om brugerens brugernavn"

#. Translators: This is used to request the user's username for a third party
#. service.
#: xmodule/lti_block.py:234
msgid "Select True to request the user's username."
msgstr "Vælg Sandt for at anmode om brugerens brugernavn."

#: xmodule/lti_block.py:239
msgid "Request user's email"
msgstr "Anmod om brugerens e-mail"

#. Translators: This is used to request the user's email for a third party
#. service.
#: xmodule/lti_block.py:241
msgid "Select True to request the user's email address."
msgstr "Vælg Sand for at anmode om brugerens e-mail-adresse"

#: xmodule/lti_block.py:247
msgid "LTI Application Information"
msgstr "LTI-applikationsoplysninger"

#: xmodule/lti_block.py:249
msgid ""
"Enter a description of the third party application. If requesting username "
"and/or email, use this text box to inform users why their username and/or "
"email will be forwarded to a third party application."
msgstr ""
"Indtast en beskrivelse af tredjeparts-applikationen. Hvis der anmodes om "
"brugernavn og/eller e-mail, kan du bruge dette tekstfelt til at informere "
"brugerne om, hvorfor deres brugernavn og/eller e-mail vil blive sendt til en"
" tredjeparts-applikation."

#: xmodule/lti_block.py:257
msgid "Button Text"
msgstr "Knappen Tekst"

#: xmodule/lti_block.py:259
msgid ""
"Enter the text on the button used to launch the third party application."
msgstr ""
"Indtast teksten på knappen, som bruges til at starte tredjeparts-"
"applikationen."

#: xmodule/lti_block.py:266
msgid "Accept grades past deadline"
msgstr "Accepter karakter efter deadline"

#: xmodule/lti_block.py:267
msgid ""
"Select True to allow third party systems to post grades past the deadline."
msgstr ""
"Vælg Sandt for at tillade tredjepartssystemer at give karakterer efter "
"deadline."

#: xmodule/lti_block.py:441
#, python-brace-format
msgid ""
"Could not parse custom parameter: {custom_parameter}. Should be \"x=y\" "
"string."
msgstr ""
"Kunne ikke analysere tilpasset parameter: {custom_parameter}. Bør være \"x ="
" y\" streng."

#: xmodule/lti_block.py:974
#, python-brace-format
msgid ""
"Could not parse LTI passport: {lti_passport}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Kunne ikke parse LTI-pas: {lti_passport}. Bør være \"id:key:secret\"  "
"streng."

#: xmodule/modulestore/inheritance.py:47 xmodule/seq_block.py:78
#: lms/templates/ccx/schedule.html:115
msgid "Due Date"
msgstr "Forfaldsdato"

#: xmodule/modulestore/inheritance.py:48
msgid "Enter the default date by which problems are due."
msgstr "Indtast default dato, hvor opgaver skal afleveres."

#: xmodule/modulestore/inheritance.py:53 xmodule/seq_block.py:84
msgid "Number of Relative Weeks Due By"
msgstr "Antal relative uger, der skal betales"

#: xmodule/modulestore/inheritance.py:54 xmodule/seq_block.py:85
msgid ""
"Enter the number of weeks the problems are due by relative to the learner's "
"enrollment date"
msgstr ""
"Indtast det antal uger, problemerne skal betales af i forhold til elevens "
"tilmeldingsdato"

#: xmodule/modulestore/inheritance.py:70
msgid "GIT URL"
msgstr "GIT-URL"

#: xmodule/modulestore/inheritance.py:71
msgid "Enter the URL for the course data GIT repository."
msgstr "Indtast URL'en for kursets data GIT arkiv."

#: xmodule/modulestore/inheritance.py:75
msgid "XQA Key"
msgstr "XQA nøgle"

#: xmodule/modulestore/inheritance.py:76
msgid "This setting is not currently supported."
msgstr "Denne indstilling understøttes ikke i øjeblikket."

#: xmodule/modulestore/inheritance.py:84
msgid "Enter the ids for the content groups this problem belongs to."
msgstr "Indtast ID for de indholdsgrupper, som denne opgave hører til."

#. Translators: DO NOT translate the words in quotes here, they are
#. specific words for the acceptable values.
#: xmodule/modulestore/inheritance.py:93
msgid ""
"Specify when the Show Answer button appears for each problem. Valid values "
"are \"always\", \"answered\", \"attempted\", \"closed\", \"finished\", "
"\"past_due\", \"correct_or_past_due\", \"after_all_attempts\", "
"\"after_all_attempts_or_correct\", \"attempted_no_past_due\", and \"never\"."
msgstr ""
"Angiv, hvornår knappen Vis svar vises for hvert problem. Gyldige værdier er "
"\"altid\", \"besvaret\", \"forsøgt\", \"lukket\", \"færdig\", \"forfaldne\","
" \"korrekt_eller_forfaldne\", \"efter_alle_forsøg\", "
"\"efter_alle_forsøg_eller_korrekt\", \"forsøg_ikke_forfaldne\" og "
"\"aldrig\"."

#. Translators: DO NOT translate the words in quotes here, they are
#. specific words for the acceptable values.
#: xmodule/modulestore/inheritance.py:107
msgid ""
"Specify when to show answer correctness and score to learners. Valid values "
"are \"always\", \"never\", and \"past_due\"."
msgstr ""
"Angiv, hvornår svar korrekt og score skal vises til eleverne. Gyldige "
"værdier er \"always\", \"never\" og \"past_due\"."

#. Translators: DO NOT translate the words in quotes here, they are
#. specific words for the acceptable values.
#: xmodule/modulestore/inheritance.py:119
msgid ""
"Specify the default for how often variable values in a problem are "
"randomized. This setting should be set to \"never\" unless you plan to "
"provide a Python script to identify and randomize values in most of the "
"problems in your course. Valid values are \"always\", \"onreset\", "
"\"never\", and \"per_student\"."
msgstr ""
"Angiv standard for, hvor ofte variable værdier i en opgave randomiseres. "
"Denne indstilling skal sættes til \"aldrig\", medmindre du planlægger at "
"give en Python-script til at identificere og randomisere værdier i de fleste"
" af opgaverne i dit kursus. Gyldige værdier er \"altid\", \"onReset\", "
"\"aldrig\" og \"pr_studerende\"."

#: xmodule/modulestore/inheritance.py:128
msgid "Days Early for Beta Users"
msgstr "Dage tidligt for betabrugere"

#: xmodule/modulestore/inheritance.py:129
msgid ""
"Enter the number of days before the start date that beta users can access "
"the course."
msgstr ""
"Indtast antallet af dage før startdato, hvor beta-brugere kan få adgang til "
"kurset."

#: xmodule/modulestore/inheritance.py:134
msgid "Static Asset Path"
msgstr "Statisk aktivsti"

#: xmodule/modulestore/inheritance.py:135
msgid ""
"Enter the path to use for files on the Files & Uploads page. This value "
"overrides the Studio default, c4x://."
msgstr ""
"Indtast stien til brug for filer på Filer & Upload siden. Denne værdi "
"overstyrer Studio standard c4x: //."

#: xmodule/modulestore/inheritance.py:140
msgid "Enable LaTeX Compiler"
msgstr "Aktiver LaTeX Compiler"

#: xmodule/modulestore/inheritance.py:141
msgid ""
"Enter true or false. If true, you can use the LaTeX templates for HTML "
"components and advanced Problem components."
msgstr ""
"Indtast sandt eller falsk. Hvis det er sandt, kan du bruge LaTeX- skabeloner"
" til HTML-komponenter og avancerede Opgave komponenter."

#: xmodule/modulestore/inheritance.py:147
msgid ""
"Enter the maximum number of times a student can try to answer problems. By "
"default, Maximum Attempts is set to null, meaning that students have an "
"unlimited number of attempts for problems. You can override this course-wide"
" setting for individual problems. However, if the course-wide setting is a "
"specific number, you cannot set the Maximum Attempts for individual problems"
" to unlimited."
msgstr ""
"Indtast det maksimale antal gange en kursist kan forsøge at besvare en "
"opgave. Som standard er Maksimum Forsøg indstillet til null, hvilket "
"betyder, at kursisterne har et ubegrænset antal forsøg. Du kan styre "
"indstillingen for individuelle opgaver. Men hvis indstillingen, som gælder "
"for hele kurset, er et bestemt antal, kan du ikke sætte Maksimalt antal "
"forsøg til ubegrænset."

#: xmodule/modulestore/inheritance.py:152
msgid ""
"Enter the API key provided by MathWorks for accessing the MATLAB Hosted "
"Service. This key is granted for exclusive use in this course for the "
"specified duration. Do not share the API key with other courses. Notify "
"MathWorks immediately if you believe the key is exposed or compromised. To "
"obtain a key for your course, or to report an issue, please contact "
"moocsupport@mathworks.com"
msgstr ""
"Indtast API-nøglen fra MathWorks for at få adgang til Matlab Hosted Service."
" Denne nøgle gives udelukkende til brug i dette kursus for den angivne "
"varighed. Del ikke API-nøgle med andre kurser. Informer MathWorks straks, "
"hvis du mener, at nøglen er blevet misbrugt eller kompromitteret. For at få "
"en nøgle til dit kursus eller for at rapportere et problem, skal du kontakte"
" moocsupport@mathworks.com"

#: xmodule/modulestore/inheritance.py:162 cms/templates/certificates.html:119
#: cms/templates/group_configurations.html:17
#: cms/templates/group_configurations.html:46 cms/templates/settings.html:709
#: cms/templates/settings_advanced.html:149
#: cms/templates/settings_graders.html:171
#: cms/templates/widgets/header.html:200
msgid "Group Configurations"
msgstr "Gruppekonfiguration"

#: xmodule/modulestore/inheritance.py:163
msgid ""
"Enter the configurations that govern how students are grouped together."
msgstr ""
"Indtast de konfigurationer, der styrer, hvordan kursisterne er samlet i "
"grupper."

#: xmodule/modulestore/inheritance.py:168
msgid "Enable video caching system"
msgstr "Aktivér video caching-system"

#: xmodule/modulestore/inheritance.py:169
msgid ""
"Enter true or false. If true, video caching will be used for HTML5 videos."
msgstr ""
"Indtast sandt eller falsk. Hvis det er sandt, vil video-caching blive brugt "
"til HTML5 videoer."

#: xmodule/modulestore/inheritance.py:174
msgid "Enable video auto-advance"
msgstr "Aktiver automatisk fremrykning af video"

#: xmodule/modulestore/inheritance.py:176
msgid ""
"Specify whether to show an auto-advance button in videos. If the student "
"clicks it, when the last video in a unit finishes it will automatically move"
" to the next unit and autoplay the first video."
msgstr ""
"Angiv, om der skal vises en knap til automatisk fremrykning i videoer. Hvis "
"eleven klikker på den, vil den, når den sidste video i en enhed er færdig, "
"automatisk flytte til den næste enhed og automatisk afspille den første "
"video."

#: xmodule/modulestore/inheritance.py:182
msgid "Video Pre-Roll"
msgstr "Forhåndsafspilningsvideo"

#: xmodule/modulestore/inheritance.py:184
#, python-brace-format
msgid ""
"Identify a video, 5-10 seconds in length, to play before course videos. "
"Enter the video ID from the Video Uploads page and one or more transcript "
"files in the following format: {format}. For example, an entry for a video "
"with two transcripts looks like this: {example}"
msgstr ""
"Identificer en video, 5-10 sekunder lang, til at afspille før kursusvideoer."
" Indtast video-id'et fra siden Videouploads og en eller flere "
"transskriptionsfiler i følgende format: {format}. For eksempel ser en post "
"for en video med to transskriptioner sådan ud: {example}"

#: xmodule/modulestore/inheritance.py:201
msgid "Show Reset Button for Problems"
msgstr "Vis Reset Knap til Opgaver"

#: xmodule/modulestore/inheritance.py:203
msgid ""
"Enter true or false. If true, problems in the course default to always "
"displaying a 'Reset' button. You can override this in each problem's "
"settings. All existing problems are affected when this course-wide setting "
"is changed."
msgstr ""
"Indtast sandt eller falsk. Hvis sandt, vises som standard altid en "
"'Nulstil'-knap. Du kan overstyre dette i indstillingerne for hver opgave. "
"Alle eksisterende opgaver påvirkes for hele kurset, når denne indstilling "
"ændres."

#: xmodule/modulestore/inheritance.py:211
msgid "Enable Student Notes"
msgstr "Aktivér Student Notes"

#: xmodule/modulestore/inheritance.py:212
msgid ""
"Enter true or false. If true, students can use the Student Notes feature."
msgstr ""
"Indtast sandt eller falsk. Hvis sandt, kan kursisterne bruge funktionen "
"Student Notes."

#: xmodule/modulestore/inheritance.py:218
msgid ""
"Indicates whether Student Notes are visible in the course. Students can also"
" show or hide their notes in the courseware."
msgstr ""
"Angiver, om Student Notes er synlige. Kursister kan også vise eller skjule "
"deres noter i kursusmateriale."

#: xmodule/modulestore/inheritance.py:225
msgid "Tag this block as part of an Entrance Exam section"
msgstr "Tag denne blok som en del af en adgangsprøvesektion"

#: xmodule/modulestore/inheritance.py:226
msgid ""
"Enter true or false. If true, answer submissions for problem blocks will be "
"considered in the Entrance Exam scoring/gating algorithm."
msgstr ""
"Indtast sand eller falsk. Hvis det er sandt, vil svarindsendelser for "
"problemblokke blive taget i betragtning i adgangsprøvens scoring/gating-"
"algoritme."

#: xmodule/modulestore/inheritance.py:244
msgid "Hide from Table of Contents"
msgstr "Skjul fra indholdsfortegnelse"

#: xmodule/modulestore/inheritance.py:245
msgid ""
"Enter true or false. If true, this block will be hidden from the Table of "
"Contents."
msgstr ""
"Indtast sandt eller falsk. Hvis sandt, vil denne blok blive skjult i "
"indholdsfortegnelsen."

#: xmodule/modulestore/xml_importer.py:82
msgid "Error while reading {}. Check file for XML errors."
msgstr "Fejl under læsning af {}. Tjek filen for XML-fejl."

#: xmodule/modulestore/xml_importer.py:94
msgid "Failed to import block: {} at location: {}"
msgstr "Kunne ikke importere blok: {} på lokation: {}"

#: xmodule/partitions/enrollment_track_partition_generator.py:38
#: cms/templates/group_configurations.html:86
msgid "Enrollment Track Groups"
msgstr "Tilmeldingssporgrupper"

#: xmodule/partitions/enrollment_track_partition_generator.py:39
msgid "Partition for segmenting users by enrollment track"
msgstr "Opdeling til segmentering af brugere efter tilmeldingsspor"

#: xmodule/poll_block.py:57
msgid "Whether this student has voted on the poll"
msgstr "Om denne elev har stemt i afstemningen"

#: xmodule/poll_block.py:62
msgid "Student answer"
msgstr "Elevens svar"

#: xmodule/poll_block.py:67
msgid "Poll answers from all students"
msgstr "Afstemningssvar fra alle elever"

#: xmodule/poll_block.py:73
msgid "Poll answers from xml"
msgstr "Afstemningssvar fra xml"

#: xmodule/poll_block.py:79
msgid "Poll question"
msgstr "Afstemningsspørgsmål"

#: xmodule/seq_block.py:79
msgid "Enter the date by which problems are due."
msgstr "Angiv forfaldsdato."

#: xmodule/seq_block.py:90
msgid "Hide sequence content After Due Date"
msgstr "Skjul sekvensindhold efter forfaldsdato"

#: xmodule/seq_block.py:92
msgid ""
"If set, the sequence content is hidden for non-staff users after the due "
"date has passed."
msgstr ""
"Hvis den er indstillet, skjules sekvensindholdet for ikke-medarbejdere efter"
" forfaldsdatoen er passeret."

#: xmodule/seq_block.py:99
msgid "Is Entrance Exam"
msgstr "Adgangseksamen"

#: xmodule/seq_block.py:101
msgid ""
"Tag this course block as an Entrance Exam. Note, you must enable Entrance "
"Exams for this course setting to take effect."
msgstr ""
"Tag denne kursusblok som en optagelsesprøve. Bemærk, du skal aktivere "
"adgangsprøver for at denne kursusindstilling kan træde i kraft."

#: xmodule/seq_block.py:152
msgid "Is Time Limited"
msgstr "Tidsbegrænset"

#: xmodule/seq_block.py:154
msgid ""
"This setting indicates whether students have a limited time to view or "
"interact with this courseware component."
msgstr ""
"Denne indstilling angiver, om kursisterne har begrænset tid til at se eller "
"interagere med dette kursusmateriale."

#: xmodule/seq_block.py:162
msgid "Time Limit in Minutes"
msgstr "Tidsbegrænsning i minutter"

#: xmodule/seq_block.py:164
msgid ""
"The number of minutes available to students for viewing or interacting with "
"this courseware component."
msgstr ""
"Antallet af minutter til rådighed for kursister til at se eller interagere "
"med dette kursusmateriale."

#: xmodule/seq_block.py:171
msgid "Is Proctoring Enabled"
msgstr "Er Proctoring aktiveret"

#: xmodule/seq_block.py:173
msgid "This setting indicates whether this exam is a proctored exam."
msgstr ""
"Denne indstilling angiver, om denne eksamen er en proctoreret eksamen."

#: xmodule/seq_block.py:180
msgid "Software Secure Review Rules"
msgstr "Regler for sikker gennemgang af software"

#: xmodule/seq_block.py:182
msgid ""
"This setting indicates what rules the proctoring team should follow when "
"viewing the videos."
msgstr ""
"Denne indstilling angiver, hvilke regler proctoring-teamet skal følge, når "
"de ser videoerne."

#: xmodule/seq_block.py:189
msgid "Is Practice Exam"
msgstr "Praktisk eksamen"

#: xmodule/seq_block.py:191
msgid ""
"This setting indicates whether this exam is for testing purposes only. "
"Practice exams are not verified."
msgstr ""
"Denne indstilling angiver, om denne eksamen kun er til testformål. "
"Praksiseksamener er ikke verificeret."

#: xmodule/seq_block.py:198
msgid "Is Onboarding Exam"
msgstr "Er onboarding eksamen"

#: xmodule/seq_block.py:200
msgid "This setting indicates whether this exam is an onboarding exam."
msgstr "Denne indstilling angiver, om denne eksamen er en onboarding-eksamen."

#: xmodule/seq_block.py:358 xmodule/seq_block.py:450
msgid ""
"This subsection is unlocked for learners when they meet the prerequisite "
"requirements."
msgstr ""
"Denne undersektion er låst op for elever, når de opfylder "
"forudsætningskravene."

#: xmodule/seq_block.py:502
msgid "This exam is hidden from the learner."
msgstr "Denne eksamen er skjult for eleven."

#: xmodule/seq_block.py:511
msgid ""
"Because the course has ended, this assignment is hidden from the learner."
msgstr "Fordi kurset er afsluttet, er denne opgave skjult for eleven."

#: xmodule/seq_block.py:513
msgid ""
"Because the due date has passed, this assignment is hidden from the learner."
msgstr ""
"Da afleveringsdatoen er overskredet, er denne opgave skjult for eleven."

#: xmodule/seq_block.py:557
msgid ""
"This section is a prerequisite. You must complete this section in order to "
"unlock additional content."
msgstr ""
"Dette afsnit er en forudsætning. Du skal udfylde dette afsnit for at låse op"
" for yderligere indhold."

#: xmodule/seq_block.py:996
msgid ""
"A list summarizing what students should look forward to in this section."
msgstr ""
"En liste, der opsummerer, hvad eleverne skal se frem til i dette afsnit."

#: xmodule/split_test_block.py:42
#, python-brace-format
msgid "Group ID {group_id}"
msgstr "Gruppe ID {group_id}"

#: xmodule/split_test_block.py:79
msgid "Not Selected"
msgstr "Ikke valgt"

#: xmodule/split_test_block.py:83
msgid "The display name for this component. (Not shown to learners)"
msgstr "Visningsnavnet for denne komponent. (Vis ikke til elever)"

#: xmodule/split_test_block.py:85
msgid "Content Experiment"
msgstr "Indholdseksperiment"

#: xmodule/split_test_block.py:96
msgid ""
"The configuration defines how users are grouped for this content experiment."
" Caution: Changing the group configuration of a student-visible experiment "
"will impact the experiment data."
msgstr ""
"Konfigurationen definerer, hvordan brugere er grupperet til dette "
"indholdseksperiment. Advarsel: Ændring af gruppekonfigurationen af et elev-"
"synlig-eksperiment vil påvirke data."

#: xmodule/split_test_block.py:98
msgid "Group Configuration"
msgstr "Konfiguration af gruppe"

#: xmodule/split_test_block.py:109
msgid "Which child block students in a particular group_id should see"
msgstr "Hvilken underordnet blok elever i et bestemt group_id skal se"

#: xmodule/split_test_block.py:295
#, python-brace-format
msgid "{group_name} (inactive)"
msgstr "{group_name} (inaktiv)"

#: xmodule/split_test_block.py:635
msgid "The experiment is not associated with a group configuration."
