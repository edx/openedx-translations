msgstr "As {drop_count} menores pontuações de {section_type} são descartadas."

#. Translators: "Homework Average = 0%"
#: xmodule/graders.py:436
#, python-brace-format
msgid "{section_type} Average = {percent:.2%}"
msgstr "Média de {section_type} = {percent:.2%}"

