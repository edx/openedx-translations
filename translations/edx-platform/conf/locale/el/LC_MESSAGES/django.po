msgstr "Αρχείο SubRip (.srt)"

#: xmodule/video_block/video_xfields.py:149
msgid "Text (.txt) file"
msgstr "Αρχείο κειμένου (.txt)"

#: xmodule/video_block/video_xfields.py:154
