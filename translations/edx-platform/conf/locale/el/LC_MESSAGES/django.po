msgstr "{refresh_icon} Ενημέρωση τώρα."

#: xmodule/library_content_block.py:286
msgid "Library is invalid, corrupt, or has been deleted."
msgstr "Η βιβλιοθήκη είναι άκυρη, κατεστραμμένη ή έχει διαγραφεί."

#: xmodule/library_content_block.py:288
msgid "Edit Library List."
msgstr "Επεξεργασία λίστας βιβλιοθηκών."

#: xmodule/library_content_block.py:315
msgid ""
"This course does not support content libraries. Contact your system "
"administrator for more information."
msgstr ""
"Αυτό το μάθημα δεν υποστηρίζει βιβλιοθήκες περιεχομένου. Επικοινωνήστε με "
"τον διαχειριστή του συστήματος για περισσότερες πληροφορίες."

#: xmodule/library_content_block.py:325
msgid "A library has not yet been selected."
msgstr "Δεν έχει επιλεγεί ακόμη βιβλιοθήκη."

#: xmodule/library_content_block.py:327
