#, python-brace-format
msgid "{platform_name} Support"
msgstr "Υποστήριξη {platform_name}"

#: common/djangoapps/third_party_auth/models.py:629
msgid "A configuration nickname."
msgstr "Ένα παρατσούκλι διαμόρφωσης."

