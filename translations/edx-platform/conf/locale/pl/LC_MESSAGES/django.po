msgid ""
"Enter the API key provided by MathWorks for accessing the MATLAB Hosted "
"Service. This key is granted for exclusive use by this course for the "
"specified duration. Please do not share the API key with other courses and "
"notify MathWorks immediately if you believe the key is exposed or "
"compromised. To obtain a key for your course, or to report an issue, please "
"contact moocsupport@mathworks.com"
msgstr ""
"Wprowadź klucz API udostępniony przez MathWorks do dostępu do usługi MATLAB "
"Hosted Service. Klucz ten jest przeznaczony wyłącznie do użytku w ramach "
"tego kursu na określony czas. Prosimy nie udostępniać klucza API innym "
"kursom i niezwłocznie powiadomić MathWorks, jeśli uznasz, że klucz został "
"ujawniony lub skompromitowany. Aby uzyskać klucz dla swojego kursu lub "
"zgłosić problem, skontaktuj się z moocsupport@mathworks.com"

#: xmodule/capa_block.py:344
msgid ""
"Indicates if the problem was edited using the Markdown editor in the "
"Authoring MFE."
msgstr ""
"Informuje, czy zadanie zostało edytowane przy użyciu edytora Markdown w "
"Authoring MFE."

#: xmodule/capa_block.py:435
msgid ""
"We're sorry, there was an error with processing your request. Please try "
"reloading your page and trying again."
msgstr ""
"Przepraszamy, wystąpił błąd podczas przetwarzania Twojego żądania. Spróbuj "
"odświeżyć stronę i spróbować ponownie."

#: xmodule/capa_block.py:440
msgid ""
"The state of this problem has changed since you loaded this page. Please "
"refresh your page."
msgstr ""
"Stan tego zadania zmienił się od momentu załadowania strony. Proszę "
"odświeżyć stronę."

#: xmodule/capa_block.py:786 xmodule/capa_block.py:802
msgid "Answer ID"
msgstr "ID odpowiedzi"

#: xmodule/capa_block.py:787 xmodule/capa_block.py:803
msgid "Question"
msgstr "Pytanie"

#: xmodule/capa_block.py:791
msgid "Correct Answer"
msgstr "Poprawna odpowiedź"

#: xmodule/capa_block.py:1037
msgid "Submitting"
msgstr "Przesyłanie"

#: xmodule/capa_block.py:1167
msgid "Warning: The problem has been reset to its initial state!"
msgstr "Ostrzeżenie: Zadanie zostało zresetowane do stanu początkowego!"

#. Translators: Following this message, there will be a bulleted list of
#. items.
#: xmodule/capa_block.py:1171
msgid ""
"The problem's state was corrupted by an invalid submission. The submission "
"consisted of:"
msgstr ""
"Stan zadania został uszkodzony przez nieprawidłowe zgłoszenie. Zgłoszenie "
"składało się z:"

#: xmodule/capa_block.py:1178
msgid "If this error persists, please contact the course staff."
msgstr "Jeśli błąd będzie się powtarzał, skontaktuj się z kadrą kursu."

#. Translators: {previous_hints} is the HTML of hints that have already been
#. generated, {hint_number_prefix}
#. is a header for this hint, and {hint_text} is the text of the hint itself.
#. This string is being passed to translation only for possible reordering of
#. the placeholders.
#: xmodule/capa_block.py:1233
#, python-brace-format
msgid "{previous_hints}{list_start_tag}{strong_text}{hint_text}</li>"
msgstr "{previous_hints}{list_start_tag}{strong_text}{hint_text}</li>"

#. Translators: e.g. "Hint 1 of 3: " meaning we are showing the first of three
#. hints.
#. This text is shown in bold before the accompanying hint text.
#: xmodule/capa_block.py:1239
#, python-brace-format
msgid "Hint ({hint_num} of {hints_count}): "
msgstr "Podpowiedź ({hint_num} z {hints_count}): "

#: xmodule/capa_block.py:1318
#, python-brace-format
msgid ""
"Your answers were previously saved. Click '{button_name}' to grade them."
msgstr ""
"Twoje odpowiedzi zostały wcześniej zapisane. Kliknij '{button_name}', aby je"
" ocenić."

#: xmodule/capa_block.py:1393
#, python-brace-format
msgid "Incorrect ({progress} point)"
msgid_plural "Incorrect ({progress} points)"
msgstr[0] "Niepoprawne ({progress} punkt)"
msgstr[1] "Niepoprawne ({progress} punkty)"
msgstr[2] "Niepoprawne ({progress} punktów)"
msgstr[3] "Niepoprawne ({progress} punktów)"

#: xmodule/capa_block.py:1402
#, python-brace-format
msgid "Correct ({progress} point)"
msgid_plural "Correct ({progress} points)"
msgstr[0] "Poprawne ({progress} punkt)"
msgstr[1] "Poprawne ({progress} punkty)"
msgstr[2] "Poprawne ({progress} punktów)"
msgstr[3] "Poprawne ({progress} punktów)"

#: xmodule/capa_block.py:1411
#, python-brace-format
msgid "Partially correct ({progress} point)"
msgid_plural "Partially correct ({progress} points)"
msgstr[0] "Częściowo poprawne ({progress} punkt)"
msgstr[1] "Częściowo poprawne ({progress} punkty)"
msgstr[2] "Częściowo poprawne ({progress} punktów)"
msgstr[3] "Częściowo poprawne ({progress} punktów)"

#: xmodule/capa_block.py:1416
msgid "Partially Correct"
msgstr "Częściowo poprawne"

#: xmodule/capa_block.py:1418
msgid "Answer submitted."
msgstr "Odpowiedź przesłana."

#. Translators: 'closed' means the problem's due date has passed. You may no
#. longer attempt to solve the problem.
#: xmodule/capa_block.py:1802 xmodule/capa_block.py:2130
msgid "Problem is closed."
msgstr "Zadanie jest zamknięte."

#: xmodule/capa_block.py:1808
msgid "Problem must be reset before it can be submitted again."
msgstr ""
"Zadanie musi zostać zresetowane, zanim będzie można je ponownie przesłać."

#: xmodule/capa_block.py:1818
#, python-brace-format
msgid "You must wait at least {wait} seconds between submissions."
msgstr "Musisz odczekać co najmniej {wait} sekund między zgłoszeniami."

#: xmodule/capa_block.py:1827
#, python-brace-format
msgid ""
"You must wait at least {wait_secs} between submissions. {remaining_secs} "
"remaining."
msgstr ""
"Musisz odczekać co najmniej {wait_secs} między zgłoszeniami. Pozostało "
"{remaining_secs}."

#: xmodule/capa_block.py:2010
#, python-brace-format
msgid "{num_hour} hour"
msgid_plural "{num_hour} hours"
msgstr[0] "{num_hour} godzina"
msgstr[1] "{num_hour} godziny"
msgstr[2] "{num_hour} godzin"
msgstr[3] "{num_hour} godzin"

#: xmodule/capa_block.py:2015
#, python-brace-format
msgid "{num_minute} minute"
msgid_plural "{num_minute} minutes"
msgstr[0] "{num_minute} minuta"
msgstr[1] "{num_minute} minuty"
