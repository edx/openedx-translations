msgstr "Ukryj stronę przed uczniami"

#: xmodule/html_block.py:414
msgid ""
"If you select this option, only course team members with the Staff or Admin "
"role see this page."
msgstr ""
"Jeśli wybierzesz tę opcję, stronę zobaczą tylko członkowie zespołu kursu z "
"rolą personelu lub administratora."

#: xmodule/html_block.py:424
msgid "HTML for the additional pages"
msgstr "HTML dla dodatkowych stron"

#: xmodule/html_block.py:442
msgid "List of course update items"
msgstr "Lista elementów aktualizacji kursu"

#: xmodule/item_bank_block.py:67 xmodule/library_content_block.py:94
msgid "Count"
msgstr "Liczba"

#: xmodule/item_bank_block.py:68 xmodule/library_content_block.py:95
msgid ""
"Enter the number of components to display to each student. Set it to -1 to "
"display all components."
msgstr ""
"Wprowadź liczbę komponentów, które mają być wyświetlane dla każdego "
"studenta. Ustaw -1, aby wyświetlić wszystkie."

#: xmodule/item_bank_block.py:81
msgid ""
"Determines whether a 'Reset Problems' button is shown, so users may reset "
"their answers and reshuffle selected items."
msgstr ""
"Określa, czy wyświetlany jest przycisk 'Reset Problems', umożliwiający "
"użytkownikom resetowanie odpowiedzi i przetasowywanie wybranych elementów."

#: xmodule/item_bank_block.py:474
#, python-brace-format
msgid ""
"The problem bank has been configured to show {count} problems. Please "
"specify a positive number of problems, or specify -1 to show all problems."
msgstr ""
"Bank zadań został skonfigurowany do wyświetlania {count} zadań. Proszę podać"
" dodatnią liczbę zadań lub -1, aby wyświetlić wszystkie."

#: xmodule/item_bank_block.py:478 xmodule/item_bank_block.py:490
msgid "Edit the problem bank configuration."
msgstr "Edytuj konfigurację banku zadań."

#: xmodule/item_bank_block.py:486
#, python-brace-format
msgid ""
"The problem bank has been configured to show {count} problems, but only "
"{actual} have been selected."
msgstr ""
"Bank zadań został skonfigurowany do wyświetlania {count} zadań, ale wybrano "
"tylko {actual}."

#: xmodule/library_content_block.py:51
msgid "Any Type"
msgstr "Dowolny typ"

#: xmodule/library_content_block.py:83 cms/templates/widgets/header.html:297
msgid "Library"
msgstr "Biblioteka"

#: xmodule/library_content_block.py:84
msgid "Select the library from which you want to draw content."
msgstr "Wybierz bibliotekę, z której chcesz pobierać treści."

#: xmodule/library_content_block.py:90
msgid "Library Version"
msgstr "Wersja biblioteki"

#: xmodule/library_content_block.py:100
msgid "Problem Type"
msgstr "Typ zadania"

#: xmodule/library_content_block.py:101
msgid ""
"Choose a problem type to fetch from the library. If \"Any Type\" is selected"
" no filtering is applied."
msgstr ""
"Wybierz typ zadania do pobrania z biblioteki. Jeśli wybrano \"Dowolny typ\","
" nie stosuje się filtrowania."

#: xmodule/library_content_block.py:200
msgid "Source content library has not been specified."
msgstr "Nie określono źródłowej biblioteki treści."

#: xmodule/library_content_block.py:204
msgid "Content libraries are not available in the current runtime."
msgstr "Biblioteki treści nie są dostępne w bieżącym środowisku wykonawczym."

#: xmodule/library_content_block.py:207
#, python-brace-format
msgid "Source content library does not exist: {source_library_id}"
msgstr "Źródłowa biblioteka treści nie istnieje: {source_library_id}"

