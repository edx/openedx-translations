msgid ""
"Press {link_start}View{link_end} to preview, sync/update, and/or remove the "
"selected components."
msgstr ""
"Naciśnij {link_start}View{link_end}, aby wyświetlić podgląd, "
"zsynchronizować/aktualizować lub usunąć wybrane komponenty."

#: xmodule/templates/item_bank/author_view.html:38
#, python-brace-format
msgid ""
"Press {link_start}Edit{link_end} to configure how many will be shown and "
"other settings."
msgstr ""
"Naciśnij {link_start}Edit{link_end}, aby skonfigurować, ile zostanie "
"wyświetlonych, oraz inne ustawienia."

#: xmodule/templates/item_bank/author_view.html:44
msgid "You have not selected any components yet."
msgstr "Nie wybrałeś jeszcze żadnych komponentów."

#: xmodule/templates/item_bank/author_view_add.html:11
