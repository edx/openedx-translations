msgstr "입력 유형의 상태를 유지하기 위한 딕셔너리"

#: xmodule/capa_block.py:297
msgid "Dictionary with the current student responses"
msgstr "현재 학생 답변을 담은 딕셔너리"

#: xmodule/capa_block.py:299
