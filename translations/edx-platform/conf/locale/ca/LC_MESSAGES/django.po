msgstr "No pot ser el mateix que el vostre correu d'inici de sessió."

#: common/djangoapps/student/views/management.py:825
msgid "Unable to send email activation link. Please try again later."
msgstr ""
"No s'ha pogut enviar l'enllaç d'activació per correu. Si us plau, torneu-ho "
"a provar més tard."

#: common/djangoapps/third_party_auth/admin.py:73
msgid "Deleted the selected configuration(s)."
msgstr "S'han suprimit la(s) configuració(ons) seleccionada(s)."

#: common/djangoapps/third_party_auth/admin.py:93
msgid "Delete the selected configuration"
msgstr "Suprimeix la configuració seleccionada"

#: common/djangoapps/third_party_auth/middleware.py:45
msgid "Unable to connect with the external provider, please try again"
msgstr ""
"No s'ha pogut connectar amb el proveïdor extern, si us plau torneu-ho a "
