msgstr ""
"Aquest curs no admet llibreries de contingut. Contacta amb l'administrador "
"del sistema per obtenir més informació."

#: xmodule/library_content_block.py:325
msgid "A library has not yet been selected."
msgstr "Encara no s'ha seleccionat cap llibreria."

#: xmodule/library_content_block.py:327
