msgid "Choose a File to Import"
msgstr "Trieu un fitxer per importar"

#: cms/templates/import.html:82
msgid "File Chosen:"
msgstr "Fitxer seleccionat:"

#: cms/templates/import.html:90
msgid "Replace my library with the selected file"
msgstr "Substitueix la meva biblioteca pel fitxer seleccionat"

#: cms/templates/import.html:92
msgid "Replace my course with the selected file"
msgstr "Substitueix el meu curs pel fitxer seleccionat"

