#: cms/templates/library.html:93
msgid "Using library content in courses"
msgstr "Utilitzar contingut de la biblioteca en els cursos"

#: cms/templates/library.html:94
#, python-brace-format
msgid ""
"Use library content in courses by adding the "
"{em_start}library_content{em_end} policy key to the Advanced Module List in "
"the course's Advanced Settings, then adding a Randomized Content Block to "
"your courseware. In the settings for each Randomized Content Block, select "
"this library as the source library, and specify the number of problems to be"
" randomly selected and displayed to each student."
msgstr ""
"Utilitza contingut de la biblioteca en els cursos afegint la clau de "
"política {em_start}library_content{em_end} a la Llista de Modules Avançats a"
" la configuració avançada del curs, i després afegeix un Bloc de Contingut "
"Aleatori al teu material del curs. En la configuració de cada Bloc de "
"Contingut Aleatori, selecciona aquesta biblioteca com a biblioteca d'origen "
"i especifica el nombre de problemes que es seleccionaran i mostraran de "
"manera aleatòria a cada estudiant."

