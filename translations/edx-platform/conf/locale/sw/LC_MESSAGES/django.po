#: xmodule/course_block.py:326
msgid "LTI Passports"
msgstr "Visa za LTI"

#: xmodule/course_block.py:327
msgid ""
"Enter the passports for course LTI tools in the following format: "
"\"id:client_key:client_secret\"."
msgstr ""
"Weka visa kwa zana za LTI za kozi kwa muundo ufuatao: "
"\"id:client_key:client_secret\"."

#: xmodule/course_block.py:331
msgid ""
"List of Textbook objects with (title, url) for textbooks used in this course"
msgstr ""
"Orodha ya vitabu vya somo pamoja na (kichwa, url) vinavyotumika katika kozi "
"hii"

#: xmodule/course_block.py:336
msgid "Slug that points to the wiki for this course"
msgstr "Slug inayoelekeza kwenye wiki ya kozi hii"

#: xmodule/course_block.py:338
msgid "Date that enrollment for this class is opened"
msgstr "Tarehe ya kuanza kujiandikisha kwa darasa hili"

#: xmodule/course_block.py:342
msgid "Date that enrollment for this class is closed"
msgstr "Tarehe ya kufungwa kwa kujiandikisha kwa darasa hili"

#: xmodule/course_block.py:344
msgid "Start time when this block is visible"
msgstr "Muda wa kuanza ambapo kipande hiki kinaonekana"

#: xmodule/course_block.py:348
msgid "Date that this class ends"
msgstr "Tarehe ya kumalizika kwa darasa hili"

#: xmodule/course_block.py:350
msgid "Date that certificates become available to learners"
msgstr "Tarehe ambayo vyeti vinakuwa vinapatikana kwa wanafunzi"

#: xmodule/course_block.py:354
msgid "Cosmetic Course Display Price"
msgstr "Bei ya uonekano wa kozi"

#: xmodule/course_block.py:356
msgid ""
"The cost displayed to students for enrolling in the course. If a paid course"
" registration price is set by an administrator in the database, that price "
"will be displayed instead of this one."
msgstr ""
"Gharama zinazoonyeshwa kwa wanafunzi wakati wa kujiandikisha kwenye kozi. "
"Ikiwa bei ya usajili wa kozi iliyolipishwa imesanidiwa na msimamizi kwenye "
"hifadhidata, hiyo bei itaonyeshwa badala yake."

#: xmodule/course_block.py:363
msgid "Course Advertised Start"
msgstr "Mwanzo wa kozi uliotangazwa"

#: xmodule/course_block.py:365
msgid ""
"Enter the text that you want to use as the advertised starting time frame "
"for the course, such as \"Winter 2018\". If you enter null for this value, "
"the start date that you have set for this course is used."
msgstr ""
"Weka maandishi unayotaka kutumia kama kipindi cha mwanzo kinachotangazwa kwa"
" kozi, kama vile \"Winter 2018\". Ikiwa utaweka null kwa thamani hii, tarehe"
" ya kuanza uliyoweka kwa kozi hii itatumika."

#: xmodule/course_block.py:372
msgid "Pre-Requisite Courses"
msgstr "Kozi zinazohitajika kwanza"

#: xmodule/course_block.py:373
msgid "Pre-Requisite Course key if this course has a pre-requisite course"
msgstr ""
"Ufunguzi wa kozi ya awali ikiwa kozi hii ina kozi inayohitajika kwanza"

#: xmodule/course_block.py:377
msgid "Grading policy definition for this class"
msgstr "Ufafanuzi wa sera ya tathmini kwa darasa hili"

#: xmodule/course_block.py:382
msgid "Show Calculator"
msgstr "Onyesha kikokotoo"

#: xmodule/course_block.py:383
msgid ""
"Enter true or false. When true, students can see the calculator in the "
"course."
msgstr ""
"Weka true au false. Ikiwa ni true, wanafunzi wanaweza kuona kikokotoo katika"
" kozi."

#: xmodule/course_block.py:388
msgid "Enter the name of the course as it should appear in the course list."
msgstr "Weka jina la kozi kama linavyopaswa kuonekana kwenye orodha ya kozi."

#: xmodule/course_block.py:390
msgid "Course Display Name"
msgstr "Jina la uonyesho la kozi"

#: xmodule/course_block.py:394 xmodule/modulestore/inheritance.py:63
msgid "Course Editor"
msgstr "Mhariri wa kozi"

#: xmodule/course_block.py:395 xmodule/modulestore/inheritance.py:64
msgid "Enter the method by which this course is edited (\"XML\" or \"Studio\")."
msgstr "Weka njia inayotumika kubadilisha kozi hii (\"XML\" au \"Studio\")."

#: xmodule/course_block.py:402
msgid "Course Survey URL"
msgstr "URL ya utafiti wa kozi"

#: xmodule/course_block.py:403
msgid ""
"Enter the URL for the end-of-course survey. If your course does not have a "
"survey, enter null."
msgstr ""
"Weka URL ya utafiti wa mwisho wa kozi. Ikiwa kozi yako haina utafiti, weka "
"null."

#: xmodule/course_block.py:408
msgid "Discussion Blackout Dates"
msgstr "Tarehe za kuzimisha mijadala"

#: xmodule/course_block.py:410
msgid ""
"Enter pairs of dates between which students cannot post to discussion "
"forums. Inside the provided brackets, enter an additional set of square "
"brackets surrounding each pair of dates you add. Format each pair of dates "
"as [\"YYYY-MM-DD\", \"YYYY-MM-DD\"]. To specify times as well as dates, "
"format each pair as [\"YYYY-MM-DDTHH:MM\", \"YYYY-MM-DDTHH:MM\"]. Be sure to"
" include the \"T\" between the date and time. For example, an entry defining"
" two blackout periods looks like this, including the outer pair of square "
"brackets: [[\"2015-09-15\", \"2015-09-21\"], [\"2015-10-01\", "
"\"2015-10-08\"]] "
msgstr ""
"Weka jozi za tarehe kati ya ambazo wanafunzi hawawezi kuweka machapisho "
"kwenye majukwaa ya mijadala. Ndani ya mabano yaliyotolewa, weka seti ya "
"mabano ya mraba yanayozunguka kila jozi ya tarehe unayoongeza. Andaa kila "
"jozi ya tarehe kama [\"YYYY-MM-DD\", \"YYYY-MM-DD\"]. Ili kubainisha nyakati"
" pamoja na tarehe, andaa kila jozi kama [\"YYYY-MM-DDTHH:MM\", \"YYYY-MM-"
"DDTHH:MM\"]. Hakikisha unajumuisha \"T\" kati ya tarehe na nyakati. Kwa "
"mfano, ingizo linalobainisha vipindi mbili vya kuzimwa linaonekana hivi, "
"ikiwa pamoja na mabano ya nje ya mraba: [[\"2015-09-15\", \"2015-09-21\"], "
"[\"2015-10-01\", \"2015-10-08\"]]"

#: xmodule/course_block.py:420
msgid "Discussion Topic Mapping"
msgstr "Ramani ya mada za mijadala"

#: xmodule/course_block.py:422
msgid ""
"Enter discussion categories in the following format: \"CategoryName\": "
"{\"id\": \"i4x-InstitutionName-CourseNumber-course-CourseRun\"}. For "
"example, one discussion category may be \"Lydian Mode\": {\"id\": "
"\"i4x-UniversityX-MUS101-course-2015_T1\"}. The \"id\" value for each "
"category must be unique. In \"id\" values, the only special characters that "
"are supported are underscore, hyphen, and period. You can also specify a "
"category as the default for new posts in the Discussion page by setting its "
"\"default\" attribute to true. For example, \"Lydian Mode\": {\"id\": "
"\"i4x-UniversityX-MUS101-course-2015_T1\", \"default\": true}."
msgstr ""
"Weka makundi ya mijadala kwa muundo ufuatao: \"CategoryName\": {\"id\": "
"\"i4x-InstitutionName-CourseNumber-course-CourseRun\"}. Kwa mfano, kundi "
"moja la mijadala linaweza kuwa \"Lydian Mode\": {\"id\": \"i4x-UniversityX-"
"MUS101-course-2015_T1\"}. Thamani ya \"id\" kwa kila kundi lazima iwe ya "
"kipekee. Katika thamani za \"id\", alama maalum zinazotegemea ni underscore,"
" hypen, na period. Unaweza pia kubainisha kundi kama la msingi kwa "
"machapisho mapya kwenye ukurasa wa Mijadala kwa kuweka sifa yake ya "
"\"default\" kuwa true. Kwa mfano, \"Lydian Mode\": {\"id\": "
"\"i4x-UniversityX-MUS101-course-2015_T1\", \"default\": true}."

#: xmodule/course_block.py:434
msgid "Discussions Plugin Settings"
msgstr "Mipangilio ya plugin za mijadala"

#: xmodule/course_block.py:436
msgid "Settings for discussions plugins."
msgstr "Mipangilio ya plugin za mijadala."

#: xmodule/course_block.py:444
msgid "Course Announcement Date"
msgstr "Tarehe ya tangazo la kozi"

#: xmodule/course_block.py:445
msgid "Enter the date to announce your course."
msgstr "Weka tarehe ya kutangaza kozi yako."

#: xmodule/course_block.py:449
msgid "Cohort Configuration"
msgstr "Usanidi wa kikundi"

#: xmodule/course_block.py:451
msgid ""
"Enter policy keys and values to enable the cohort feature, define automated "
"student assignment to groups, or identify any course-wide discussion topics "
"as private to cohort members."
msgstr ""
"Weka funguo na thamani za sera ili kuwezesha kipengele cha kikundi, "
"kufafanua ugawaji wa wanafunzi kwa makundi kwa njia ya kiotomatiki, au "
"kubainisha mada za mijadala ya kozi nzima kuwa za kibinafsi kwa wanachama wa"
" kikundi."

#: xmodule/course_block.py:457
msgid "Course Is New"
msgstr "Kozi ni mpya"

#: xmodule/course_block.py:459
msgid ""
"Enter true or false. If true, the course appears in the list of new courses,"
" and a New! badge temporarily appears next to the course image."
msgstr ""
"Weka true au false. Ikiwa ni true, kozi huonekana kwenye orodha ya kozi "
"mpya, na alama ya \"New!\" huonekana kwa muda karibu na picha ya kozi."

#: xmodule/course_block.py:465
msgid "Mobile Course Available"
msgstr "Kozi ya simu inapatikana"

#: xmodule/course_block.py:466
msgid ""
"Enter true or false. If true, the course will be available to mobile "
"devices."
msgstr ""
"Weka true au false. Ikiwa ni true, kozi itapatikana kwenye vifaa vya simu."

#: xmodule/course_block.py:471
msgid "Video Upload Credentials"
msgstr "Vyeti vya kupakia video"

#: xmodule/course_block.py:473
#, python-brace-format
msgid ""
"Enter the unique identifier for your course's video files provided by "
"{platform_name}."
msgstr ""
"Weka kitambulisho cha kipekee kwa faili za video za kozi yako zilizotolewa "
"na {platform_name}."

#: xmodule/course_block.py:478
msgid "Course Not Graded"
msgstr "Kozi haitapewa tathmini"

#: xmodule/course_block.py:479
msgid "Enter true or false. If true, the course will not be graded."
msgstr "Weka true au false. Ikiwa ni true, kozi haitapewa tathmini."

#: xmodule/course_block.py:484
msgid "Disable Progress Graph"
msgstr "Zima chati ya maendeleo"

#: xmodule/course_block.py:485
msgid "Enter true or false. If true, students cannot view the progress graph."
msgstr ""
"Weka true au false. Ikiwa ni true, wanafunzi hawawezi kuona chati ya "
"maendeleo."

#: xmodule/course_block.py:490
msgid "PDF Textbooks"
msgstr "Vitabu vya somo vya PDF"

#: xmodule/course_block.py:491
msgid "List of dictionaries containing pdf_textbook configuration"
msgstr "Orodha ya kamusi zinazoonyesha usanidi wa pdf_textbook"

#: xmodule/course_block.py:494
msgid "HTML Textbooks"
msgstr "Vitabu vya somo vya HTML"

#: xmodule/course_block.py:496
msgid ""
"For HTML textbooks that appear as separate tabs in the course, enter the "
"name of the tab (usually the title of the book) as well as the URLs and "
"titles of each chapter in the book."
msgstr ""
"Kwa vitabu vya HTML vinavyoonekana kama vichupo tofauti kwenye kozi, weka "
"jina la kicho (ambacho kwa kawaida ni kichwa cha kitabu) pamoja na URLs na "
"vichwa vya kila sura ya kitabu."

#: xmodule/course_block.py:502
msgid "Remote Gradebook"
msgstr "Kitabu cha alama cha mbali"

#: xmodule/course_block.py:504
msgid ""
"Enter the remote gradebook mapping. Only use this setting when "
"REMOTE_GRADEBOOK_URL has been specified."
msgstr ""
"Weka ramani ya kitabu cha alama cha mbali. Tumia mpangilio huu tu wakati "
"REMOTE_GRADEBOOK_URL imewekwa."

#. Translators: Custom Courses for edX (CCX) is an edX feature for re-using
#. course content. CCX Coach is
#. a role created by a course Instructor to enable a person (the "Coach") to
#. manage the custom course for
#. his students.
#: xmodule/course_block.py:513
msgid "Enable CCX"
msgstr "Wezesha CCX"

#. Translators: Custom Courses for edX (CCX) is an edX feature for re-using
#. course content. CCX Coach is
#. a role created by a course Instructor to enable a person (the "Coach") to
#. manage the custom course for
#. his students.
#: xmodule/course_block.py:518
#, python-brace-format
msgid ""
"Allow course instructors to assign CCX Coach roles, and allow coaches to "
"manage Custom Courses on {platform_name}. When false, Custom Courses cannot "
"be created, but existing Custom Courses will be preserved."
msgstr ""
"Wezesha waelimishaji wa kozi kugawa majukumu ya CCX Coach, na waache "
"wakufunzi kusimamia kozi binafsi kwenye {platform_name}. Ikiwa ni false, "
"kozi binafsi hazitaweza kuundwa, lakini zile zilizopo zitahifadhiwa."

#. Translators: Custom Courses for edX (CCX) is an edX feature for re-using
#. course content.
#: xmodule/course_block.py:527
msgid "CCX Connector URL"
msgstr "URL ya CCX Connector"

#: xmodule/course_block.py:530
msgid ""
"URL for CCX Connector application for managing creation of CCXs. (optional)."
" Ignored unless 'Enable CCX' is set to 'true'."
msgstr ""
"URL ya programu ya CCX Connector kwa kusimamia uundaji wa CCX. (Hiari). "
"Inapuuzwa isipokuwa 'Enable CCX' imesetiwa kuwa 'true'."

#: xmodule/course_block.py:536
msgid "Allow Anonymous Discussion Posts"
msgstr "Wezesha machapisho ya mijadala bila kujulikana"

#: xmodule/course_block.py:537
msgid ""
"Enter true or false. If true, students can create discussion posts that are "
"anonymous to all users."
msgstr ""
"Weka true au false. Ikiwa ni true, wanafunzi wanaweza kuunda machapisho ya "
"mijadala ambayo hayajulikani kwa watumiaji wote."

#: xmodule/course_block.py:541
msgid "Allow Anonymous Discussion Posts to Peers"
msgstr "Wezesha machapisho ya mijadala bila kujulikana kwa wenzako"

#: xmodule/course_block.py:543
msgid ""
"Enter true or false. If true, students can create discussion posts that are "
"anonymous to other students. This setting does not make posts anonymous to "
"course staff."
msgstr ""
"Weka true au false. Ikiwa ni true, wanafunzi wanaweza kuunda machapisho ya "
"mijadala ambayo hayajulikani kwa wanafunzi wengine. Mpangilio huu haufanyii "
"machapisho kuwa ya siri kwa wafanyakazi wa kozi."

#: xmodule/course_block.py:549 xmodule/library_root_xblock.py:36
msgid "Advanced Module List"
msgstr "Orodha ya moduli za juu"

#: xmodule/course_block.py:550
msgid "Enter the names of the advanced modules to use in your course."
msgstr "Weka majina ya moduli za juu zitakazotumika kwenye kozi yako."

#: xmodule/course_block.py:556
msgid ""
"True if timezones should be shown on dates in the course. Deprecated in "
"favor of due_date_display_format."
msgstr ""
"True ikiwa maeneo ya saa yanapaswa kuonyeshwa kwenye tarehe za kozi. "
"Imetolewa matumizi yake badala ya due_date_display_format."

#: xmodule/course_block.py:562
msgid "Due Date Display Format"
msgstr "Muundo wa uonyeshaji wa tarehe ya kukabidhiwa"

#: xmodule/course_block.py:564
msgid ""
"Enter the format for due dates. The default is Mon DD, YYYY. Enter "
"\"%m-%d-%Y\" for MM-DD-YYYY, \"%d-%m-%Y\" for DD-MM-YYYY, \"%Y-%m-%d\" for "
"YYYY-MM-DD, or \"%Y-%d-%m\" for YYYY-DD-MM."
msgstr ""
"Weka muundo wa tarehe za kukabidhiwa. Sehemu chaguo ni Mon DD, YYYY. Weka "
"\"%m-%d-%Y\" kwa MM-DD-YYYY, \"%d-%m-%Y\" kwa DD-MM-YYYY, \"%Y-%m-%d\" kwa "
"YYYY-MM-DD, au \"%Y-%d-%m\" kwa YYYY-DD-MM."

#: xmodule/course_block.py:570
msgid "External Login Domain"
msgstr "Eneo la kuingia la nje"

#: xmodule/course_block.py:571
msgid "Enter the external login method students can use for the course."
msgstr ""
"Weka njia ya kuingia ya nje ambayo wanafunzi wanaweza kuitumia kwa kozi."

#: xmodule/course_block.py:575
msgid "Certificates Downloadable Before End"
msgstr "Vyeti vinavyopatikana kupakuliwa kabla ya kumalizika"

#: xmodule/course_block.py:577
msgid ""
"Enter true or false. If true, students can download certificates before the "
"course ends, if they've met certificate requirements."
msgstr ""
"Weka true au false. Ikiwa ni true, wanafunzi wanaweza kupakua vyeti kabla ya"
" kozi kumalizika, ikiwa wamekutana na mahitaji ya vyeti."

#: xmodule/course_block.py:586 cms/templates/settings.html:257
msgid "Certificates Display Behavior"
msgstr "Tabia ya uonyeshaji wa vyeti"

#: xmodule/course_block.py:588
msgid ""
"This field, together with certificate_available_date will determine when a "
"user can see their certificate for the course"
msgstr ""
"Uwanja huu, pamoja na certificate_available_date, utaamua lini mtumiaji "
"anaweza kuona cheti chake cha kozi."

#: xmodule/course_block.py:595
msgid "Course About Page Image"
msgstr "Picha ya ukurasa wa \"Kuhusu Kozi\""

#: xmodule/course_block.py:597
msgid ""
"Edit the name of the course image file. You must upload this file on the "
"Files & Uploads page. You can also set the course image on the Settings & "
"Details page."
msgstr ""
"Hariri jina la faili la picha ya kozi. Lazima upakue faili hilo kwenye "
"ukurasa wa Faili & Upakiaji. Pia unaweza kuweka picha ya kozi kwenye ukurasa"
" wa Mipangilio & Maelezo."

#: xmodule/course_block.py:606 cms/templates/settings.html:490
#: cms/templates/settings.html:494 cms/templates/settings.html:506
msgid "Course Banner Image"
msgstr "Picha ya bannia ya kozi"

#: xmodule/course_block.py:608
msgid ""
"Edit the name of the banner image file. You can set the banner image on the "
"Settings & Details page."
msgstr ""
"Hariri jina la faili la picha ya bani. Unaweza kuweka picha ya bani kwenye "
"ukurasa wa Mipangilio & Maelezo."

#: xmodule/course_block.py:616 cms/templates/settings.html:523
msgid "Course Video Thumbnail Image"
msgstr "Picha ndogo ya video ya kozi"

#: xmodule/course_block.py:618
msgid ""
"Edit the name of the video thumbnail image file. You can set the video "
"thumbnail image on the Settings & Details page."
msgstr ""
"Hariri jina la faili la picha ndogo ya video. Unaweza kuweka picha ndogo ya "
"video kwenye ukurasa wa Mipangilio & Maelezo."

#: xmodule/course_block.py:628
msgid ""
"Use this setting only when generating PDF certificates. Between quotation "
"marks, enter the short name of the type of certificate that students receive"
" when they complete the course. For instance, \"Certificate\"."
msgstr ""
"Tumia mpangilio huu tu wakati wa kutengeneza vyeti vya PDF. Kati ya alama za"
" nukuu, weka jina fupi la aina ya cheti ambacho wanafunzi wanapokea "
"wanapomaliza kozi. Kwa mfano, \"Certificate\"."

#: xmodule/course_block.py:632
msgid "Certificate Name (Short)"
msgstr "Jina la cheti (fupi)"

#: xmodule/course_block.py:638
msgid ""
"Use this setting only when generating PDF certificates. Between quotation "
"marks, enter the long name of the type of certificate that students receive "
"when they complete the course. For instance, \"Certificate of Achievement\"."
msgstr ""
"Tumia mpangilio huu tu wakati wa kutengeneza vyeti vya PDF. Kati ya alama za"
" nukuu, weka jina refu la aina ya cheti ambacho wanafunzi wanapokea "
"wanapomaliza kozi. Kwa mfano, \"Certificate of Achievement\"."

#: xmodule/course_block.py:642
msgid "Certificate Name (Long)"
msgstr "Jina la cheti (refu)"

#: xmodule/course_block.py:647
msgid "Certificate Web/HTML View Enabled"
msgstr "Maonyesho ya cheti ya Web/HTML yamewezeshwa"

#: xmodule/course_block.py:648
msgid "If true, certificate Web/HTML views are enabled for the course."
msgstr "Ikiwa ni true, maonyesho ya cheti ya Web/HTML yamewezeshwa kwa kozi."

#. Translators: This field is the container for course-specific certificate
#. configuration values
#: xmodule/course_block.py:655
msgid "Certificate Web/HTML View Overrides"
msgstr "Vipengele vinavyobadilisha maonyesho ya cheti ya Web/HTML"

#. Translators: These overrides allow for an alternative configuration of the
#. certificate web view
#: xmodule/course_block.py:657
msgid ""
"Enter course-specific overrides for the Web/HTML template parameters here "
"(JSON format)"
msgstr ""
"Weka vipengele vinavyobadilisha maalum vya kozi kwa vigezo vya muundo wa "
"Web/HTML hapa (muundo wa JSON)"

#. Translators: This field is the container for course-specific certificate
#. configuration values
#: xmodule/course_block.py:664
msgid "Certificate Configuration"
msgstr "Usanidi wa vyeti"

#. Translators: These overrides allow for an alternative configuration of the
#. certificate web view
#: xmodule/course_block.py:666
msgid "Enter course-specific configuration information here (JSON format)"
msgstr "Weka taarifa za usanidi maalum wa kozi hapa (muundo wa JSON)"

#: xmodule/course_block.py:680
msgid "CSS Class for Course Reruns"
msgstr "Daraja la CSS kwa kurudia kozi"

#: xmodule/course_block.py:681
msgid ""
"Allows courses to share the same css class across runs even if they have "
"different numbers."
msgstr ""
"Inaruhusu kozi kugawana daraja lile lile la CSS katika kurudia hata kama "
"zina nambari tofauti."

#: xmodule/course_block.py:692
msgid "Discussion Forum External Link"
msgstr "Kiungo cha nje cha jukwaa la mijadala"

#: xmodule/course_block.py:693
msgid "Allows specification of an external link to replace discussion forums."
msgstr "Inaruhusu kubainisha kiungo cha nje kubadilisha majukwaa ya mijadala."

#: xmodule/course_block.py:702
msgid "Hide Progress Tab"
msgstr "Ficha kichupo cha maendeleo"

#: xmodule/course_block.py:703
msgid "Allows hiding of the progress tab."
msgstr "Inaruhusu kuficha kichupo cha maendeleo."

#: xmodule/course_block.py:709
msgid "Course Organization Display String"
msgstr "Maonyesho ya shirika la kozi"

#: xmodule/course_block.py:711
msgid ""
"Enter the course organization that you want to appear in the course. This "
"setting overrides the organization that you entered when you created the "
"course. To use the organization that you entered when you created the "
"course, enter null."
msgstr ""
"Weka shirika la kozi unalotaka kuonekana kwenye kozi. Mpangilio huu "
"unalipuka shirika ulilioweka wakati ulipoanzisha kozi. Ili kutumia shirika "
"ulilioweka wakati wa kuzindua kozi, weka null."

#: xmodule/course_block.py:719
msgid "Course Number Display String"
msgstr "Muonekano wa nambari ya kozi"

#: xmodule/course_block.py:721
msgid ""
"Enter the course number that you want to appear in the course. This setting "
"overrides the course number that you entered when you created the course. To"
" use the course number that you entered when you created the course, enter "
"null."
msgstr ""
"Weka nambari ya kozi unayotaka ionekane kwenye kozi. Mpangilio huu unalipuka"
" nambari ya kozi uliyoingiza wakati ulipoanzisha kozi. Ili kutumia nambari "
"ya kozi uliyoingiza wakati wa kuzindua kozi, weka null."

#: xmodule/course_block.py:730
msgid "Course Maximum Student Enrollment"
msgstr "Idadi kuu ya wanafunzi wanaoweza kujiandikisha kwenye kozi"

#: xmodule/course_block.py:732
msgid ""
"Enter the maximum number of students that can enroll in the course. To allow"
" an unlimited number of students, enter null."
msgstr ""
"Weka idadi kuu ya wanafunzi wanaoweza kujiandikisha kwenye kozi. Ili "
"kuruhusu idadi isiyo na kikomo, weka null."

#: xmodule/course_block.py:739
msgid "Allow Public Wiki Access"
msgstr "Wezesha ufikiaji wa wiki ya umma"

#: xmodule/course_block.py:741
msgid ""
"Enter true or false. If true, students can view the course wiki even if "
"they're not enrolled in the course."
msgstr ""
"Weka true au false. Ikiwa ni true, wanafunzi wanaweza kuona wiki ya kozi "
"hata kama hawajiandikisha."

#: xmodule/course_block.py:749
msgid "Invitation Only"
msgstr "Kwa mwaliko tu"

#: xmodule/course_block.py:750
msgid "Whether to restrict enrollment to invitation by the course staff."
msgstr ""
"Iwapo unataka kuzuia ujiandikishaji hadi upate mwaliko kutoka kwa timu ya "
"kozi."

#: xmodule/course_block.py:756
msgid "Pre-Course Survey Name"
msgstr "Jina la utafiti wa kabla ya kozi"

#: xmodule/course_block.py:757
msgid "Name of SurveyForm to display as a pre-course survey to the user."
msgstr ""
"Jina la SurveyForm ambalo litakuonyeshwa kama utafiti wa kabla ya kozi kwa "
"mtumiaji."

#: xmodule/course_block.py:764
msgid "Pre-Course Survey Required"
msgstr "Utafiti wa kabla ya kozi unahitajika"

#: xmodule/course_block.py:766
msgid ""
"Specify whether students must complete a survey before they can view your "
"course content. If you set this value to true, you must add a name for the "
"survey to the Course Survey Name setting above."
msgstr ""
"Bainisha iwapo wanafunzi wanapaswa kukamilisha utafiti kabla ya kuweza kuona"
" maudhui ya kozi yako. Ikiwa utaweka thamani hii kuwa true, lazima uongeze "
"jina la utafiti kwenye mpangilio wa Jina la utafiti wa kozi hapo juu."

#: xmodule/course_block.py:775
msgid "Course Visibility In Catalog"
msgstr "Uonekano wa kozi kwenye orodha"

#. Translators: the quoted words 'both', 'about', and 'none' must be
#. left untranslated.  Leave them as English words.
#: xmodule/course_block.py:779
msgid ""
"Defines the access permissions for showing the course in the course catalog."
" This can be set to one of three values: 'both' (show in catalog and allow "
"access to about page), 'about' (only allow access to about page), 'none' (do"
" not show in catalog and do not allow access to an about page)."
msgstr ""
"Inaelezea ruhusa za ufikiaji kwa kuonyesha kozi kwenye orodha ya kozi. Hii "
"inaweza kuwekwa kama moja ya thamani tatu: 'both' (onyesha kwenye orodha na "
"kuruhusu ufikiaji wa ukurasa wa \"about\"), 'about' (ruhusu ufikiaji wa "
"ukurasa wa \"about\" tu), 'none' (usionyeshe kwenye orodha na usiruhusu "
"ufikiaji wa ukurasa wa \"about\")."

#: xmodule/course_block.py:793
msgid "Entrance Exam Enabled"
msgstr "Mitihani ya kuingilia imewezeshwa"

#: xmodule/course_block.py:795
msgid ""
"Specify whether students must complete an entrance exam before they can view"
" your course content. Note, you must enable Entrance Exams for this course "
"setting to take effect."
msgstr ""
"Bainisha iwapo wanafunzi wanapaswa kukamilisha mtihani wa kuingia kabla ya "
"kuweza kuona maudhui ya kozi yako. Kumbuka, lazima uwezeshe mitihani ya "
"kuingia ili mpangilio huu uwe na athari."

#: xmodule/course_block.py:806
msgid "Entrance Exam Minimum Score (%)"
msgstr "Alama adimu za mtihani wa kuingia (%)"

#: xmodule/course_block.py:808
msgid ""
"Specify a minimum percentage score for an entrance exam before students can "
"view your course content. Note, you must enable Entrance Exams for this "
"course setting to take effect."
msgstr ""
"Bainisha asilimia ya chini ya alama kwa mtihani wa kuingia kabla ya "
"wanafunzi kuweza kuona maudhui ya kozi yako. Kumbuka, lazima uwezeshe "
"mitihani ya kuingia ili mpangilio huu uweze kutekelezeka."

#: xmodule/course_block.py:816
msgid "Entrance Exam ID"
msgstr "Kitambulisho cha mtihani wa kuingia"

#: xmodule/course_block.py:817
msgid "Content block identifier (location) of entrance exam."
msgstr "Kitambulisho cha kipande cha maudhui (mahali) cha mtihani wa kuingia."

#: xmodule/course_block.py:823
msgid "Social Media Sharing URL"
msgstr "URL ya kushirikiana kwa mitandao ya kijamii"

#: xmodule/course_block.py:825
msgid ""
"If dashboard social sharing and custom course URLs are enabled, you can "
"provide a URL (such as the URL to a course About page) that social media "
"sites can link to. URLs must be fully qualified. For example: "
"http://www.edx.org/course/Introduction-to-MOOCs-ITM001"
msgstr ""
"Iwapo ushirikiano wa mitandao ya kijamii kwenye dashibodi na URL maalum za "
"kozi zimewezeshwa, unaweza kutoa URL (kwa mfano, URL ya ukurasa wa Kuhusu "
"Kozi) ambayo tovuti za mitandao ya kijamii zinaweza kuiunganisha. URLs "
"lazima ziwe kamili. Kwa mfano: http://www.edx.org/course/Introduction-to-"
"MOOCs-ITM001"

#: xmodule/course_block.py:833 cms/templates/settings.html:370
msgid "Course Language"
msgstr "Lugha ya kozi"

#: xmodule/course_block.py:834
msgid "Specify the language of your course."
msgstr "Bainisha lugha ya kozi yako."

#: xmodule/course_block.py:840
msgid "Teams Configuration"
msgstr "Usanidi wa timu"

#: xmodule/course_block.py:843
msgid ""
"Configure team sets, limit team sizes, and set visibility settings using "
"JSON. See <a target=\"&#95;blank\" "
"href=\"https://docs.openedx.org/en/latest/educators/references/advanced_features/teams_configuration_options.html>teams"
" configuration documentation</a> for help and examples."
msgstr ""
"Sanidi vikundi vya timu, punguza ukubwa wa timu, na weka mipangilio ya "
"uonekano kwa kutumia JSON. Angalia <a target=\"&#95;blank\" "
"href=\"https://docs.openedx.org/en/latest/educators/references/advanced_features/teams_configuration_options.html\">nyaraka"
" za usanidi wa timu</a> kwa msaada na mifano."

#: xmodule/course_block.py:852
msgid "Enable Proctored Exams"
msgstr "Wezesha mitihani inayoongozwa"

#: xmodule/course_block.py:854
msgid ""
"Enter true or false. If this value is true, proctored exams are enabled in "
"your course. Note that enabling proctored exams will also enable timed "
"exams."
msgstr ""
"Weka true au false. Ikiwa ni true, mitihani inayoongozwa imewezeshwa katika "
"kozi yako. Kumbuka kuwa kuwezesha mitihani inayoongozwa pia itawezesha "
"mitihani yenye muda."

#: xmodule/course_block.py:863
msgid "Proctoring Provider"
msgstr "Mtoa huduma wa usimamizi wa mitihani"

#: xmodule/course_block.py:865
#, python-brace-format
msgid ""
"Enter the proctoring provider you want to use for this course run. Choose "
"from the following options: {available_providers}."
msgstr ""
"Weka mtoa huduma wa kupanga mitihani unayotaka kutumia kwa kozi hii. Chagua "
"kutoka kwa chaguzi zifuatazo: {available_providers}."

#: xmodule/course_block.py:879
msgid "Proctortrack Exam Escalation Contact"
msgstr "Mawasiliano ya inua mtihani wa Proctortrack"

#: xmodule/course_block.py:881
msgid ""
"Required if 'proctortrack' is selected as your proctoring provider. Enter an"
" email address to be contacted by the support team whenever there are "
"escalations (e.g. appeals, delayed reviews, etc.)."
msgstr ""
"Inahitajika ikiwa 'proctortrack' imechaguliwa kama mtoa huduma wa kupanga "
"mitihani. Weka anwani ya barua pepe itakayotumiwa na timu ya msaada wakati "
"kuna ongezeko (kwa mfano, malalamiko, ukaguzi uliocheleweshwa, nk.)."

#: xmodule/course_block.py:891
msgid "Allow Opting Out of Proctored Exams"
msgstr "Wezesha kujiondoa mitahanini inayoongozwa"

#: xmodule/course_block.py:893
msgid ""
"Enter true or false. If this value is true, learners can choose to take "
"proctored exams without proctoring. If this value is false, all learners "
"must take the exam with proctoring. This setting only applies if proctored "
"exams are enabled for the course."
msgstr ""
"Weka true au false. Ikiwa ni true, wanafunzi wanaweza kuchagua kufanya "
"mitihani isiyoongozwa. Ikiwa ni false, wanafunzi wote lazima wafanye mtihani"
" wenye uangalizi. Mpangilio huu unatumika tu ikiwa mitihani inayoongozwa "
"imewezeshwa kwenye kozi."

#: xmodule/course_block.py:903
msgid "Create Zendesk Tickets For Suspicious Proctored Exam Attempts"
msgstr ""
"Tengeneza tiketi za Zendesk kwa jaribio la mitihani linaloashiria mashaka"

#: xmodule/course_block.py:905
msgid ""
"Enter true or false. If this value is true, a Zendesk ticket will be created"
" for suspicious attempts."
msgstr ""
"Weka true au false. Ikiwa ni true, tiketi ya Zendesk itaundwa kwa jaribio "
"lililo na mashaka."

#: xmodule/course_block.py:913
msgid "Enable Timed Exams"
msgstr "Wezesha mitihani yenye muda"

#: xmodule/course_block.py:915
msgid ""
"Enter true or false. If this value is true, timed exams are enabled in your "
"course. Regardless of this setting, timed exams are enabled if Enable "
"Proctored Exams is set to true."
msgstr ""
"Weka true au false. Ikiwa ni true, mitihani yenye muda imewezeshwa kwenye "
"kozi yako. Bila kujali mpangilio huu, mitihani yenye muda itawezeshwa ikiwa "
"Enable Proctored Exams imesetiwa kuwa true."

#: xmodule/course_block.py:924
msgid "Minimum Grade for Credit"
msgstr "Alama adimu ya kiwango cha mkopo"

#: xmodule/course_block.py:926
msgid ""
"The minimum grade that a learner must earn to receive credit in the course, "
"as a decimal between 0.0 and 1.0. For example, for 75%, enter 0.75."
msgstr ""
"Alama adimu ambayo mtumiaji lazima apate ili apate mkopo kwenye kozi, kama "
"desimali kati ya 0.0 na 1.0. Kwa mfano, kwa 75%, weka 0.75."

#: xmodule/course_block.py:934 xmodule/modulestore/inheritance.py:233
msgid "Self Paced"
msgstr "Kozi inayoendeshwa binafsi"

#: xmodule/course_block.py:936 xmodule/modulestore/inheritance.py:235
msgid ""
"Set this to \"true\" to mark this course as self-paced. Self-paced courses "
"do not have due dates for assignments, and students can progress through the"
" course at any rate before the course ends."
msgstr ""
"Weka \"true\" ili kuashiria kozi hii kuwa inaendeshwa binafsi. Kozi "
"zinazokuja binafsi hazina tarehe za kukabidhiwa kwa majukumu, na wanafunzi "
"wanaweza kusonga mbele kwa viwango mbalimbali kabla ya kozi kumalizika."

#: xmodule/course_block.py:945
msgid "Enable Subsection Prerequisites"
msgstr "Wezesha mahitaji ya awali ya sehemu ndogo"

#: xmodule/course_block.py:947
msgid ""
"Enter true or false. If this value is true, you can hide a subsection until "
"learners earn a minimum score in another, prerequisite subsection."
msgstr ""
"Weka true au false. Ikiwa ni true, unaweza kuficha sehemu ndogo mpaka "
"wanafunzi wapate alama adimu kwenye sehemu ndogo nyingine inayohitajika "
"kwanza."

#: xmodule/course_block.py:956
msgid "Course Learning Information"
msgstr "Taarifa za kujifunza kwa kozi"

#: xmodule/course_block.py:957
msgid "Specify what student can learn from the course."
msgstr "Bainisha kile mwanafunzi anaweza kujifunza kutoka kwa kozi."

#: xmodule/course_block.py:963
msgid "Course Visibility For Unenrolled Learners"
msgstr "Uonekano wa kozi kwa wanafunzi wasiojiandikisha"

#. Translators: the quoted words 'private', 'public_outline', and 'public'
#. must be left untranslated.  Leave them as English words.
#: xmodule/course_block.py:967
msgid ""
"Defines the access permissions for unenrolled learners. This can be set to "
"one of three values: 'private' (default visibility, only allowed for "
"enrolled students), 'public_outline' (allow access to course outline) and "
"'public' (allow access to both outline and course content)."
msgstr ""
"Inaelezea ruhusa za ufikiaji kwa wanafunzi wasiojiandikisha. Hii inaweza "
"kuwekwa kama moja ya thamani tatu: 'private' (uonekano wa msingi, kwa "
"wanafunzi waliojiandikisha tu), 'public_outline' (ruhusu ufikiaji wa "
"muhtasari wa kozi), na 'public' (ruhusu ufikiaji wa muhtasari na maudhui ya "
"kozi)."

#: xmodule/course_block.py:981
msgid "Video Sharing Options"
msgstr "Chaguo za kushirikiana video"

#: xmodule/course_block.py:983
msgid ""
"Specify the video sharing options for the course. This can be set to one of "
"three values: 'all-on', 'all-off' and 'per-video'. with 'per-video' as the "
"default."
msgstr ""
"Bainisha chaguo za kushirikiana video kwa kozi. Hii inaweza kuwekwa kama "
"moja ya thamani tatu: 'all-on', 'all-off' na 'per-video', ambapo 'per-video'"
" ndio chaguo la msingi."

#: xmodule/course_block.py:997
msgid "Force Flexible Grading for Peer ORAs"
msgstr "Lazimisha utaratibu unaobadilika wa tathmini kwa ORAs za wenzako"

#: xmodule/course_block.py:998
msgid ""
"Setting this flag will force on the flexible grading option for all peer-"
"graded ORAs in this course."
msgstr ""
"Kuweka bendera hii kutalazimisha chaguo la tathmini linalobadilika kwa ORAs "
"zote zinazopimwa na wenzako katika kozi hii."

#: xmodule/course_block.py:1018
msgid "Course Instructor"
msgstr "Mwalimu wa kozi"

#: xmodule/course_block.py:1019
msgid "Enter the details for Course Instructor"
msgstr "Weka maelezo ya mwalimu wa kozi"

#: xmodule/course_block.py:1026
msgid "Add Unsupported Problems and Tools"
msgstr "Ongeza matatizo na zana zisizotegemewa"

#: xmodule/course_block.py:1028
msgid ""
"Enter true or false. If true, you can add unsupported problems and tools to "
"your course in Studio. Unsupported problems and tools are not recommended "
"for use in courses due to non-compliance with one or more of the base "
"requirements, such as testing, accessibility, internationalization, and "
"documentation."
msgstr ""
"Weka true au false. Ikiwa ni true, unaweza kuongeza matatizo na zana "
"zisizotegemewa kwenye kozi yako katika Studio. Matatizo na zana "
"zisizotegemewa hawapendekezwi kutumika kwenye kozi kutokana na kutokufuata "
"mahitaji ya msingi kama upimaji, ufikiaji, kimataifa, na nyaraka."

#: xmodule/course_block.py:1035
msgid "Highlights Enabled for Messaging"
msgstr "Mwangaza umewezeshwa kwa ujumbe"

#: xmodule/course_block.py:1037
msgid ""
"Enter true or false. If true, any highlights associated with content in the "
"course will be messaged to learners at their scheduled time."
msgstr ""
"Weka true au false. Ikiwa ni true, mwangaza wowote unaohusiana na maudhui ya"
" kozi utaelekezwa kwa wanafunzi kwa wakati uliopangwa."

#: xmodule/course_block.py:1044
msgid "Course-wide Custom JS"
msgstr "JS maalum ya kozi nzima"

#: xmodule/course_block.py:1045
msgid ""
"Enter Javascript resource URLs you want to be loaded globally throughout the"
" course pages."
msgstr ""
"Weka URLs za rasilimali za Javascript unazotaka zipakuliwa kote kwenye "
"kurasa za kozi."

#: xmodule/course_block.py:1050
msgid "Course-wide Custom CSS"
msgstr "CSS maalum ya kozi nzima"

#: xmodule/course_block.py:1051
msgid ""
"Enter CSS resource URLs you want to be loaded globally throughout the course"
" pages."
msgstr ""
"Weka URLs za rasilimali za CSS unazotaka zipakuliwa kote kwenye kurasa za "
"kozi."

#: xmodule/course_block.py:1056 cms/templates/certificates.html:112
#: cms/templates/certificates.html:113
#: cms/templates/group_configurations.html:123
#: cms/templates/group_configurations.html:124 cms/templates/settings.html:704
#: cms/templates/settings.html:705 cms/templates/settings_advanced.html:143
#: cms/templates/settings_advanced.html:144
#: cms/templates/settings_graders.html:166
#: cms/templates/settings_graders.html:167
msgid "Other Course Settings"
msgstr "Mipangilio mingine ya kozi"

#: xmodule/course_block.py:1058
msgid ""
"Any additional information about the course that the platform needs or that "
"allows integration with external systems such as CRM software. Enter a "
"dictionary of values in JSON format, such as { \"my_custom_setting\": "
"\"value\", \"other_setting\": \"value\" }"
msgstr ""
"Taarifa zozote za ziada kuhusu kozi ambazo jukwaa linahitaji au zinazoruhusu"
" muunganiko na mifumo ya nje kama programu ya CRM. Weka kamusi ya thamani "
"katika muundo wa JSON, kama { \"my_custom_setting\": \"value\", "
"\"other_setting\": \"value\" }"

#: xmodule/course_block.py:1110
msgid "General"
msgstr "Msingi"

#: xmodule/discussion_block.py:55
msgid "Category"
msgstr "Kategoria"

#: xmodule/discussion_block.py:56
msgid "Week 1"
msgstr "Wiki 1"

#: xmodule/discussion_block.py:58
msgid ""
"A category name for the discussion. This name appears in the left pane of "
"the discussion forum for the course."
msgstr ""
"Jina la kategoria la mijadala. Jina hili huonekana kwenye paneli ya kushoto "
"ya jukwaa la mijadala la kozi."

#: xmodule/discussion_block.py:64
msgid "Subcategory"
msgstr "Chini ya kategoria"

#: xmodule/discussion_block.py:67
msgid ""
"A subcategory name for the discussion. This name appears in the left pane of"
" the discussion forum for the course."
msgstr ""
"Jina la chini ya kategoria la mijadala. Jina hili huonekana kwenye paneli ya"
" kushoto ya jukwaa la mijadala la kozi."

#: xmodule/discussion_block.py:184
#, python-brace-format
msgid ""
"You are not signed in. To view the discussion content, {sign_in_link} or "
"{register_link}, and enroll in this course."
msgstr ""
"Hujaingia. Ili kuona maudhui ya mijadala, {sign_in_link} au {register_link},"
" na jiandikishe kwenye kozi hii."

#: xmodule/graders.py:276
#, python-brace-format
msgid "{assignment_type} = {weighted_percent:.2%} of a possible {weight:.2%}"
msgstr ""
"{assignment_type} = {weighted_percent:.2%} ya uwezekano wa {weight:.2%}"

#: xmodule/graders.py:382
msgid "Generated"
msgstr "Imeundwa"

#. Translators: "Homework 1 - Unreleased - 0% (?/?)" The section has not been
#. released for viewing.
#: xmodule/graders.py:403
#, python-brace-format
msgid "{section_type} {index} Unreleased - 0% (?/?)"
msgstr "{section_type} {index} haijasitolewa - 0% (?/?)"

#: xmodule/graders.py:417
#, python-brace-format
msgid "The lowest {drop_count} {section_type} scores are dropped."
msgstr "Alama za chini zaidi za {drop_count} za {section_type} zinatupwa."

#. Translators: "Homework Average = 0%"
#: xmodule/graders.py:436
#, python-brace-format
msgid "{section_type} Average = {percent:.2%}"
msgstr "Wastani wa {section_type} = {percent:.2%}"

#. Translators: Avg is short for Average
#: xmodule/graders.py:441
#, python-brace-format
msgid "{short_label} Avg"
msgstr "Wastani wa {short_label}"

#: xmodule/hidden_block.py:38
#, python-brace-format
msgid ""
"ERROR: \"{block_type}\" is an unknown component type. This component will be"
" hidden in LMS."
msgstr ""
"KOSA: \"{block_type}\" ni aina isiyojulikana ya kipengee. Kipengee hiki "
"kitafichwa katika LMS."

#: xmodule/html_block.py:63 xmodule/html_block.py:387
#: xmodule/html_block.py:447
msgid "Html contents to display for this block"
msgstr "Yaliyomo ya HTML ya kuonyeshwa kwa kipande hiki"

#: xmodule/html_block.py:65
msgid "Upstream html contents to store upstream data field"
msgstr "Maudhui ya HTML ya juu ya mto kuhifadhi uwanja wa data ya juu"

#: xmodule/html_block.py:72
msgid "Source code for LaTeX documents. This feature is not well-supported."
msgstr ""
"Msimbo wa chanzo kwa hati za LaTeX. Kipengele hiki hakina msaada mzuri."

#: xmodule/html_block.py:82
msgid ""
"Select Visual to enter content and have the editor automatically create the "
"HTML. Select Raw to edit HTML directly. If you change this setting, you must"
" save the component and then re-open it for editing."
msgstr ""
"Chagua Visual kuingiza maudhui na mhariri ataunda HTML moja kwa moja. Chagua"
" Raw kubadilisha HTML moja kwa moja. Ikiwa utabadilisha mpangilio huu, "
"lazima uhifadhi kipengee kisha uifungue tena ili kuhariri."

#: xmodule/html_block.py:85
msgid "Editor"
msgstr "Mhariri"

#: xmodule/html_block.py:88
msgid "Visual"
msgstr "Mwangaza"

#: xmodule/html_block.py:89
msgid "Raw"
msgstr "Raw"

#: xmodule/html_block.py:413
msgid "Hide Page From Learners"
msgstr "Ficha ukurasa kutoka kwa wanafunzi"

#: xmodule/html_block.py:414
msgid ""
"If you select this option, only course team members with the Staff or Admin "
"role see this page."
msgstr ""
"Ikiwa utachagua chaguo hili, ni wanachama wa timu ya kozi wenye nafasi ya "
"Wafanyakazi au Wasimamizi tu ndio wataoona ukurasa huu."

#: xmodule/html_block.py:424
msgid "HTML for the additional pages"
msgstr "HTML kwa kurasa za ziada"

#: xmodule/html_block.py:442
msgid "List of course update items"
msgstr "Orodha ya vipengele vya masasisho ya kozi"

#: xmodule/item_bank_block.py:67 xmodule/library_content_block.py:94
msgid "Count"
msgstr "Hesabu"

#: xmodule/item_bank_block.py:68 xmodule/library_content_block.py:95
msgid ""
"Enter the number of components to display to each student. Set it to -1 to "
"display all components."
msgstr ""
"Weka idadi ya vipengele vya kuonyeshwa kwa kila mwanafunzi. Weka -1 "
"kuonyesha vipengele vyote."

#: xmodule/item_bank_block.py:81
msgid ""
"Determines whether a 'Reset Problems' button is shown, so users may reset "
"their answers and reshuffle selected items."
msgstr ""
"Inaamua iwapo kitufe cha 'Reset Problems' kinaonyeshwa, ili watumiaji waweze"
" kusanidi upya majibu yao na kuandaa upya vipengele vilivyochaguliwa."

#: xmodule/item_bank_block.py:474
#, python-brace-format
msgid ""
"The problem bank has been configured to show {count} problems. Please "
"specify a positive number of problems, or specify -1 to show all problems."
msgstr ""
"Benki ya matatizo imewezeshwa kuonyesha matatizo {count}. Tafadhali bainisha"
" idadi chanya ya matatizo, au weka -1 kuonyesha matatizo yote."

#: xmodule/item_bank_block.py:478 xmodule/item_bank_block.py:490
msgid "Edit the problem bank configuration."
msgstr "Hariri usanidi wa benki ya matatizo."

#: xmodule/item_bank_block.py:486
#, python-brace-format
msgid ""
"The problem bank has been configured to show {count} problems, but only "
"{actual} have been selected."
msgstr ""
"Benki ya matatizo imewezeshwa kuonyesha matatizo {count}, lakini {actual} "
"pekee zimechaguliwa."

#: xmodule/library_content_block.py:51
msgid "Any Type"
msgstr "Aina yoyote"

#: xmodule/library_content_block.py:83 cms/templates/widgets/header.html:297
msgid "Library"
msgstr "Maktaba"

#: xmodule/library_content_block.py:84
msgid "Select the library from which you want to draw content."
msgstr "Chagua maktaba unayotaka kuchota maudhui nayo."

#: xmodule/library_content_block.py:90
msgid "Library Version"
msgstr "Toleo la maktaba"

#: xmodule/library_content_block.py:100
msgid "Problem Type"
msgstr "Aina ya tatizo"

#: xmodule/library_content_block.py:101
msgid ""
"Choose a problem type to fetch from the library. If \"Any Type\" is selected"
" no filtering is applied."
msgstr ""
"Chagua aina ya tatizo la kupakua kutoka maktaba. Ikiwa \"Aina yoyote\" "
"imechaguliwa, hakuna uchujaji unaofanyika."

#: xmodule/library_content_block.py:200
msgid "Source content library has not been specified."
msgstr "Maktaba ya maudhui ya chanzo haijabainishwa."

#: xmodule/library_content_block.py:204
msgid "Content libraries are not available in the current runtime."
msgstr "Maktaba za maudhui hazipatikani katika mzunguko wa sasa."

#: xmodule/library_content_block.py:207
#, python-brace-format
msgid "Source content library does not exist: {source_library_id}"
msgstr "Maktaba ya maudhui ya chanzo haipo: {source_library_id}"

#: xmodule/library_content_block.py:273
msgid "This component is out of date. The library has new content."
msgstr "Kipengee hiki kimepita umri. Maktaba ina maudhui mapya."

#. Translators: {refresh_icon} placeholder is substituted to "↻" (without
#. double quotes)
#: xmodule/library_content_block.py:278
#, python-brace-format
msgid "{refresh_icon} Update now."
msgstr "{refresh_icon} Sasisha sasa."

#: xmodule/library_content_block.py:286
msgid "Library is invalid, corrupt, or has been deleted."
msgstr "Maktaba sio halali, imeharibika, au imefutwa."

#: xmodule/library_content_block.py:288
msgid "Edit Library List."
msgstr "Hariri orodha ya maktaba."

#: xmodule/library_content_block.py:315
msgid ""
"This course does not support content libraries. Contact your system "
"administrator for more information."
msgstr ""
"Kozi hii haidumii maktaba za maudhui. Wasiliana na msimamizi wa mfumo kwa "
"taarifa zaidi."

#: xmodule/library_content_block.py:325
msgid "A library has not yet been selected."
msgstr "Maktaba bado haijachaguliwa."

#: xmodule/library_content_block.py:327
msgid "Select a Library."
msgstr "Chagua maktaba."

#: xmodule/library_content_block.py:341
#, python-brace-format
msgid "There are no problems in the specified library of type {capa_type}."
msgstr "Hakuna matatizo katika maktaba iliyobainishwa ya aina {capa_type}."

#: xmodule/library_content_block.py:344
msgid "Select another problem type."
msgstr "Chagua aina nyingine ya tatizo."

#: xmodule/library_content_block.py:355
#, python-brace-format
msgid "The specified library is configured to fetch {count} problem, "
msgid_plural "The specified library is configured to fetch {count} problems, "
msgstr[0] "Maktaba iliyobainishwa imewekwa kupakua tatizo {count}, "
msgstr[1] "Maktaba iliyobainishwa imewekwa kupakua matatizo {count}, "

#: xmodule/library_content_block.py:360
#, python-brace-format
msgid "but there is only {actual} matching problem."
msgid_plural "but there are only {actual} matching problems."
msgstr[0] "lakini kuna tatizo {actual} linalolingana."
msgstr[1] "lakini kuna matatizo {actual} tu yanayolingana."

#: xmodule/library_content_block.py:366
msgid "Edit the library configuration."
msgstr "Hariri usanidi wa maktaba."

#: xmodule/library_content_block.py:384
msgid "Invalid Library"
msgstr "Maktaba si sahihi"

#: xmodule/library_content_block.py:385
msgid "No Library Selected"
msgstr "Hakuna maktaba yaliyoteuliwa"

#: xmodule/library_root_xblock.py:32
msgid "Library Display Name"
msgstr "Jina la uonyesho la maktaba"

#: xmodule/library_root_xblock.py:37
msgid "Enter the names of the advanced components to use in your library."
msgstr "Weka majina ya vipengele vya juu vitakavyotumika kwenye maktaba yako."

#: xmodule/lti_block.py:133
msgid ""
"The display name for this component. Analytics reports may also use the "
"display name to identify this component."
msgstr ""
"Jina la uonyesho kwa kipengee hiki. Ripoti za uchambuzi zinaweza pia kutumia"
" jina hili kutambua kipengee hiki."

#: xmodule/lti_block.py:140
msgid "LTI ID"
msgstr "LTI ID"

#: xmodule/lti_block.py:142
#, python-brace-format
msgid ""
"Enter the LTI ID for the external LTI provider.  This value must be the same"
" LTI ID that you entered in the LTI Passports setting on the Advanced "
"Settings page.{break_tag}See {docs_anchor_open}the edX LTI "
"documentation{anchor_close} for more details on this setting."
msgstr ""
"Weka LTI ID kwa mtoa huduma wa nje wa LTI. Thamani hii lazima iwe LTI ID ile"
" ile uliyoweka kwenye mpangilio wa Visa za LTI kwenye ukurasa wa Mipangilio "
"ya Juu.{break_tag}Tazama {docs_anchor_open}nyaraka za edX LTI{anchor_close} "
"kwa maelezo zaidi kuhusu mpangilio huu."

#: xmodule/lti_block.py:155
msgid "LTI URL"
msgstr "URL ya LTI"

#: xmodule/lti_block.py:157
#, python-brace-format
msgid ""
"Enter the URL of the external tool that this component launches. This "
"setting is only used when Hide External Tool is set to False.{break_tag}See "
"{docs_anchor_open}the edX LTI documentation{anchor_close} for more details "
"on this setting."
msgstr ""
"Weka URL ya zana ya nje ambayo kipengee hiki kinaanzisha. Mpangilio huu "
"unatumika tu ikiwa Hide External Tool imesetiwa kuwa False.{break_tag}Tazama"
" {docs_anchor_open}nyaraka za edX LTI{anchor_close} kwa maelezo zaidi kuhusu"
" mpangilio huu."

#: xmodule/lti_block.py:168
msgid "Custom Parameters"
msgstr "Vigezo maalum"

#: xmodule/lti_block.py:170
#, python-brace-format
msgid ""
"Add the key/value pair for any custom parameters, such as the page your "
"e-book should open to or the background color for this "
"component.{break_tag}See {docs_anchor_open}the edX LTI "
"documentation{anchor_close} for more details on this setting."
msgstr ""
"Ongeza jozi ya ufunguo/thamani kwa vigezo maalum, kama vile ukurasa ambao "
"e-kitabu chako kinapaswa kufunguliwa au rangi ya nyuma kwa kipengee "
"hiki.{break_tag}Tazama {docs_anchor_open}nyaraka za edX LTI{anchor_close} "
"kwa maelezo zaidi kuhusu mpangilio huu."

#: xmodule/lti_block.py:180
msgid "Open in New Page"
msgstr "Fungua katika ukurasa mpya"

#: xmodule/lti_block.py:182
msgid ""
"Select True if you want students to click a link that opens the LTI tool in "
"a new window. Select False if you want the LTI content to open in an IFrame "
"in the current page. This setting is only used when Hide External Tool is "
"set to False.  "
msgstr ""
"Chagua True ikiwa unataka wanafunzi kubofya kiungo kinachofungua zana ya LTI"
" kwenye dirisha jipya. Chagua False ikiwa unataka maudhui ya LTI yafungue "
"kwenye IFrame katika ukurasa wa sasa. Mpangilio huu unatumika tu ikiwa Hide "
"External Tool imesetiwa kuwa False."

#: xmodule/lti_block.py:190
msgid "Scored"
msgstr "Imepewa alama"

#: xmodule/lti_block.py:192
msgid ""
"Select True if this component will receive a numerical score from the "
"external LTI system."
msgstr ""
"Chagua True ikiwa kipengee hiki kitapokea alama ya nambari kutoka kwa mfumo "
"wa nje wa LTI."

#: xmodule/lti_block.py:198
msgid "Weight"
msgstr "Uzito"

#: xmodule/lti_block.py:200
msgid ""
"Enter the number of points possible for this component.  The default value "
"is 1.0.  This setting is only used when Scored is set to True."
msgstr ""
"Weka idadi ya alama zinazowezekana kwa kipengee hiki. Thamani chaguo-nchi ni"
" 1.0. Mpangilio huu unatumika tu wakati Scored imesetiwa kuwa True."

#: xmodule/lti_block.py:209
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Alama inahifadhiwa katika xblock KVS -- nakala ya alama iliyochapishwa "
"katika django DB."

#: xmodule/lti_block.py:214
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Maoni kama yalivyorejeshwa na mtoaji tathmini, LTI2.0 spec"

#: xmodule/lti_block.py:219
msgid "Hide External Tool"
msgstr "Ficha zana ya nje"

#: xmodule/lti_block.py:221
msgid ""
"Select True if you want to use this component as a placeholder for syncing "
"with an external grading  system rather than launch an external tool.  This "
"setting hides the Launch button and any IFrames for this component."
msgstr ""
"Chagua True ikiwa unataka kutumia kipengee hiki kama nafasi ya kusawazisha "
"na mfumo wa tathmini wa nje badala ya kuanzisha zana ya nje. Mpangilio huu "
"unaficha kitufe cha Launch na IFrame yoyote ya kipengee hiki."

#: xmodule/lti_block.py:232
msgid "Request user's username"
msgstr "Omba jina la mtumiaji"

#. Translators: This is used to request the user's username for a third party
#. service.
#: xmodule/lti_block.py:234
msgid "Select True to request the user's username."
msgstr "Chagua True kuomba jina la mtumiaji."

#: xmodule/lti_block.py:239
msgid "Request user's email"
msgstr "Omba barua pepe ya mtumiaji"

#. Translators: This is used to request the user's email for a third party
#. service.
#: xmodule/lti_block.py:241
msgid "Select True to request the user's email address."
msgstr "Chagua True kuomba anwani ya barua pepe ya mtumiaji."

#: xmodule/lti_block.py:247
msgid "LTI Application Information"
msgstr "Taarifa za ombi la LTI"

#: xmodule/lti_block.py:249
msgid ""
"Enter a description of the third party application. If requesting username "
"and/or email, use this text box to inform users why their username and/or "
"email will be forwarded to a third party application."
msgstr ""
"Weka maelezo ya programu ya upande wa tatu. Ikiwa unahitaji ombi la jina la "
"mtumiaji na/au barua pepe, tumia kisanduku hiki cha maandishi kuwafahamisha "
"watumiaji kwa nini jina lao na/au barua pepe zitatumwa kwa programu ya "
"upande wa tatu."

#: xmodule/lti_block.py:257
msgid "Button Text"
msgstr "Maandishi ya kitufe"

#: xmodule/lti_block.py:259
msgid ""
"Enter the text on the button used to launch the third party application."
msgstr ""
"Weka maandishi yaliyomo kwenye kitufe kinachotumiwa kuanzisha programu ya "
"upande wa tatu."

#: xmodule/lti_block.py:266
msgid "Accept grades past deadline"
msgstr "Kubali alama baada ya tarehe ya mwisho"

#: xmodule/lti_block.py:267
msgid ""
"Select True to allow third party systems to post grades past the deadline."
msgstr ""
"Chagua True kuruhusu mifumo ya upande wa tatu kuchapisha alama baada ya "
"tarehe ya mwisho."

#: xmodule/lti_block.py:441
#, python-brace-format
msgid ""
"Could not parse custom parameter: {custom_parameter}. Should be \"x=y\" "
"string."
msgstr ""
"Haiwezi kuchambua kigezo cha kipekee: {custom_parameter}. Inapaswa kuwa "
"muundo wa \"x=y\"."

#: xmodule/lti_block.py:974
#, python-brace-format
msgid ""
"Could not parse LTI passport: {lti_passport}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Haiwezi kuchambua visa za LTI: {lti_passport}. Zinapaswa kuwa muundo wa "
"\"id:key:secret\"."

#: xmodule/modulestore/inheritance.py:47 xmodule/seq_block.py:78
#: lms/templates/ccx/schedule.html:115
msgid "Due Date"
msgstr "Tarehe ya kukabidhiwa"

#: xmodule/modulestore/inheritance.py:48
msgid "Enter the default date by which problems are due."
msgstr "Weka tarehe ya msingi ambayo matatizo yanapaswa kukabidhiwa."

#: xmodule/modulestore/inheritance.py:53 xmodule/seq_block.py:84
msgid "Number of Relative Weeks Due By"
msgstr "Idadi ya wiki zilizo binafsi za tarehe ya kukabidhiwa"

#: xmodule/modulestore/inheritance.py:54 xmodule/seq_block.py:85
msgid ""
"Enter the number of weeks the problems are due by relative to the learner's "
"enrollment date"
msgstr ""
"Weka idadi ya wiki ambapo matatizo yanapaswa kukabidhiwa kulingana na tarehe"
" ya ujiandikishaji wa mtumiaji."

#: xmodule/modulestore/inheritance.py:70
msgid "GIT URL"
msgstr "URL ya GIT"

#: xmodule/modulestore/inheritance.py:71
msgid "Enter the URL for the course data GIT repository."
msgstr "Weka URL ya hazina ya data ya kozi ya GIT."

#: xmodule/modulestore/inheritance.py:75
msgid "XQA Key"
msgstr "Ufunguo wa XQA"

#: xmodule/modulestore/inheritance.py:76
msgid "This setting is not currently supported."
msgstr "Mpangilio huu haujaungwa mkono kwa sasa."

#: xmodule/modulestore/inheritance.py:84
msgid "Enter the ids for the content groups this problem belongs to."
msgstr ""
"Weka vitambulisho vya makundi ya maudhui ambavyo tatizo hili linahusiana "
"nao."

#. Translators: DO NOT translate the words in quotes here, they are
#. specific words for the acceptable values.
#: xmodule/modulestore/inheritance.py:93
msgid ""
"Specify when the Show Answer button appears for each problem. Valid values "
"are \"always\", \"answered\", \"attempted\", \"closed\", \"finished\", "
"\"past_due\", \"correct_or_past_due\", \"after_all_attempts\", "
"\"after_all_attempts_or_correct\", \"attempted_no_past_due\", and \"never\"."
msgstr ""
"Bainisha ni lini kitufe cha Onyesha Jibu kinaonekana kwa kila tatizo. "
"Thamani halali ni \"always\", \"answered\", \"attempted\", \"closed\", "
"\"finished\", \"past_due\", \"correct_or_past_due\", \"after_all_attempts\","
" \"after_all_attempts_or_correct\", \"attempted_no_past_due\", na \"never\"."

#. Translators: DO NOT translate the words in quotes here, they are
#. specific words for the acceptable values.
#: xmodule/modulestore/inheritance.py:107
msgid ""
"Specify when to show answer correctness and score to learners. Valid values "
"are \"always\", \"never\", and \"past_due\"."
msgstr ""
"Bainisha ni lini kuonyesha usahihi wa jibu na alama kwa wanafunzi. Thamani "
"halali ni \"always\", \"never\", na \"past_due\"."

#. Translators: DO NOT translate the words in quotes here, they are
#. specific words for the acceptable values.
#: xmodule/modulestore/inheritance.py:119
msgid ""
"Specify the default for how often variable values in a problem are "
"randomized. This setting should be set to \"never\" unless you plan to "
"provide a Python script to identify and randomize values in most of the "
"problems in your course. Valid values are \"always\", \"onreset\", "
"\"never\", and \"per_student\"."
msgstr ""
"Bainisha chaguo-msingi kwa mara ngapi thamani za mabadiliko katika tatizo "
"zinabadilishwa mpangilio wa nasibu. Mpangilio huu unapaswa kuwekwa kuwa "
"\"never\" isipokuwa unapanga kutoa skripti ya Python ili kutambua na "
"kubadilisha thamani katika matatizo mengi katika kozi yako. Thamani halali "
"ni \"always\", \"onreset\", \"never\", na \"per_student\"."

#: xmodule/modulestore/inheritance.py:128
msgid "Days Early for Beta Users"
msgstr "Siku za Awali kwa Watumiaji wa Beta"

#: xmodule/modulestore/inheritance.py:129
msgid ""
"Enter the number of days before the start date that beta users can access "
"the course."
msgstr ""
"Weka idadi ya siku kabla ya tarehe ya kuanza ambapo watumiaji wa beta "
"wanaweza kufikia kozi."

#: xmodule/modulestore/inheritance.py:134
msgid "Static Asset Path"
msgstr "Njia ya Mali Imara"

#: xmodule/modulestore/inheritance.py:135
msgid ""
"Enter the path to use for files on the Files & Uploads page. This value "
"overrides the Studio default, c4x://."
msgstr ""
"Weka njia itakayotumika kwa faili katika ukurasa wa Faili na Upakiaji. "
"Thamani hii inabadili chaguo-msingi la Studio, c4x://."

#: xmodule/modulestore/inheritance.py:140
msgid "Enable LaTeX Compiler"
msgstr "Washa Mkusanyaji wa LaTeX"

#: xmodule/modulestore/inheritance.py:141
msgid ""
"Enter true or false. If true, you can use the LaTeX templates for HTML "
"components and advanced Problem components."
msgstr ""
"Weka kweli au uongo. Ikiwa ni kweli, unaweza kutumia template za LaTeX kwa "
"vipengele vya HTML na vipengele vya Tatizo vya juu."

#: xmodule/modulestore/inheritance.py:147
msgid ""
"Enter the maximum number of times a student can try to answer problems. By "
"default, Maximum Attempts is set to null, meaning that students have an "
"unlimited number of attempts for problems. You can override this course-wide"
" setting for individual problems. However, if the course-wide setting is a "
"specific number, you cannot set the Maximum Attempts for individual problems"
" to unlimited."
msgstr ""
"Weka idadi ya juu ya mara ambayo mwanafunzi anaweza kujaribu kujibu "
"matatizo. Kwa kawaida, Jaribio la Juu limewekwa kuwa null, ikimaanisha kuwa "
"wanafunzi wana jaribio lisilo na kikomo kwa matatizo. Unaweza kubadilisha "
"mpangilio huu wa kozi kwa matatizo binafsi. Hata hivyo, ikiwa mpangilio wa "
"kozi ni nambari maalum, huwezi kuweka Jaribio la Juu kwa matatizo binafsi "
"kuwa lisilo na kikomo."

#: xmodule/modulestore/inheritance.py:152
msgid ""
"Enter the API key provided by MathWorks for accessing the MATLAB Hosted "
"Service. This key is granted for exclusive use in this course for the "
"specified duration. Do not share the API key with other courses. Notify "
"MathWorks immediately if you believe the key is exposed or compromised. To "
"obtain a key for your course, or to report an issue, please contact "
"moocsupport@mathworks.com"
msgstr ""
"Ingiza ufunguo wa API unaotolewa na MathWorks kwa kufikia Huduma ya "
"Kuhifadhi MATLAB. Ufunguo huu umetolewa kwa matumizi ya kipekee katika kozi "
"hii kwa kipindi kilichowekwa. Usishirikishe ufunguo wa API na kozi zingine. "
"Arifu MathWorks mara moja ikiwa unaamini ufunguo umefunuliwa au "
"umekatikizwa. Ili kupata ufunguo kwa kozi yako, au kuripoti tatizo, "
"tafadhali wasiliana na moocsupport@mathworks.com"

#: xmodule/modulestore/inheritance.py:162 cms/templates/certificates.html:119
#: cms/templates/group_configurations.html:17
#: cms/templates/group_configurations.html:46 cms/templates/settings.html:709
#: cms/templates/settings_advanced.html:149
#: cms/templates/settings_graders.html:171
#: cms/templates/widgets/header.html:200
msgid "Group Configurations"
msgstr "Mipangilio ya Makundi"

#: xmodule/modulestore/inheritance.py:163
msgid ""
"Enter the configurations that govern how students are grouped together."
msgstr "Weka mipangilio inayosimamia jinsi wanafunzi wanavyogawanywa pamoja."

#: xmodule/modulestore/inheritance.py:168
msgid "Enable video caching system"
msgstr "Washa mfumo wa kuhifadhi video kwenye kumbukumbu"

#: xmodule/modulestore/inheritance.py:169
msgid ""
"Enter true or false. If true, video caching will be used for HTML5 videos."
msgstr ""
"Weka kweli au uongo. Ikiwa ni kweli, kuhifadhi video kwenye kumbukumbu "
"kutatumika kwa video za HTML5."

#: xmodule/modulestore/inheritance.py:174
msgid "Enable video auto-advance"
msgstr "Washa usukani wa video otomatiki"

#: xmodule/modulestore/inheritance.py:176
msgid ""
"Specify whether to show an auto-advance button in videos. If the student "
"clicks it, when the last video in a unit finishes it will automatically move"
" to the next unit and autoplay the first video."
msgstr ""
"Bainisha kama kuonyesha kitufe cha usukani wa otomatiki katika video. Ikiwa "
"mwanafunzi anakibonyeza, video ya mwisho katika kitengo inapoishia, itahamia"
" moja kwa moja kitengo kinachofuata na kuanzisha video ya kwanza moja."

#: xmodule/modulestore/inheritance.py:182
msgid "Video Pre-Roll"
msgstr "Video ya Utangulizi"

#: xmodule/modulestore/inheritance.py:184
#, python-brace-format
msgid ""
"Identify a video, 5-10 seconds in length, to play before course videos. "
"Enter the video ID from the Video Uploads page and one or more transcript "
"files in the following format: {format}. For example, an entry for a video "
"with two transcripts looks like this: {example}"
msgstr ""
"Tambua video, yenye urefu wa sekunde 5-10, ili kuchezwa kabla ya video za "
"kozi. Weka kitambulisho cha video kutoka kwenye ukurasa wa Upakiaji wa Video"
" na faili moja au zaidi za maandishi katika muundo ufuatao: {format}. Mfano,"
" ingizo kwa video yenye maandishi mawili linaonekana hivi: {example}"

#: xmodule/modulestore/inheritance.py:201
msgid "Show Reset Button for Problems"
msgstr "Onyesha Kitufe cha Weka Upya kwa Matatizo"

#: xmodule/modulestore/inheritance.py:203
msgid ""
"Enter true or false. If true, problems in the course default to always "
"displaying a 'Reset' button. You can override this in each problem's "
"settings. All existing problems are affected when this course-wide setting "
"is changed."
msgstr ""
"Weka kweli au uongo. Ikiwa ni kweli, matatizo katika kozi kwa chaguo-msingi "
"yanaonyesha kitufe cha 'Reset' kila wakati. Unaweza kubadilisha hili katika "
"mipangilio ya kila tatizo. Matatizo yote yaliyopo yataathiriwa wakati "
"mpangilio wa kozi unapobadilishwa."

#: xmodule/modulestore/inheritance.py:211
msgid "Enable Student Notes"
msgstr "Washa Vidokezo vya Wanafunzi"

#: xmodule/modulestore/inheritance.py:212
msgid ""
"Enter true or false. If true, students can use the Student Notes feature."
msgstr ""
"Weka kweli au uongo. Ikiwa ni kweli, wanafunzi wanaweza kutumia kipengele "
"cha Vidokezo vya Wanafunzi."

#: xmodule/modulestore/inheritance.py:218
msgid ""
"Indicates whether Student Notes are visible in the course. Students can also"
" show or hide their notes in the courseware."
msgstr ""
"Inaonyesha kama Vidokezo vya Wanafunzi vinaonekana katika kozi. Wanafunzi "
"pia wanaweza kuonyesha au kuficha vidokezo vyao katika maudhui ya kozi."

#: xmodule/modulestore/inheritance.py:225
msgid "Tag this block as part of an Entrance Exam section"
msgstr ""
"Weka lebo hii kwenye kipande hiki kama sehemu ya sehemu ya Mtihani wa "
"Kuwasilika"

#: xmodule/modulestore/inheritance.py:226
msgid ""
"Enter true or false. If true, answer submissions for problem blocks will be "
"considered in the Entrance Exam scoring/gating algorithm."
msgstr ""
"Weka kweli au uongo. Ikiwa ni kweli, majibu yaliyowasilishwa kwa vipande vya"
" matatizo yatazingatiwa katika algoriti ya upimaji/uzingaji ya Mtihani wa "
"Kuwasilika."

#: xmodule/modulestore/inheritance.py:244
msgid "Hide from Table of Contents"
msgstr "Ficha kutoka kwenye Jedwali la Yaliyomo"

#: xmodule/modulestore/inheritance.py:245
msgid ""
"Enter true or false. If true, this block will be hidden from the Table of "
"Contents."
msgstr ""
"Weka kweli au uongo. Ikiwa ni kweli, kipande hiki kitafichwa kutoka kwenye "
"Jedwali la Yaliyomo."

#: xmodule/modulestore/xml_importer.py:82
msgid "Error while reading {}. Check file for XML errors."
msgstr "Hitilafu wakati wa kusoma {}. Angalia faili kwa makosa ya XML."

#: xmodule/modulestore/xml_importer.py:94
msgid "Failed to import block: {} at location: {}"
msgstr "Imeshindwa kuingiza kipande: {} katika eneo: {}"

#: xmodule/partitions/enrollment_track_partition_generator.py:38
#: cms/templates/group_configurations.html:86
msgid "Enrollment Track Groups"
msgstr "Makundi ya Njia ya Usajili"

#: xmodule/partitions/enrollment_track_partition_generator.py:39
msgid "Partition for segmenting users by enrollment track"
