msgstr ""
"Proporciona un títol significatiu perquè altres estudiants sàpiguen si els "
"és útil"

#: templates/recommender.html:189
msgid "Location"
msgstr "Ubicació"

#: templates/recommender.html:191 templates/recommender.html:216
