msgstr "Beri downvote jika sumber daya ini tidak bermanfaat"

#: static/js/src/cats.js:69
msgid "Votes"
msgstr "Suara"

#: static/js/src/cats.js:70
msgid "Resource title"
msgstr "Judul sumber daya"

