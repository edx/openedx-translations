#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Token otentikasi LTI 1.3 hilang."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Header token tidak valid. Tidak ada kredensial yang diberikan."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr "Header token tidak valid. String token tidak boleh mengandung spasi."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Konfigurasi LTI tidak ditemukan."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Tanda tangan token tidak valid."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "Tidak ditemukan ID pengguna yang valid dalam URL titik akhir."

#: lti_xblock.py:147
msgid "New"
msgstr "Baru"

#: lti_xblock.py:151
msgid "Database"
msgstr "Basis Data"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Yang Ada"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Nama Tampilan"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Masukkan nama yang dilihat peserta didik untuk komponen ini. Nama ini juga "
"dapat muncul di laporan."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Konsumen LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Pemberitahuan Berbagi Data"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Masukkan pemberitahuan singkat tentang alat ini. Gunakan kolom ini untuk "
"menjelaskan mengapa data peserta didik dapat dibagikan dengan alat tersebut."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Jenis Konfigurasi"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Pilih 'Baru' untuk mengonfigurasi Alat LTI yang baru. Jika admin Anda telah "
"menyediakan ID dari konfigurasi alat yang dapat digunakan kembali yang sudah"
" ada, pilih 'Yang Ada' dan masukkan di kolom teks di sebelah kanan."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Versi LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Pilih versi LTI yang didukung oleh alat Anda."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "ID Penggunaan Ulang LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Masukkan ID konfigurasi alat yang dapat digunakan kembali yang sudah ada."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "ID paspor LTI 1.3 yang menunjuk ke tabel Lti1p3Passport."

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "ID paspor untuk kunci yang dapat digunakan kembali."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "URL Peluncuran"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Masukkan URL peluncuran untuk alat ini. Untuk LTI 1.3, ini adalah URL yang "
"digunakan Open edX untuk meluncurkan alat tersebut."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "URL Inisiasi Login Alat (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Masukkan URL inisiasi login OIDC alat. Open edX menggunakan URL ini untuk "
"memulai alur login LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URI Redirect Terdaftar"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Masukkan URI redirect yang diizinkan untuk digunakan alat ini saat login, "
"misalnya [\"https://tool.com\", \"https://tool_deeplink.com\"]. Biarkan "
"kosong untuk menggunakan URL peluncuran dan URL deep linking secara default."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Mode Kunci Publik Alat"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Pilih bagaimana Open edX akan mendapatkan kunci publik alat untuk "
"memvalidasi pesan yang ditandatangani."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL Keyset Alat"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Masukkan URL keyset JWK alat. Open edX menggunakan URL ini untuk mengambil "
"kunci publik yang dibutuhkan untuk memvalidasi pesan yang ditandatangani."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Kunci Publik Alat"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Masukkan kunci publik alat dalam format PEM (dimulai dengan -----BEGIN "
"PUBLIC KEY-----). Gunakan ini ketika alat menyediakan kunci publik statis "
"secara langsung."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Nama & Peran (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Aktifkan ini untuk memungkinkan alat mengakses nama dan peran peserta yang "
"terdaftar, jika alat mendukung NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Deep linking"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Aktifkan ini jika Anda ingin melakukan deep linking konten dari dalam alat, "
"di Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL Peluncuran Deep Linking"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Masukkan URL deep linking untuk alat ini. Jika alat tidak menentukan satu, "
"masukkan 'URL Peluncuran' di sini."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Tugas dan Nilai"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Deklaratif"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programatik"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Dinonaktifkan"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Aktifkan AGS dan pilih fungsionalitas. 'Deklaratif' menyediakan alat dengan "
"item baris yang sudah ada. 'Programatik' memungkinkan alat untuk membuat dan"
" mengelola item baris."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "ID Paspor LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Pilih ID paspor LTI untuk alat ini. Ini adalah ID paspor LTI yang Anda buat "
"di halaman Pengaturan Lanjutan."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "URL LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Masukkan URL peluncuran untuk alat ini. Untuk LTI 1.1/1.2, ini adalah URL "
"yang digunakan Open edX untuk meluncurkan alat tersebut."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Parameter Kustom"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Masukkan pasangan kunci-nilai untuk dikirim bersama setiap peluncuran, "
"misalnya [\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Buka alat dalam"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Pilih bagaimana alat dibuka untuk peserta didik: secara inline dalam "
"halaman, di modal, atau di jendela baru."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Teks Tombol Peluncuran"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Masukkan label yang ditampilkan pada tombol peluncuran ketika alat dibuka di"
" modal atau jendela baru."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Tinggi Inline (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Masukkan tinggi iframe inline dalam piksel."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Tinggi Modal (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Masukkan tinggi modal sebagai persentase dari jendela peramban."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Lebar Modal (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Masukkan lebar modal sebagai persentase dari jendela peramban."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Aktivitas ini dinilai"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr "Aktifkan ini jika alat mengirimkan skor numerik kembali ke Open edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Bobot Nilai"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Masukkan jumlah poin maksimum untuk komponen ini."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Skor yang disimpan dalam xblock KVS -- duplikat dari skor yang diterbitkan "
"di django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Komentar seperti yang dikembalikan dari penilai, spesifikasi LTI2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Sembunyikan Alat Eksternal"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Aktifkan ini untuk menyembunyikan tombol peluncuran dan iframe sehingga Anda"
" dapat menggunakan komponen untuk sinkronisasi nilai, dll."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Terima nilai setelah tanggal jatuh tempo"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Aktifkan ini untuk memungkinkan alat mengirim nilai setelah tanggal jatuh "
"tempo berlalu."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Bagikan Nama Pengguna"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr ""
"Aktifkan ini untuk mengirim nama pengguna peserta didik ke alat tersebut."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Bagikan Nama Lengkap"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr ""
"Aktifkan ini untuk mengirim nama lengkap peserta didik ke alat tersebut."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Bagikan Email"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Aktifkan ini untuk mengirim alamat email peserta didik ke alat tersebut."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Kirim parameter tambahan"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Aktifkan ini untuk mengirim parameter tambahan (mungkin mengandung PII). "
"Konsultasikan dengan admin situs untuk detailnya."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Parameter kustom harus berupa daftar"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Parameter kustom harus berupa string dalam format \"x=y\"."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"ID konfigurasi yang dapat digunakan kembali harus ditetapkan saat "
"menggunakan konfigurasi eksternal (Contoh: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"LTI ID yang ditentukan tidak dikonfigurasi dalam Pengaturan Lanjutan kursus "
"ini."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Tidak dapat mengambil data pengguna untuk permintaan saat ini."

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Tidak dapat mengurai paspor LTI: {lti_passport!r}. Harus berupa string "
"\"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Tidak dapat mengambil ID pengguna untuk permintaan saat ini."

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Tidak dapat mengurai parameter kustom: {custom_parameter!r}. Harus berupa "
"string \"x=y\"."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Pengguna sesungguhnya tidak ditemukan untuk anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Kunci Privat yang dihasilkan oleh platform. Jaga nilai ini tetap rahasia."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "ID Kunci Privat yang dihasilkan oleh platform."

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Keyset JWK yang dihasilkan oleh platform."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "ID Klien yang digunakan oleh alat LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Konfigurasi LTI yang disimpan pada model untuk LTI 1.3 harus memiliki nilai "
"untuk salah satu dari lti_1p3_tool_public_key atau lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfigurasi Disimpan pada field XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfigurasi Disimpan pada model ini"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfigurasi Disimpan pada layanan eksternal"

#: models.py:239
msgid "LTI configuration data."
msgstr "Data konfigurasi LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL alat eksternal yang memulai peluncuran."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Kunci klien yang disediakan oleh penyedia alat LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Rahasia klien yang disediakan oleh penyedia alat LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Konfigurasi LTI yang disimpan pada XBlock memerlukan penetapan lokasi blok."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Konfigurasi LTI yang menggunakan konfigurasi yang dapat digunakan kembali "
"memerlukan ID eksternal dalam format \"x:y\"."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "Konfigurasi LTI untuk 1.3 memerlukan paspor untuk ditetapkan."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK dan CONFIG_EXTERNAL tidak didukung untuk LTI 1.3 Proctoring"
" Services."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Konfigurasi LTI tidak valid."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Tipe konten yang dipilih tidak didukung oleh Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Anda tidak memiliki akses untuk menyimpan Item Konten LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Harap periksa bahwa Anda memiliki izin staf kursus dan periksa kembali "
"pengaturan LTI blok ini."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Deep Linking LTI gagal."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "Deep Linking LTI"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "Konten Deep Linking LTI berhasil disimpan di LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Anda dapat menutup halaman ini dengan aman sekarang."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Tidak diizinkan."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Siswa tidak memiliki izin untuk melakukan peluncuran konfigurasi Deep "
"Linking LTI."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "Peluncuran LTI 1.3 hanya dapat dilakukan dari LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Untuk mengatur integrasi LTI, Anda perlu mendaftarkan LMS di alat dengan "
"informasi yang diberikan di bawah ini."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "ID Klien: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "ID Deployment: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "URL Keyset: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "URL Access Token: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "URL Login: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Deep Linking telah dikonfigurasi pada alat ini."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "Konfigurasi Deep Linking yang disimpan ditampilkan di bawah ini:"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr ""
"Jika Anda menjalankan deep linking lagi, konten di atas akan digantikan."

#: templates/html/lti_1p3_studio.html:49
msgid "You can configure this tool's content using LTI Deep Linking."
msgstr ""
"Anda dapat mengonfigurasi konten alat ini menggunakan Deep Linking LTI."

#: templates/html/lti_1p3_studio.html:50
msgid "To do that, make sure the block is published and click the link below:"
msgstr ""
"Untuk melakukan itu, pastikan blok telah dipublikasikan dan klik tautan di "
"bawah ini:"

#: templates/html/lti_1p3_studio.html:53
msgid "Deep Linking Launch - Configure tool"
msgstr "Peluncuran Deep Linking - Konfigurasikan alat"

#: templates/html/lti_launch.html:27
msgid "Press to Launch"
msgstr "Tekan untuk Meluncurkan"

#: templates/html/lti_launch_error.html:10
msgid "There was an error while launching the LTI tool: "
msgstr "Terjadi kesalahan saat meluncurkan alat LTI: "

#: templates/html/lti_launch_error.html:16
#: templates/html/lti_proctoring_start_error.html:13
msgid ""
"If you're seeing this on a live course, please contact the course staff."
msgstr ""
"Jika Anda melihat ini pada kursus yang sedang berjalan, harap hubungi staf "
"kursus."

#: templates/html/lti_proctoring_start_error.html:10
msgid "There was an error while starting your LTI proctored assessment."
msgstr "Terjadi kesalahan saat memulai penilaian proktor LTI Anda."

#: templates/html/lti_start_assessment.html:11
msgid "Sending you back to your exam."
msgstr "Mengembalikan Anda ke ujian Anda."

#: templates/html/lti_start_assessment.html:15
msgid "Return to exam."
msgstr "Kembali ke ujian."

#: templates/html/lti_studio_edit/_actions.html:5
msgid "Previous"
msgstr "Sebelumnya"

