#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "No s'ha trobat el token d'autenticació LTI 1.3."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Capçalera de token no vàlida. No s'han proporcionat credencials."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Capçalera de token no vàlida. La cadena del token no ha de contenir espais."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "No s'ha trobat la configuració LTI."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Signatura de token no vàlida."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr ""
"No s'ha trobat cap identificador d'usuari vàlid a l'URL del punt final."

#: lti_xblock.py:147
msgid "New"
msgstr "Nou"

#: lti_xblock.py:151
msgid "Database"
msgstr "Base de dades"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Existent"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Nom per a mostrar"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Introduïu el nom que veuen els estudiants per a aquest component. Aquest nom"
" també pot aparèixer en els informes."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Consumidor LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Avís de compartició de dades"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Introduïu un avís breu sobre l'eina. Feu servir aquest camp per explicar per"
" què es poden compartir les dades dels estudiants amb ella."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Tipus de configuració"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Seleccioneu 'Nou' per configurar una nova eina LTI. Si l'administrador us ha"
" proporcionat l'identificador d'una configuració d'eina reutilitzable "
"existent, seleccioneu 'Existent' i introduïu-lo al camp de text de la dreta."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Versió LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Seleccioneu la versió LTI que suporta la vostra eina."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "ID de reutilització LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "Introduïu l'ID d'una configuració d'eina reutilitzable existent."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "ID de passaport LTI 1.3 que apunta a la taula Lti1p3Passport"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "ID de passaport per a claus reutilitzables."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "URL de llançament"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Introduïu l'URL de llançament per a aquesta eina. Per a LTI 1.3, aquesta és "
"l'URL que utilitza Open edX per llançar l'eina."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "URL d'inici de sessió de l'eina (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Introduïu l'URL d'inici de sessió OIDC de l'eina. Open edX utilitza aquesta "
"URL per iniciar el flux d'inici de sessió LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URIs de redirecció registrades"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Introduïu les URIs de redirecció que aquesta eina pot utilitzar durant "
"l'inici de sessió, per exemple [\"https://tool.com\", "
"\"https://tool_deeplink.com\"]. Deixeu-ho en blanc per a usar per defecte "
"l'URL de llançament i l'URL de deep linking."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Mode de clau pública de l'eina"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Trieu com obtindrà Open edX la clau pública de l'eina per validar missatges "
"signats."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL del conjunt de claus de l'eina"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Introduïu l'URL del conjunt de claus JWK de l'eina. Open edX utilitza "
"aquesta URL per obtenir les claus públiques necessàries per validar "
"missatges signats."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Clau pública de l'eina"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Introduïu la clau pública de l'eina en format PEM (comença amb -----BEGIN "
"PUBLIC KEY-----). Utilitzeu això quan l'eina proporcioni directament una "
"clau pública estàtica."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Noms i rols (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Activeu això per permetre que l'eina accedeixi als noms i rols dels "
"estudiants inscrits, si l'eina admet NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Deep linking"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Activeu això si voleu enllaçar en profunditat contingut des de dins de "
"l'eina, a Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL de llançament de deep linking"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Introduïu l'URL de deep linking per a aquesta eina. Si l'eina no "
"n'especifica cap, introduïu aquí l'\"URL de llançament\"."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Tasques i qualificacions"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Declaratiu"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programàtic"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Desactivat"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Activeu AGS i seleccioneu la funcionalitat. 'Declaratiu' proporciona a "
"l'eina un element de línia existent. 'Programàtic' permet que les eines "
"creïn i gestionin elements de línia."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "ID de passaport LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Seleccioneu l'ID de passaport LTI per a aquesta eina. Aquest és l'ID del "
"passaport LTI que heu creat a la pàgina de Configuració avançada."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "URL LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Introduïu l'URL de llançament per a aquesta eina. Per a LTI 1.1/1.2, aquesta"
" és l'URL que utilitza Open edX per llançar l'eina."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Paràmetres personalitzats"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Introduïu parells clau-valor per enviar amb cada llançament, per exemple "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Obrir l'eina a"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Seleccioneu com s'obre l'eina per als estudiants: en línia a la pàgina, en "
"una finestra modal o en una nova finestra."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Text del botó de llançament"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Introduïu l'etiqueta que es mostra al botó de llançament quan l'eina s'obre "
"en una finestra modal o en una nova finestra."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Alçada en línia (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Introduïu l'alçada de l'iframe en línia en píxels."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Alçada modal (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr ""
"Introduïu l'alçada modal com un percentatge de la finestra del navegador."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Amplada modal (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr ""
"Introduïu l'amplada modal com un percentatge de la finestra del navegador."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Aquesta activitat es qualifica"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr "Activeu això si l'eina envia una puntuació numèrica a Open edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Pes de la qualificació"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Introduïu el nombre màxim de punts per a aquest component."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"La puntuació emmagatzemada al KVS de l'xblock -- duplicat de la puntuació "
"publicada a la base de dades de Django"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Comentari tal com retorna el corrector, especificació LTI 2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Amaga l'eina externa"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Activeu això per amagar el botó de llançament i l'iframe, de manera que es "
"faci servir el component per sincronitzar qualificacions, etc."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Acceptar qualificacions després de la data límit"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Activeu això per permetre que l'eina enviï qualificacions després que hagi "
"passat la data límit."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Compartir nom d'usuari"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "Activeu això per enviar el nom d'usuari de l'estudiant a l'eina."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Compartir nom complet"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Activeu això per enviar el nom complet de l'estudiant a l'eina."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Compartir correu electrònic"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Activeu això per enviar l'adreça de correu electrònic de l'estudiant a "
"l'eina."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Enviar paràmetres addicionals"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Activeu això per enviar paràmetres addicionals (podrien contenir Dades "
"d'Identificació Personal). Consulteu l'administrador del lloc per obtenir "
"més detalls."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Els paràmetres personalitzats han de ser una llista"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Els paràmetres personalitzats han de ser cadenes en format \"x=y\"."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"S'ha d'establir l'ID de configuració reutilitzable quan s'utilitza una "
"configuració externa (exemple: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"L'ID LTI especificat no està configurat en la Configuració avançada d'aquest"
" curs."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr ""
"No s'ha pogut obtenir les dades de l'usuari per a la sol·licitud actual."

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"No s'ha pogut analitzar el passaport LTI: {lti_passport!r}. Ha de ser una "
"cadena de tipus \"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "No s'ha pogut obtenir l'ID d'usuari per a la sol·licitud actual."

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"No s'ha pogut analitzar el paràmetre personalitzat: {custom_parameter!r}. Ha"
" de ser una cadena de tipus \"x=y\"."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: No s'ha trobat un usuari real per anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Clau privada generada per la plataforma. Manteniu aquest valor en secret."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "ID de la clau privada generada per la plataforma"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Conjunt de claus JWK generat per la plataforma."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "ID de client utilitzat per l'eina LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"La configuració LTI emmagatzemada en el model per a LTI 1.3 ha de tenir un "
"valor per a una de les claus: lti_1p3_tool_public_key o "
"lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Configuració emmagatzemada en els camps de l'XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Configuració emmagatzemada en aquest model"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Configuració emmagatzemada en un servei extern"

#: models.py:239
msgid "LTI configuration data."
msgstr "Dades de configuració LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "L'URL de l'eina externa que inicia el llançament."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Clau de client proporcionada pel proveïdor de l'eina LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Secret de client proporcionat pel proveïdor de l'eina LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"La configuració LTI emmagatzemada a l'XBlock necessita una ubicació de bloc "
"definida."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"La configuració LTI que utilitza una configuració reutilitzable necessita un"
" ID extern en format \"x:y\"."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr ""
"La configuració LTI per a 1.3 requereix que el passaport estigui configurat."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK i CONFIG_EXTERNAL no són compatibles amb els serveis de "
"proctoring LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Configuració LTI no vàlida."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "El tipus de contingut seleccionat no és compatible amb Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "No teniu accés per desar elements de contingut LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Comproveu que teniu permisos de personal del curs i reviseu novament la "
"configuració LTI d'aquest bloc."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Ha fallat el deep linking LTI."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "Deep Linking LTI"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "El contingut de deep linking LTI s'ha desat correctament a l'LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Podeu tancar aquesta pàgina de manera segura ara."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "No autoritzat."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Els estudiants no tenen permisos per realitzar llançaments de configuració "
"de Deep Linking LTI."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "Els llançaments LTI 1.3 només es poden realitzar des de l'LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Per configurar la integració LTI, cal registrar l'LMS a l'eina amb la "
"informació proporcionada a continuació."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "ID de client: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "ID de desplegament: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "URL del conjunt de claus: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "URL del token d'accés: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "URL d'inici de sessió: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "El deep linking està configurat en aquesta eina."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "La configuració de deep linking desada es presenta a continuació:"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr ""
"Si executeu de nou el deep linking, el contingut anterior serà substituït."

#: templates/html/lti_1p3_studio.html:49
msgid "You can configure this tool's content using LTI Deep Linking."
msgstr ""
"Podeu configurar el contingut d'aquesta eina utilitzant el deep linking LTI."

#: templates/html/lti_1p3_studio.html:50
msgid "To do that, make sure the block is published and click the link below:"
msgstr ""
"Per fer-ho, assegureu-vos que el bloc està publicat i feu clic al següent "
"enllaç:"

#: templates/html/lti_1p3_studio.html:53
msgid "Deep Linking Launch - Configure tool"
msgstr "Llançament de Deep Linking - Configurar eina"

#: templates/html/lti_launch.html:27
msgid "Press to Launch"
msgstr "Premeu per llançar"

#: templates/html/lti_launch_error.html:10
msgid "There was an error while launching the LTI tool: "
msgstr "S'ha produït un error en llançar l'eina LTI: "

#: templates/html/lti_launch_error.html:16
#: templates/html/lti_proctoring_start_error.html:13
msgid ""
