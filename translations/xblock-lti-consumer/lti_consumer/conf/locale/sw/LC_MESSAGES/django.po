#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Tokeni ya uthibitishaji ya LTI 1.3 haipo."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Kichwa cha ishara si sahihi. Hakuna kitambulisho kilichotolewa."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Kichwa cha ishara si sahihi. Mfuatano wa ishara haufai kuwa na nafasi."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Usanidi wa LTI haujapatikana."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Sahihi ya tokeni isiyo sahihi."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr ""
"Hakuna kitambulisho halali cha mtumiaji kilichopatikana katika sehemu ya "
"mwisho ya URL"

#: lti_xblock.py:147
msgid "New"
msgstr "Mpya"

#: lti_xblock.py:151
msgid "Database"
msgstr "Hifadhidata"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Iliyopo"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Jina la Kuonyesha"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Ingiza jina ambacho wanafunzi wanaona kwa ajili ya kipengele hiki. Jina hili"
" linaweza pia kuonekana katika ripoti."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Mtumiaji wa LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Arifa ya Kushirikisha Data"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Andika taarifa fupi kuhusu chombo. Tumia sehemu hii kuelezea kwa nini data "
"ya wanafunzi inaweza kushirikiwa na chombo hicho."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Aina ya Usanidi"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Chagua 'Mpya' ili kusanidi Chombo cha LTI kipya. Ikiwa msimamizi wako "
"amekupatia kitambulisho cha usanidi wa chombo kinachotumika tena, chagua "
"'Iliyopo' na uingize katika sehemu ya maandishi upande wa kulia."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Toleo la LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Chagua toleo la LTI linaloungwa mkono na chombo chako."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "Kitambulisho cha Utumiaji Tena cha LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Ingiza kitambulisho cha usanidi wa chombo kinachotumika tena kilicho tayari."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr ""
"Kitambulisho cha pasipoti cha LTI 1.3 kinachoonyesha kwenye jedwali la "
"Lti1p3Passport"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "Kitambulisho cha pasipoti kwa funguo zinazotumika tena."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "URL ya Uzinduzi"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Ingiza URL ya uzinduzi kwa chombo hiki. Kwa LTI 1.3, huu ndio URL Open edX "
"inayotumia kuzindua chombo."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "URL ya Kuanzisha Kuingia kwa Chombo (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Ingiza URL ya kuanzisha kuingia kwa OIDC kwa chombo. Open edX inatumia URL "
"hii kuanzisha mtiririko wa kuingia kwa LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URI Zilizosajiliwa"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Ingiza URI za kuelekeza tena ambavyo chombo hiki kinaruhusiwa kutumia wakati"
" wa kuingia, mfano [\"https://tool.com\", \"https://tool_deeplink.com\"]. "
"Acha sehemu hii tupu ili kutumia URL ya uzinduzi na URL ya uunganisho wa "
"kina kwa chaguo-msingi."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Njia ya Ufunguo wa Umma ya Zana"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Chagua jinsi Open edX itakavyopata ufunguo wa umma wa chombo ili "
"kuthibitisha ujumbe uliosainiwa."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL ya Kitufe cha Zana"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Ingiza URL ya mkusanyiko wa funguo za JWK wa chombo. Open edX inatumia URL "
"hii kupata funguo za umma zinazohitajika kuthibitisha ujumbe uliosainiwa."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Ufunguo wa Umma wa Zana"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Ingiza ufunguo wa umma wa chombo kwa muundo wa PEM (huanza na -----BEGIN "
"PUBLIC KEY-----). Tumia hili wakati chombo kinapotoa ufunguo wa umma wa "
"kudumu moja kwa moja."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Majina na Wajibu (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Washa chaguo hili kuruhusu chombo kufikia majina na wajibu wa wanafunzi "
"waliojisajili, ikiwa chombo kinasaidia NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Kuunganisha kwa kina"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Washa chaguo hili ikiwa unataka kuunganisha moja kwa moja maudhui kutoka "
"ndani ya chombo, katika Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL ya Uzinduzi wa Kuunganisha Kina"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Ingiza URL ya uunganisho wa kina kwa chombo hiki. Ikiwa chombo hakitataja "
"moja, ingiza hapa 'URL ya Uzinduzi'."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Kazi na Alama"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Taarifu"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programmatic"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Imezimwa"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Washa AGS na chagua utendakazi. 'Taarifu' inatoa chombo kipengele kilicho "
"tayari. 'Programmatic' inaruhusu chombo kuunda na kusimamia vipengele."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "Kitambulisho cha Pasipoti cha LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Chagua kitambulisho cha pasipoti cha LTI kwa chombo hiki. Hiki ndicho "
"kitambulisho cha pasipoti cha LTI ulichoandaa kwenye ukurasa wa Mipangilio "
"ya Zaidi."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "URL ya LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Ingiza URL ya uzinduzi kwa chombo hiki. Kwa LTI 1.1/1.2, huu ndio URL Open "
"edX inayotumia kuzindua chombo."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Vigezo Maalum"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Ingiza jozi za ufunguo-thamani za kutumwa kila tunapoanzisha, mfano "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Fungua chombo katika"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Chagua jinsi chombo kitatokea kwa wanafunzi: ndani ya ukurasa, katika "
"dirisha la modal, au katika dirisha jipya."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Andiko la Kitufe cha Kuzindua"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Ingiza lebo inayoonyeshwa kwenye kitufe cha kuzinduia wakati chombo "
"kinakufunguliwa katika modal au dirisha jipya."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Urefu wa Inline (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Ingiza urefu wa iframe ya ndani kwa pikseli."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Urefu wa Modal (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Ingiza urefu wa modal kama asilimia ya dirisha la kivinjari."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Upana wa Modal (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Ingiza upana wa modal kama asilimia ya dirisha la kivinjari."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Shughuli hii inapimwa"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Washa chaguo hili ikiwa chombo kitatumia alama za nambari kurudisha Open "
"edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Uzito wa Alama"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Ingiza idadi ya juu kabisa ya pointi kwa kipengele hiki."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Alama zilizowekwa katika xblock KVS -- nakala ya alama zilizochapishwa "
"katika django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Maoni kama yalivyorejeshwa kutoka kwa grader, LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Ficha Zana ya Nje"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Washa chaguo hili kuficha kitufe cha uzinduzi na iframe, ili kutumia "
"kipengele hiki kwa usawazishaji wa alama n.k."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Kubali alama baada ya tarehe ya mwisho"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Washa chaguo hili kuruhusu chombo kutuma alama baada ya tarehe ya mwisho "
"kupita."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Shiriki Jina la Mtumiaji"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "Washa chaguo hili kutuma jina la mtumiaji wa mwanafunzi kwa chombo."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Shiriki Jina Kamili"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Washa chaguo hili kutuma jina kamili la mwanafunzi kwa chombo."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Shiriki Barua Pepe"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr ""
"Washa chaguo hili kutuma anwani ya barua pepe ya mwanafunzi kwa chombo."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Tuma vigezo vya ziada"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Washa chaguo hili kutuma vigezo vya ziada (vinaweza kuwa na taarifa "
"binafsi). Wasiliana na msimamizi wa tovuti kwa maelezo zaidi."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Vigezo Maalum lazima iwe orodha"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr ""
"Vigezo Maalum vinapaswa kuwa mifuatano katika umbizo la &quot;x=y&quot;."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Kitambulisho cha usanidi kinachoweza kutumika tena lazima kiwekwe unapotumia"
" usanidi wa nje (Mfano: &quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Kitambulisho cha LTI kilichobainishwa hakijasanidiwa katika Mipangilio ya "
"Kina ya kozi hii."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Haikuweza kupata data ya mtumiaji kwa ombi la sasa"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Haikuweza kuchanganua pasipoti ya LTI: {lti_passport!r}. Inapaswa kuwa "
"&quot;id:key:secret&quot; kamba."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Haikuweza kupata kitambulisho cha mtumiaji kwa ombi la sasa"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Haikuweza kuchanganua kigezo maalum: {custom_parameter!r}. Inapaswa kuwa "
"&quot;x=y&quot; kamba."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Mtumiaji halisi hakupatikana dhidi ya anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Ufunguo wa Kibinafsi uliotengenezwa na Jukwaa. Weka siri hii ya thamani."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Kitambulisho cha ufunguo wa Faragha kilichotengenezwa na Jukwaa"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Kitufe cha JWK kilichotengenezwa na Jukwaa."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Kitambulisho cha Mteja kinachotumiwa na zana ya LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Usanidi wa LTI uliohifadhiwa kwenye muundo wa LTI 1.3 lazima uwe na thamani "
"ya mojawapo ya lti_1p3_tool_public_key au lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Usanidi Umehifadhiwa kwenye sehemu za XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Usanidi Umehifadhiwa kwenye muundo huu"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Usanidi Umehifadhiwa kwenye huduma ya nje"

#: models.py:239
msgid "LTI configuration data."
msgstr "Data ya usanidi wa LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL ya zana ya nje inayoanzisha uzinduzi."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Kitufe cha mteja kilichotolewa na mtoaji zana wa LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Siri ya mteja iliyotolewa na mtoaji wa zana za LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Maduka ya Usanidi ya LTI kwenye XBlock yanahitaji seti ya eneo la kizuizi."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Usanidi wa LTI kwa kutumia usanidi unaoweza kutumika tena unahitaji "
"kitambulisho cha nje katika umbizo la &quot;x:y&quot;."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "Usanidi wa LTI kwa 1.3 unahitaji pasipoti kuwekwa."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK na CONFIG_EXTERNAL hazitumiki kwa Huduma za Uzalishaji wa "
"LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Usanidi batili wa LTI."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Aina ya maudhui iliyochaguliwa haitumiki na Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Huna ufikiaji wa kuhifadhi Vipengee vya Maudhui ya LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Tafadhali hakikisha kuwa una ruhusa za wafanyikazi wa kozi na uangalie tena "
"mipangilio ya LTI ya kizuizi hiki."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Kuunganisha kwa kina LTI kumeshindwa."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "Uunganisho wa kina wa LTI"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "Maudhui ya LTI Deep Linking yalihifadhiwa kwa ufanisi katika LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Unaweza kufunga ukurasa huu kwa usalama sasa."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Haijaidhinishwa."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Wanafunzi hawana ruhusa ya kutekeleza uzinduzi wa usanidi wa LTI Deep "
"Linking."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "Uzinduzi wa LTI 1.3 unaweza tu kufanywa kutoka kwa LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Ili kusanidi muunganisho wa LTI, unahitaji kusajili LMS kwenye zana kwa "
"taarifa iliyotolewa hapa chini."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Kitambulisho cha Mteja: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "Kitambulisho cha Usambazaji: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "URL ya kuweka vitufe: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "URL ya Tokeni ya Ufikiaji: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "URL ya Kuingia: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Kuunganisha kwa kina kumesanidiwa kwenye zana hii."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "Usanidi wa Uunganisho wa Kina uliohifadhiwa umewasilishwa hapa chini:"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr ""
"Ikiwa unatumia kiunganishi cha kina tena, maudhui yaliyo hapo juu "
"yatabadilishwa."

#: templates/html/lti_1p3_studio.html:49
msgid "You can configure this tool's content using LTI Deep Linking."
