#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Відсутній маркер автентифікації LTI 1.3."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Недійсний заголовок маркера. Облікові дані не надано."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Недійсний заголовок маркера. Рядок маркера не повинен містити пробілів."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Конфігурацію LTI не знайдено."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Недійсний підпис маркера."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr ""
"Не знайдено дійсного ідентифікатора користувача в URL-адресі кінцевої точки"

#: lti_xblock.py:147
msgid "New"
msgstr "Новий"

#: lti_xblock.py:151
msgid "Database"
msgstr "База даних"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Існуючий"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Назва, що відображається"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Введіть назву, яку учні бачать для цього компонента. Ця назва може "
"з’являтися в звітах."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Споживач LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Повідомлення про обмін даними"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Введіть коротке повідомлення про інструмент. Використовуйте це поле, щоб "
"пояснити, чому дані учнів можуть бути надані інструменту."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Тип конфігурації"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Виберіть «Новий», щоб налаштувати новий LTI інструмент. Якщо ваш "
"адміністратор надав вам ідентифікатор існуючої конфігурації для повторного "
"використання, виберіть «Існуючий» та введіть його в поле праворуч."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Версія LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Виберіть версію LTI, яку підтримує ваш інструмент."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "Ідентифікатор повторного використання LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr ""
"Введіть ідентифікатор існуючої конфігурації для повторного використання."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr ""
"Ідентифікатор паспорту LTI 1.3, що посилається на таблицю Lti1p3Passport."

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "Паспортний ID для повторно використовуваних ключів."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "URL запуску"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Введіть URL запуску для цього інструменту. Для LTI 1.3 це URL, який Open edX"
" використовує для запуску інструменту."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "URL ініціації входу інструменту (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Введіть URL ініціації входу інструменту за OIDC. Open edX використовує цей "
"URL для запуску процесу входу LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "Зареєстровані URI перенаправлення"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Введіть URI перенаправлення, які цей інструмент може використовувати під час"
" входу, наприклад, [\"https://tool.com\", \"https://tool_deeplink.com\"]. "
"Залиште це поле порожнім, щоб за замовчуванням використовувати URL запуску "
"та URL глибокого посилання."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Режим відкритого ключа інструмента"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Виберіть, як Open edX отримуватиме публічний ключ інструменту для перевірки "
"підписаних повідомлень."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "URL набору інструментів"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Введіть URL набору ключів JWK інструменту. Open edX використовує цей URL для"
" отримання публічних ключів, необхідних для перевірки підписаних "
"повідомлень."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Відкритий ключ інструменту"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Введіть публічний ключ інструменту у форматі PEM (починається з -----BEGIN "
"PUBLIC KEY-----). Використовуйте це, коли інструмент надає статичний "
"публічний ключ безпосередньо."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Імена та ролі (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Увімкніть це, щоб дозволити інструменту доступ до імен та ролей "
"зареєстрованих учнів, якщо інструмент підтримує NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Глибинне посилання"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Увімкніть це, якщо ви бажаєте робити глибокі посилання на контент з "
"інструменту, у Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "URL-адреса запуску глибокого посилання"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Введіть URL глибокого посилання для цього інструменту. Якщо інструмент не "
"визначає його, введіть тут «URL запуску»."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Завдання та оцінки"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Декларативний"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Програмний"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Вимкнено"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Увімкніть AGS та виберіть функціональність. «Декларативний» надає "
"інструменту існуючий елемент рядка. «Програмний» дозволяє інструментам "
"створювати та керувати елементами рядка."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "Ідентифікатор паспорту LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Виберіть ідентифікатор паспорту LTI для цього інструменту. Це ідентифікатор "
"паспорту LTI, який ви створили на сторінці розширених налаштувань."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "URL LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Введіть URL запуску для цього інструменту. Для LTI 1.1/1.2 це URL, який Open"
" edX використовує для запуску інструменту."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Персональні параметри"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Введіть пари ключ-значення, які надсилатимуться при кожному запуску, "
"наприклад, [\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Відкрити інструмент у"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Виберіть, як інструмент відкриватиметься для учнів: вбудовано на сторінці, у"
" модальному вікні або в новому вікні."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Текст кнопки запуску"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Введіть мітку, яка відображається на кнопці запуску, коли інструмент "
"відкривається у модальному чи новому вікні."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Висота вбудованого елемента (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Введіть висоту вбудованого iframe в пікселях."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Висота модального вікна (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Введіть висоту модального вікна у відсотках від вікна браузера."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Ширина модального вікна (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Введіть ширину модального вікна у відсотках від вікна браузера."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Ця діяльність оцінюється"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Увімкніть це, якщо інструмент надсилає числове значення оцінки назад до Open"
" edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Вага оцінки"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Введіть максимальну кількість балів для цього компонента."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Результат збережений в xblock KVS - опублікований результат продубльований в"
" django DB."

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Коментар оцінювача, специфікація LTI 2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Приховати зовнішній додаток"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Увімкніть це, щоб приховати кнопку запуску та iframe, якщо ви використовуєте"
" компонент для синхронізації оцінок тощо."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Приймати оцінки після строки здачі"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Увімкніть це, щоб дозволити інструменту надсилати оцінки після закінчення "
"строку здачі."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Надіслати ім’я користувача"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "Увімкніть це, щоб надсилати ім’я користувача учня до інструменту."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Надіслати повне ім’я"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Увімкніть це, щоб надсилати повне ім’я учня до інструменту."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Надіслати електронну пошту"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Увімкніть це, щоб надсилати електронну адресу учня до інструменту."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Надіслати додаткові параметри"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Увімкніть це, щоб надсилати додаткові параметри (можуть містити особисту "
"інформацію). Зверніться до адміністратора сайту для отримання докладної "
"інформації."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Спеціальні параметри мають бути списком"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Спеціальні параметри мають бути рядками у форматі &quot;x=y&quot;."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Ідентифікатор багаторазової конфігурації має бути встановлений під час "
"використання зовнішньої конфігурації (приклад: &quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Зазначений ідентифікатор LTI не налаштовано в додаткових налаштуваннях цього"
" курсу."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Не вдалося отримати дані користувача для поточного запиту"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Не вдалося проаналізувати паспорт LTI: {lti_passport!r}. Має бути рядок "
"&quot;id:key:secret&quot;."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Не вдалося отримати ідентифікатор користувача для поточного запиту"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Не вдалося проаналізувати спеціальний параметр: {custom_parameter!r}. Має "
"бути рядок &quot;x=y&quot;."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: справжнього користувача не знайдено за anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Приватний ключ, згенерований платформою. Тримайте це значення в секреті."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Ідентифікатор закритого ключа, згенерований платформою"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Набір ключів JWK, створений платформою."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Ідентифікатор клієнта, який використовується інструментом LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Конфігурація LTI, збережена в моделі для LTI 1.3, повинна мати значення для "
"одного з lti_1p3_tool_public_key або lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Конфігурація зберігається в полях XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Конфігурація збережена на цій моделі"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Конфігурація зберігається на зовнішній службі"

#: models.py:239
msgid "LTI configuration data."
msgstr "Дані конфігурації LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "URL-адреса зовнішнього інструменту, який ініціює запуск."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Ключ клієнта надається постачальником інструменту LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Секрет клієнта, наданий постачальником інструменту LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Для сховищ конфігурації LTI на XBlock потрібен набір розташування блоку."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Для конфігурації LTI із використанням багаторазової конфігурації потрібен "
"зовнішній ідентифікатор у форматі «x:y»."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "Для LTI 1.3 необхідно налаштувати паспорт."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK і CONFIG_EXTERNAL не підтримуються для LTI 1.3 Proctoring "
"Services."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Недійсна конфігурація LTI."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Вибраний тип вмісту не підтримується Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
