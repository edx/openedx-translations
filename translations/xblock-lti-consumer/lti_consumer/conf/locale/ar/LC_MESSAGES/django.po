#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "رمز مصادقة LTI 1.3 مفقود."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "الرمز (Token) في الرأس غير صالح. لم تُقدَّم معلومات الاعتماد."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr "الـtoken في الـheader غير صالح. يجب أن لا يحوي الـtoken أيّ فراغات."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "لم يتم العثور على إعدادات LTI."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "توقيع الرمز (Token) غير صالح."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "لم يُعثر على معرّف مستخدم صالح في رابط نقطة النهاية"

#: lti_xblock.py:147
msgid "New"
msgstr "جديد"

#: lti_xblock.py:151
msgid "Database"
msgstr "قاعدة البيانات"

#: lti_xblock.py:154
msgid "Existing"
msgstr "موجود"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "الاسم الظاهر"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"أدخل الاسم الذي يراه المتعلمون لهذا المكوّن. قد يظهر هذا الاسم أيضاً في "
"التقارير."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "مستخدم LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "إشعار مشاركة البيانات"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"أدخل إشعاراً موجزاً حول الأداة. استخدم هذا الحقل لشرح سبب مشاركة بيانات "
"المتعلمين معها."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "نوع الإعداد"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"اختر 'جديد' لتكوين أداة LTI جديدة. إذا قام المسؤول بتزويدك بمعرّف لتكوين "
"أداة قابلة لإعادة الاستخدام موجودة، فاختر 'موجود' وأدخلها في حقل النص على "
"اليمين."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "إصدار LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "اختر إصدار LTI الذي تدعمه أداتك."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "معرّف إعادة استخدام LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "أدخل معرّف تكوين الأداة القابلة لإعادة الاستخدام الموجودة."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "معرّف جواز سفر LTI 1.3 الذي يشير إلى جدول Lti1p3Passport"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "معرّف جواز السفر للمفاتيح القابلة لإعادة الاستخدام."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "رابط التشغيل"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"أدخل رابط التشغيل لهذه الأداة. بالنسبة لـ LTI 1.3، فإن هذا هو الرابط الذي "
"يستخدمه Open edX لتشغيل الأداة."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "رابط بدء تسجيل دخول الأداة (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"أدخل رابط بدء تسجيل دخول OIDC للأداة. يستخدم Open edX هذا الرابط لبدء عملية "
"تسجيل الدخول لـ LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "عناوين URI المُسجَّلة المُخصّصة لإعادة التوجيه"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"أدخل عناوين URL لإعادة التوجيه التي يُسمح للأداة باستخدامها أثناء تسجيل "
"الدخول، على سبيل المثال [\"https://tool.com\", "
"\"https://tool_deeplink.com\"]. اترك هذا الحقل فارغاً لاستخدام رابط التشغيل "
"ورابط الربط العميق افتراضياً."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "وضع المفتاح العام للأداة"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"اختر كيف سيحصل Open edX على المفتاح العام للأداة للتحقق من صحة الرسائل "
"الموقعة."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "عنوان URL لمجموعة مفاتيح الأداة"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"أدخل رابط مجموعة مفاتيح JWK للأداة. يستخدم Open edX هذا الرابط لاسترجاع "
"المفاتيح العامة اللازمة للتحقق من صحة الرسائل الموقعة."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "المفتاح العام للأداة"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"أدخل المفتاح العام للأداة بصيغة PEM (يبدأ بـ -----BEGIN PUBLIC KEY-----). "
"استخدم هذا عند توفير الأداة للمفتاح العام الثابت مباشرةً."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "الأسماء والأدوار (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"فعّل هذا للسماح للأداة بالوصول إلى أسماء وأدوار المتعلمين المسجلين، إذا كانت"
" الأداة تدعم NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "الربط العميق (Deep linking)"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr "فعّل هذا إذا كنت تريد الربط العميق للمحتوى من داخل الأداة في Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "رابط تشغيل الربط العميق "

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"أدخل رابط الربط العميق لهذه الأداة. إذا لم تحدد الأداة واحداً، أدخل 'رابط "
"التشغيل' هنا."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "الواجبات والدرجات"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "تصريحي"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "برمجي"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "معطل"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"فعّل نظام AGS واختر الوظيفة. يَقدم الخيار 'تصريحي' للأداة عنصر خطي موجود "
"مسبقاً، بينما يسمح الخيار 'برمجي' للأدوات بإنشاء وإدارة العناصر الخطية."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "معرّف جواز سفر LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"اختر معرّف جواز سفر LTI لهذه الأداة. هذا هو المعرف الذي أنشأته في صفحة "
"الإعدادات المتقدمة."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "رابط LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"أدخل رابط التشغيل لهذه الأداة. بالنسبة لـ LTI 1.1/1.2، فإن هذا هو الرابط "
"الذي يستخدمه Open edX لتشغيل الأداة."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "المُعطيات المُخصّصة"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"أدخل أزواج القيمة والمفتاح التي سترسل مع كل تشغيل، على سبيل المثال "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "افتح الأداة في"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"اختر كيف تُفتح الأداة للمتعلمين: مضمّنة في الصفحة، أو في نافذة منبثقة، أو في"
" نافذة جديدة."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "نص زر التشغيل"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"أدخل التسمية المعروضة على زر التشغيل عند فتح الأداة في نافذة منبثقة أو "
"جديدة."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "ارتفاع المضمّن (بكسل)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "أدخل ارتفاع الإطار المضمّن (iframe) بالبكسل."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "ارتفاع النافذة المنبثقة (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "أدخل ارتفاع النافذة المنبثقة كنسبة مئوية من نافذة المتصفح."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "عرض النافذة المنبثقة (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "أدخل عرض النافذة المنبثقة كنسبة مئوية من نافذة المتصفح."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "يتم تقييم هذا النشاط"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr "فعّل هذا إذا كانت الأداة ترسل درجة رقمية إلى Open edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "وزن الدرجة"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "أدخل الحد الأقصى لعدد النقاط لهذا المكوّن."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"حُفِظت النتيجة في xblock KVS -- وهي نسخة مطابقة للنتيجة المنشورة في قاعدة "
"بيانات django"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "التعليق العائد من المقيّم، LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "اخفِ الأداة الخارجية"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"فعّل هذا لإخفاء زر التشغيل والإطار المضمّن بحيث تستخدم المكوّن لمزامنة "
"الدرجات وغيرها."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "قبول الدرجات بعد تاريخ الاستحقاق"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr "فعّل هذا للسماح للأداة بإرسال الدرجات بعد انقضاء تاريخ الاستحقاق."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "مشاركة اسم المستخدم"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "فعّل هذا لإرسال اسم المستخدم الخاص بالمتعلم إلى الأداة."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "مشاركة الاسم الكامل"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "فعّل هذا لإرسال الاسم الكامل للمتعلم إلى الأداة."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "مشاركة البريد الإلكتروني"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "فعّل هذا لإرسال عنوان البريد الإلكتروني الخاص بالمتعلم إلى الأداة."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "أرسِل مُعطيات إضافية"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"فعّل هذا لإرسال معلمات إضافية (قد تحتوي على معلومات شخصية). استشر مسؤول "
"الموقع للمزيد من التفاصيل."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "يجب أن تكون المُعطيات المُخصّصة لائحة"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "يجب أن تكون المُعطيات المُخصّصة سلاسل نصّية بنَسَق \"x=y\"."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"يجب أن يُضبَط معرّف الإعدادات الصالحة لإعادة الاستخدام عند استخدام إعدادات "
"خارجية (مثلاً: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr "لم يُضبَط معرّف LTI المحدّد في الإعدادات المتقدمة لهذا المساق."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "تعذر الحصول على بيانات المستخدم للطلب الحالي"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"تعذّر تفسير معلومات استيثاق LTI: {lti_passport!r}. يجب أن تكون سلسلة نصّية "
"بنَسَق \"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "تعذر الحصول على معرف المستخدم للطلب الحالي"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"تعذّر تفسير المُعطيات المُخصّصة: {custom_parameter!r}. يجب أن تكون سلسلة "
"نصّية بنَسَق \"x=y\"."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: لم يُعثر على مستخدم حقيقي يُقابِل anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "لقد أُنشِئ المفتاح الخاص للمنصة. حافِظ على سرّيته!"

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "معرف المِفتاح الخاص للمنصّة الذي تم إنشاؤه"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "مجموعة مفاتيح JWK للمنصة التي تَمَّ إنشاؤها."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "معرف العميل الذي تستخدمه أداة LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"يجب أن تحتوي إعدادات LTI المُخزّنة في إصدار LTI 1.3 إمّا على "
"lti_1p3_tool_public_key أو lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "الإعدادات المخزّنة في حقول XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "الإعدادات المخزّنة في هذا النموذج"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "الإعدادات المخزّنة في الخدمة الخارجية"

#: models.py:239
msgid "LTI configuration data."
msgstr "بيانات إعداد LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "رابط الأداة الخارجية المعنية ببَدء التشغيل"

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "مفتاح العميل المقدم من مُزوِّد أداة LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "سر العميل المقدم من مُزوِّد أداة LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr "تحتاج مخازن إعدادات LTI في XBlock إلى تعيين موقع الكتلة."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"تحتاج إعدادات LTI التي تستخدم إعدادات ممكن إعادة استخدامها إلى معرّف خارجي "
"بنَسَق \"x:y\"."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "يتطلب تكوين LTI 1.3 تعيين جواز السفر."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK و CONFIG_EXTERNAL ليسا مدعومين لخدمات مراقبة LTI 1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "إعدادات LTI غير صالحة."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "نوع المحتوى الذي اخترته لا تدعمه Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "ليست لديك صلاحية حفظ عناصر محتوى LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
