#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "Brakuje tokenu uwierzytelniającego LTI 1.3."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr ""
"Niepoprawny nagłówek tokenu. Brak podanych danych uwierzytelniających."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr ""
"Niepoprawny nagłówek tokenu. Ciąg tokenu nie powinien zawierać spacji."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "Konfiguracja LTI nie znaleziona."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Nieprawidłowy podpis tokenu."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr ""
"Nie znaleziono prawidłowego identyfikatora użytkownika w adresie URL punktu "
"końcowego."

#: lti_xblock.py:147
msgid "New"
msgstr "Nowy"

#: lti_xblock.py:151
msgid "Database"
msgstr "Baza danych"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Istniejący"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Nazwa wyświetlana"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Wpisz nazwę, którą uczniowie zobaczą dla tego elementu. Ta nazwa może "
"również pojawić się w raportach."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "Konsument LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Informacja o udostępnianiu danych"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Wpisz krótką informację o narzędziu. Użyj tego pola, aby wyjaśnić, dlaczego "
"dane uczniów mogą być z nim udostępniane."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Typ konfiguracji"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Wybierz 'Nowy', aby skonfigurować nowe narzędzie LTI. Jeśli administrator "
"podał Ci identyfikator istniejącej, wielokrotnej konfiguracji narzędzia, "
"wybierz 'Istniejący' i wpisz go w polu po prawej stronie."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "Wersja LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Wybierz wersję LTI obsługiwaną przez Twoje narzędzie."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "Identyfikator wielokrotnego użytku LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "Wpisz identyfikator istniejącej, wielokrotnej konfiguracji narzędzia."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "Identyfikator paszportu LTI 1.3 wskazujący na tabelę Lti1p3Passport"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "Identyfikator paszportu dla wielokrotnego użycia kluczy."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "Adres URL uruchomienia"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Wpisz adres URL uruchomienia dla tego narzędzia. Dla LTI 1.3 jest to adres "
"URL używany przez Open edX do uruchamiania narzędzia."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "Adres URL inicjacji logowania narzędzia (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Wpisz adres URL inicjujący logowanie OIDC narzędzia. Open edX używa tego "
"adresu do rozpoczynania przepływu logowania LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "Zarejestrowane przekierowania URI"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Wpisz przekierowania URI, których narzędzie może używać podczas logowania, "
"np. [\"https://tool.com\", \"https://tool_deeplink.com\"]. Pozostaw puste, "
"aby domyślnie użyć adresu URL uruchomienia i adresu URL głębokiego "
"linkowania."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Tryb klucza publicznego narzędzia"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"Wybierz, w jaki sposób Open edX uzyska klucz publiczny narzędzia do "
"weryfikacji podpisanych wiadomości."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "Adres URL zestawu kluczy narzędzia"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Wpisz adres URL zestawu kluczy JWK narzędzia. Open edX używa tego adresu do "
"pobierania kluczy publicznych potrzebnych do weryfikacji podpisanych "
"wiadomości."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Klucz publiczny narzędzia"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Wpisz klucz publiczny narzędzia w formacie PEM (zaczynający się od "
"-----BEGIN PUBLIC KEY-----). Użyj tego, gdy narzędzie udostępnia statyczny "
"klucz publiczny bezpośrednio."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "Nazwy i role (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Włącz to, aby umożliwić narzędziu dostęp do nazw i ról zapisanych uczniów, "
"jeżeli narzędzie obsługuje NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Głębokie linkowanie"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Włącz to, jeśli chcesz wykorzystać głębokie linkowanie treści w narzędziu, w"
" Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "Adres URL uruchomienia głębokiego linkowania"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Wpisz adres URL głębokiego linkowania dla tego narzędzia. Jeśli narzędzie go"
" nie określa, wpisz tutaj 'Adres URL uruchomienia'."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Zadanie i oceny"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Deklaratywny"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programistyczny"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Wyłączony"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"Włącz AGS i wybierz funkcjonalność. Opcja 'Deklaratywny' udostępnia "
"narzędziu istniejący element linii, natomiast 'Programistyczny' pozwala "
"narzędziom na tworzenie i zarządzanie elementami linii."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "Identyfikator paszportu LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Wybierz identyfikator paszportu LTI dla tego narzędzia. Jest to "
"identyfikator paszportu LTI, który utworzyłeś na stronie Ustawień "
"zaawansowanych."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "Adres URL LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Wpisz adres URL uruchomienia dla tego narzędzia. Dla LTI 1.1/1.2 jest to "
"adres URL używany przez Open edX do uruchamiania narzędzia."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Parametry niestandardowe"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Wpisz pary klucz-wartość do przesłania przy każdym uruchomieniu, np. "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Otwórz narzędzie w"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Wybierz, jak narzędzie ma być otwierane dla uczniów: bezpośrednio na "
"stronie, w oknie modalnym lub w nowym oknie."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Tekst przycisku uruchomienia"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Wpisz etykietę wyświetlaną na przycisku uruchomienia, gdy narzędzie otwiera "
"się w oknie modalnym lub nowym oknie."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Wysokość osadzenia (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Wpisz wysokość osadzonego iframe w pikselach."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Wysokość okna modalnego (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr ""
"Wpisz wysokość okna modalnego jako procent wielkości okna przeglądarki."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Szerokość okna modalnego (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr ""
"Wpisz szerokość okna modalnego jako procent wielkości okna przeglądarki."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Ta aktywność jest oceniana"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr ""
"Włącz to, jeśli narzędzie przesyła numeryczną ocenę z powrotem do Open edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Waga oceny"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Wpisz maksymalną liczbę punktów dla tego elementu."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Wynik przechowywany w KVS xblock — duplikat opublikowanego wyniku w bazie "
"Django."

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr ""
"Komentarz zwrócony przez system oceniania, zgodnie ze specyfikacją LTI 2.0"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Ukryj narzędzie zewnętrzne"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Włącz to, aby ukryć przycisk uruchomienia i iframe, dzięki czemu komponent "
"będzie używany do synchronizacji ocen itp."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Akceptuj oceny po terminie"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr "Włącz to, aby narzędzie mogło przesyłać oceny po upływie terminu."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Udostępnij nazwę użytkownika"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "Włącz to, aby przesłać nazwę użytkownika ucznia do narzędzia."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Udostępnij pełne imię i nazwisko"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Włącz to, aby przesłać pełne imię i nazwisko ucznia do narzędzia."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "Udostępnij adres e-mail"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Włącz to, aby przesłać adres e-mail ucznia do narzędzia."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Wyślij dodatkowe parametry"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Włącz to, aby przesłać dodatkowe parametry (mogą zawierać dane osobowe). "
"Skonsultuj się z administratorem witryny w celu uzyskania szczegółów."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Parametry niestandardowe muszą być listą"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Parametry niestandardowe powinny być ciągami w formacie \"x=y\"."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Musisz ustawić identyfikator konfiguracji wielokrotnego użytku podczas "
"korzystania z konfiguracji zewnętrznej (Przykład: \"x:y\")."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Podany identyfikator LTI nie jest skonfigurowany w Ustawieniach "
"zaawansowanych tego kursu."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Nie udało się pobrać danych użytkownika dla bieżącego żądania."

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"Nie udało się przeanalizować paszportu LTI: {lti_passport!r}. Powinien być "
"ciągiem \"id:key:secret\"."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr ""
"Nie udało się pobrać identyfikatora użytkownika dla bieżącego żądania."

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Nie udało się przeanalizować parametru niestandardowego: "
"{custom_parameter!r}. Powinien być ciągiem \"x=y\"."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: Nie znaleziono prawdziwego użytkownika dla anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr ""
"Wygenerowany przez platformę klucz prywatny. Zachowaj tę wartość w "
"tajemnicy."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Wygenerowany przez platformę identyfikator klucza prywatnego."

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Wygenerowany przez platformę zestaw kluczy JWK."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "Identyfikator klienta używany przez narzędzie LTI."

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"Konfiguracja LTI zapisana w modelu dla LTI 1.3 musi mieć wartość dla jednego"
" z: lti_1p3_tool_public_key lub lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "Konfiguracja zapisana w polach XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Konfiguracja zapisana w tym modelu"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Konfiguracja zapisana w usłudze zewnętrznej"

#: models.py:239
msgid "LTI configuration data."
msgstr "Dane konfiguracji LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Adres URL narzędzia zewnętrznego, które inicjuje uruchomienie."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "Klucz klienta dostarczony przez dostawcę narzędzia LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "Tajny klucz klienta dostarczony przez dostawcę narzędzia LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"Konfiguracja LTI zapisana w XBlock wymaga ustawienia lokalizacji bloku."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Konfiguracja LTI wykorzystująca konfigurację wielokrotnego użytku wymaga "
"zewnętrznego ID w formacie \"x:y\"."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "Konfiguracja LTI dla 1.3 wymaga ustawienia paszportu."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK i CONFIG_EXTERNAL nie są obsługiwane dla usług nadzoru LTI "
"1.3."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Niepoprawna konfiguracja LTI."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Wybrany typ treści nie jest obsługiwany przez Open edX."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "Nie masz dostępu do zapisu elementów treści LTI."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Sprawdź, czy masz uprawnienia personelu kursu i dokładnie zweryfikuj "
"ustawienia LTI tego bloku."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "Głębokie linkowanie LTI nie powiodło się."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "Głębokie linkowanie LTI"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "Treść głębokiego linkowania LTI została pomyślnie zapisana w LMS."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Możesz teraz bezpiecznie zamknąć tę stronę."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Nieautoryzowany."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Uczniowie nie mają uprawnień do uruchamiania konfiguracji głębokiego "
"linkowania LTI."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "Uruchomienia LTI 1.3 mogą być wykonane tylko z poziomu LMS."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"Aby skonfigurować integrację LTI, musisz zarejestrować LMS w narzędziu przy "
"użyciu informacji podanych poniżej."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Identyfikator klienta: "

#: templates/html/lti_1p3_studio.html:16
