#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "LTI 1.3 kimlik doğrulama jetonu eksik."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "Geçersiz jeton başlığı. Hiçbir kimlik bilgisi sağlanmadı."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr "Geçersiz jeton başlığı. Belirteç dizesi boşluk içermemelidir."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "LTI yapılandırması bulunamadı."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "Geçersiz jeton imzası."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "Uç nokta URL&#39;sinde geçerli bir kullanıcı kimliği bulunamadı"

#: lti_xblock.py:147
msgid "New"
msgstr "Yeni"

#: lti_xblock.py:151
msgid "Database"
msgstr "Veritabanı"

#: lti_xblock.py:154
msgid "Existing"
msgstr "Mevcut"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "Görünen Ad"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr ""
"Öğrencilerin bu bileşen için gördüğü adı girin. Bu ad, raporlarda da "
"görünebilir."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "LTI Tüketicisi"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "Veri Paylaşım Bildirimi"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"Araç hakkında kısa bir bildirim girin. Bu alanı, öğrenci verilerinin neden "
"paylaşılabileceğini açıklamak için kullanın."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "Yapılandırma Türü"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"Yeni bir LTI Aracı yapılandırmak için 'Yeni'yi seçin. Yönetici mevcut, "
"yeniden kullanılabilir araç yapılandırmasının kimliğini sağlamışsa, "
"'Mevcut'i seçin ve sağdaki metin alanına girin."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "LTI Sürümü"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "Araç tarafından desteklenen LTI sürümünü seçin."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "LTI Yeniden Kullanılabilirlik Kimliği"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "Mevcut yeniden kullanılabilir araç yapılandırmasının kimliğini girin."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "LTI 1.3 pasaport kimliği, Lti1p3Passport tablosuna işaret eder"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "Yeniden kullanılabilir anahtarlar için pasaport kimliği."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "Başlatma URL'si"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"Bu araç için başlatma URL'sini girin. LTI 1.3 için, Open edX'in aracı "
"başlatmak için kullandığı URL'dir."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "Araç Giriş Başlatma URL'si (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"Aracın OIDC giriş başlatma URL'sini girin. Open edX, LTI 1.3 giriş akışını "
"başlatmak için bu URL'yi kullanır."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "Kayıtlı Yönlendirme URI&#39;leri"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"Bu aracın giriş sırasında kullanmasına izin verilen yönlendirme URI'larını "
"girin, örneğin [\"https://tool.com\", \"https://tool_deeplink.com\"]. "
"Varsayılan olarak başlatma URL'si ve derin bağlantı URL'sini kullanmak için "
"boş bırakın."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "Araç Genel Anahtar Modu"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr ""
"İmzalı mesajları doğrulamak için aracın genel anahtarını Open edX'in nasıl "
"alacağını seçin."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "Araç Anahtar Seti URL&#39;si"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"Aracın JWK anahtar kümesinin URL'sini girin. Open edX, imzalı mesajların "
"doğrulanması için gerekli genel anahtarları almak amacıyla bu URL'yi "
"kullanır."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "Araç Genel Anahtarı"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"Aracın genel anahtarını PEM formatında girin (-----BEGIN PUBLIC KEY----- ile"
" başlar). Aracın doğrudan statik bir genel anahtar sağladığı durumlarda bunu"
" kullanın."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "İsimler & Roller (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"Aracın NRPS destekliyorsa, kayıtlı öğrencilerin isimlerine ve rollerine "
"erişmesine izin vermek için bunu etkinleştirin."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "Derin bağlantı"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr ""
"Stüdyo'da aracın içinden içerik için derin bağlantı vermek istiyorsanız bunu"
" etkinleştirin."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "Derin Bağlantı Başlatma URL&#39;si"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"Bu araç için derin bağlantı URL'sini girin. Araç bir tanesini belirtmediyse,"
" buraya 'Başlatma URL'sini girin."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "Ödev ve Notlar"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "Beyan"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "Programatik"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "Devre dışı"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"AGS'yi etkinleştirin ve işlevselliği seçin. 'Beyan' araca mevcut bir satır "
"öğesi sağlar. 'Programatik' ise araçların satır öğeleri oluşturmasına ve "
"yönetmesine izin verir."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "LTI Pasaport Kimliği"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"Bu araç için LTI pasaport kimliğini seçin. Bu, Gelişmiş Ayarlar sayfasında "
"oluşturduğunuz LTI pasaportun kimliğidir."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "LTI URL'si"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"Bu araç için başlatma URL'sini girin. LTI 1.1/1.2 için, Open edX'in aracı "
"başlatmak için kullandığı URL'dir."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "Özel yapılmış parametreler"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr ""
"Her başlatmada göndermek için anahtar-değer çiftlerini girin, örneğin "
"[\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "Aracı aç"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr ""
"Aracın öğrenciler için nasıl açılacağını seçin: sayfa içinde yerleşik "
"olarak, modal pencerede veya yeni bir pencerede."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "Başlatma Butonu Metni"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"Araç modal veya yeni pencerede açıldığında başlatma butonunda gösterilen "
"etiketi girin."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "Yerleşik Yükseklik (px)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "Yerleşik iframe'in yüksekliğini piksel cinsinden girin."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "Modal Yükseklik (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "Modal yüksekliğini tarayıcı penceresinin yüzdesi olarak girin."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "Modal Genişlik (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "Modal genişliğini tarayıcı penceresinin yüzdesi olarak girin."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "Bu etkinlik notlandırılır"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr "Araç, Open edX'e sayısal bir puan gönderiyorsa bunu etkinleştirin."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "Not Ağırlığı"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "Bu bileşen için maksimum puan sayısını girin."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr ""
"Puan xblock KVS'de tutuldu -- django DB'deki yayınlanan puanın kopyası"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "Derecelendirenden döndüğü gibi yorum, LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "Harici Aracı Gizle"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"Bileşeni not senkronizasyonu vb. için kullanıyorsanız, başlatma butonunu ve "
"iframe'i gizlemek için bunu etkinleştirin."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "Son teslim tarihinden sonra notları kabul et"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr ""
"Son teslim tarihi geçtikten sonra aracın not göndermesine izin vermek için "
"bunu etkinleştirin."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "Kullanıcı Adını Paylaş"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "Öğrencinin kullanıcı adını araca göndermek için bunu etkinleştirin."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "Tam Adı Paylaş"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "Öğrencinin tam adını araca göndermek için bunu etkinleştirin."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "E-posta Paylaş"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "Öğrencinin e-posta adresini araca göndermek için bunu etkinleştirin."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "Ekstra parametreler gönder"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"Ek parametreler göndermek için bunu etkinleştirin (KI içerebilir). "
"Ayrıntılar için site yöneticisine danışın."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "Özel Parametreler bir liste olmalıdır"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "Özel Parametreler &quot;x=y&quot; biçiminde dizeler olmalıdır."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"Harici yapılandırma kullanılırken yeniden kullanılabilir yapılandırma "
"kimliği ayarlanmalıdır (Örnek: &quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr ""
"Belirtilen LTI kimliği bu kursun Gelişmiş Ayarlar&#39;ında "
"yapılandırılmamış."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "Mevcut istek için kullanıcı verileri alınamadı"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"LTI pasaportu ayrıştırılamadı: {lti_passport!r}. &quot;id:key:secret&quot; "
"dizesi olmalıdır."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "Mevcut istek için kullanıcı kimliği alınamadı"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"Özel parametre ayrıştırılamadı: {custom_parameter!r}. &quot;x=y&quot; dizesi"
" olmalıdır."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: anon_id&#39;ye karşı gerçek kullanıcı bulunamadı: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "Platformun oluşturduğu Özel anahtar. Bu değeri gizli tutun."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "Platformun oluşturduğu Özel anahtar kimliği"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "Platformun oluşturduğu JWK anahtar seti."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "LTI aracı tarafından kullanılan istemci kimliği"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"LTI 1.3 için modelde depolanan LTI Yapılandırması, lti_1p3_tool_public_key "
"veya lti_1p3_tool_keyset_url&#39;den biri için bir değere sahip olmalıdır."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "XBlock alanlarında saklanan konfigürasyon"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "Bu modelde saklanan yapılandırma"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "Yapılandırma Harici hizmette saklandı"

#: models.py:239
msgid "LTI configuration data."
msgstr "LTI yapılandırma verileri."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "Başlatmayı başlatan harici aracın URL&#39;si."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "LTI aracı sağlayıcısı tarafından sağlanan istemci anahtarı."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "LTI aracı sağlayıcısı tarafından sağlanan istemci sırrı."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr ""
"XBlock&#39;taki LTI Yapılandırma depolarının bir blok konumu ayarına "
"ihtiyacı vardır."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"Yeniden kullanılabilir yapılandırmayı kullanan LTI Yapılandırması, "
"&quot;x:y&quot; biçiminde harici bir kimliğe ihtiyaç duyar."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "LTI 1.3 yapılandırması için pasaportun ayarlanması gerekmektedir."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK ve CONFIG_EXTERNAL, LTI 1.3 Gözetmenlik Hizmetleri için "
"desteklenmez."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "Geçersiz LTI yapılandırması."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
msgstr "Seçilen içerik türü Open edX tarafından desteklenmiyor."

#: plugin/views.py:635
msgid "You don't have access to save LTI Content Items."
msgstr "LTI İçerik Öğelerini kaydetme erişiminiz yok."

#: plugin/views.py:636
msgid ""
"Please check that you have course staff permissions and double check this "
"block's LTI settings."
msgstr ""
"Lütfen kurs personeli izinlerinizin olup olmadığını kontrol edin ve bu "
"bloğun LTI ayarlarını tekrar kontrol edin."

#: templates/html/lti-dl/dl_response_error.html:6
msgid "LTI Deep Linking failed."
msgstr "LTI Derin Bağlantısı başarısız oldu."

#: templates/html/lti-dl/dl_response_saved.html:6
msgid "LTI Deep Linking"
msgstr "LTI Derin Bağlantısı"

#: templates/html/lti-dl/dl_response_saved.html:10
msgid "The LTI Deep Linking content was successfully saved in the LMS."
msgstr "LTI Deep Linking içeriği LMS&#39;e başarıyla kaydedildi."

#: templates/html/lti-dl/dl_response_saved.html:13
msgid "You can safely close this page now."
msgstr "Artık bu sayfayı güvenle kapatabilirsiniz."

#: templates/html/lti_1p3_permission_error.html:10
msgid "Unauthorized."
msgstr "Yetkisiz."

#: templates/html/lti_1p3_permission_error.html:13
msgid ""
"Students don't have permissions to perform LTI Deep Linking configuration "
"launches."
msgstr ""
"Öğrencilerin LTI Derin Bağlantı yapılandırması başlatma işlemlerini "
"gerçekleştirme izinleri yoktur."

#: templates/html/lti_1p3_studio.html:3
msgid "LTI 1.3 Launches can only be performed from the LMS."
msgstr "LTI 1.3 Başlatmaları yalnızca LMS&#39;den gerçekleştirilebilir."

#: templates/html/lti_1p3_studio.html:7
msgid ""
"To set up the LTI integration, you need to register the LMS in the tool with"
" the information provided below."
msgstr ""
"LTI entegrasyonunu kurmak için aşağıda verilen bilgilerle LMS&#39;yi araca "
"kaydetmeniz gerekir."

#: templates/html/lti_1p3_studio.html:11
msgid "Client ID: "
msgstr "Müşteri Kimliği: "

#: templates/html/lti_1p3_studio.html:16
msgid "Deployment ID: "
msgstr "Dağıtım Kimliği: "

#: templates/html/lti_1p3_studio.html:21
msgid "Keyset URL: "
msgstr "Anahtar seti URL&#39;si: "

#: templates/html/lti_1p3_studio.html:26
msgid "Access Token URL: "
msgstr "Erişim Belirteci URL&#39;si: "

#: templates/html/lti_1p3_studio.html:31
msgid "Login URL: "
msgstr "Giriş URL&#39;si: "

#: templates/html/lti_1p3_studio.html:39
msgid "Deep Linking is configured on this tool."
msgstr "Derin Bağlantı bu araçta yapılandırılmıştır."

#: templates/html/lti_1p3_studio.html:40
msgid "The Deep Linking configuration stored is presented below:"
msgstr "Saklanan Derin Bağlantı yapılandırması aşağıda sunulmuştur:"

#: templates/html/lti_1p3_studio.html:45
msgid "If you run deep linking again, the content above will be replaced."
msgstr ""
