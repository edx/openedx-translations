#: lti_1p3/extensions/rest_framework/authentication.py:41
msgid "Missing LTI 1.3 authentication token."
msgstr "חסר אסימון אימות LTI 1.3."

#: lti_1p3/extensions/rest_framework/authentication.py:45
msgid "Invalid token header. No credentials provided."
msgstr "כותרת אסימון לא חוקית. לא סופקו אישורים."

#: lti_1p3/extensions/rest_framework/authentication.py:49
msgid "Invalid token header. Token string should not contain spaces."
msgstr "כותרת אסימון לא חוקית. מחרוזת אסימון לא צריכה להכיל רווחים."

#: lti_1p3/extensions/rest_framework/authentication.py:57
msgid "LTI configuration not found."
msgstr "תצורת LTI לא נמצאה."

#: lti_1p3/extensions/rest_framework/authentication.py:66
msgid "Invalid token signature."
msgstr "חתימת אסימון לא חוקית."

#: lti_xblock.py:134
msgid "No valid user id found in endpoint URL"
msgstr "לא נמצא מזהה משתמש חוקי בכתובת האתר של נקודת הקצה"

#: lti_xblock.py:147
msgid "New"
msgstr "חדש"

#: lti_xblock.py:151
msgid "Database"
msgstr "מסד נתונים"

#: lti_xblock.py:154
msgid "Existing"
msgstr "קיים"

#: lti_xblock.py:262
msgid "Display Name"
msgstr "שם לתצוגה"

#: lti_xblock.py:264
msgid ""
"Enter the name learners see for this component. This name may also appear in"
" reports."
msgstr "הזן את השם שהתלמידים רואים עבור רכיב זה. שם זה עשוי להופיע גם בדוחות."

#: lti_xblock.py:267
msgid "LTI Consumer"
msgstr "צרכן LTI"

#: lti_xblock.py:270
msgid "Data Sharing Notice"
msgstr "הודעת שיתוף נתונים"

#: lti_xblock.py:272
msgid ""
"Enter a short notice about the tool. Use this field to explain why learner "
"data may be shared with it."
msgstr ""
"הזן הודעה קצרה על הכלי. השתמש בשדה זה כדי להסביר מדוע נתוני התלמיד עשויים "
"להיות משותפים עם הכלי."

#: lti_xblock.py:278
msgid "Configuration Type"
msgstr "סוג תצורה"

#: lti_xblock.py:283
msgid ""
"Select 'New' to configure a new LTI Tool. If your admin has provided you "
"with ID of an existing reusable tool configuration, select 'Existing' and "
"enter it in the text field on the right."
msgstr ""
"בחר ב'חדש' כדי להגדיר כלי LTI חדש. אם המנהל שלך סיפק לך מזהה של קונפיגורציה "
"קיימת לשימוש חוזר, בחר ב'קיים' והזן אותו בשדה הטקסט שבצד."

#: lti_xblock.py:289
msgid "LTI Version"
msgstr "גרסת LTI"

#: lti_xblock.py:297
msgid "Select the LTI version supported by your tool."
msgstr "בחר את גרסת LTI הנתמכת על ידי הכלי שלך."

#: lti_xblock.py:302
msgid "LTI Reusability ID"
msgstr "מזהה שימוש חוזר ב-LTI"

#: lti_xblock.py:304
msgid "Enter the ID of an existing reusable tool configuration."
msgstr "הזן את המזהה של קונפיגורציית כלי קיימת לשימוש חוזר."

#: lti_xblock.py:309
msgid "Lti 1.3 passport ID that points to Lti1p3Passport table"
msgstr "מזהה דרכון LTI 1.3 שמצביע לטבלת Lti1p3Passport"

#: lti_xblock.py:312
msgid "Passport ID for a reusable keys."
msgstr "מזהה הדרכון למפתחות לשימוש חוזר."

#: lti_xblock.py:316
msgid "Launch URL"
msgstr "כתובת השקה"

#: lti_xblock.py:320
msgid ""
"Enter the launch URL for this tool. For LTI 1.3, this is the URL Open edX "
"uses to launch the tool."
msgstr ""
"הזן את כתובת ההשקה של הכלי. עבור LTI 1.3, זו הכתובת שבה Open edX משתמשת כדי "
"להשיק את הכלי."

#: lti_xblock.py:324
msgid "Tool Initiate Login URL (OIDC)"
msgstr "כתובת URL לייזום התחברות (OIDC)"

#: lti_xblock.py:328
msgid ""
"Enter the tool’s OIDC login initiation URL. Open edX uses this URL to start "
"the LTI 1.3 login flow."
msgstr ""
"הזן את כתובת ה-OIDC להתחברות הכלי. Open edX משתמשת בכתובת זו כדי להתחיל את "
"תהליך ההתחברות של LTI 1.3."

#: lti_xblock.py:332
msgid "Registered Redirect URIs"
msgstr "URI רשומים להפניה מחדש"

#: lti_xblock.py:334
msgid ""
"Enter the redirect URIs this tool is allowed to use during login e.g. "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. Leave this blank to "
"use the launch URL and deep linking URL by default."
msgstr ""
"הזן את רשימת ה-redirect URIs שהכלי מורשה להשתמש בהן במהלך ההתחברות, למשל "
"[\"https://tool.com\", \"https://tool_deeplink.com\"]. השאר שדה זה ריק כדי "
"להשתמש כברירת מחדל בכתובת ההשקה ובכתובת הקישור המעמיק."

#: lti_xblock.py:342
msgid "Tool Public Key Mode"
msgstr "מצב מפתח ציבורי של כלי"

#: lti_xblock.py:350
msgid ""
"Choose how Open edX will get the tool’s public key for validating signed "
"messages."
msgstr "בחר כיצד Open edX תקבל את המפתח הציבורי של הכלי לאימות הודעות חתומות."

#: lti_xblock.py:354
msgid "Tool Keyset URL"
msgstr "כתובת אתר של ערכת מפתחות של כלי"

#: lti_xblock.py:358
msgid ""
"Enter the URL of the tool’s JWK keyset. Open edX uses this URL to retrieve "
"the public keys needed to validate signed messages."
msgstr ""
"הזן את כתובת ה-URL של קבוצת המפתחות JWK של הכלי. Open edX משתמשת בכתובת זו "
"כדי לאחזר את המפתחות הציבוריים הדרושים לאימות הודעות חתומות."

#: lti_xblock.py:363
msgid "Tool Public Key"
msgstr "מפתח ציבורי של כלי"

#: lti_xblock.py:368
msgid ""
"Enter the tool’s public key in PEM format (starts with -----BEGIN PUBLIC "
"KEY-----). Use this when the tool provides a static public key directly."
msgstr ""
"הזן את המפתח הציבורי של הכלי בפורמט PEM (מתחיל עם -----BEGIN PUBLIC "
"KEY-----). השתמש בזה כאשר הכלי מספק מפתח ציבורי סטטי ישירות."

#: lti_xblock.py:374
msgid "Names & Roles (NRPS)"
msgstr "שמות ותפקידים (NRPS)"

#: lti_xblock.py:376
msgid ""
"Enable this to allow the tool to access the names and roles of enrolled "
"learners, if the tool supports NRPS."
msgstr ""
"אפשר זאת כדי לאפשר לכלי גישה לשמות ולתפקידים של תלמידים נרשמים, במידה והכלי "
"תומך ב-NRPS."

#: lti_xblock.py:385
msgid "Deep linking"
msgstr "קישור עמוק"

#: lti_xblock.py:387
msgid ""
"Enable this if you want to deep link content from within the tool, in "
"Studio."
msgstr "אפשר זאת אם ברצונך לקשר תוכן לעומק מתוך הכלי, ב-Studio."

#: lti_xblock.py:393
msgid "Deep Linking Launch URL"
msgstr "כתובת אתר השקת קישור עמוק"

#: lti_xblock.py:397
msgid ""
"Enter the deep linking URL for this tool. If the tool does not specify one, "
"enter the 'Launch URL' here."
msgstr ""
"הזן את כתובת ה-URL לקישור מעמיק עבור הכלי. אם הכלי אינו מציין כתובת כזו, הזן"
" כאן את 'כתובת ההשקה'."

#: lti_xblock.py:401
msgid "Assignment and Grades"
msgstr "מטלות וציונים"

#: lti_xblock.py:403
msgid "Declarative"
msgstr "דקלרטיבי"

#: lti_xblock.py:404
msgid "Programmatic"
msgstr "תכנותי"

#: lti_xblock.py:405 templates/html/lti_studio_edit/_step_advantage.html:30
#: templates/html/lti_studio_edit/_step_advantage.html:114
#: templates/html/lti_studio_edit/_step_review.html:97
#: templates/html/lti_studio_edit/_step_review.html:218
msgid "Disabled"
msgstr "מושבת"

#: lti_xblock.py:410
msgid ""
"Enable AGS and select functionality. 'Declarative' provides the tool with an"
" existing line item. 'Programmatic' allows tools to create and manage line "
"items."
msgstr ""
"הפעל את AGS ובחר בפונקציונליות. 'דקלרטיבי' מספק לכלי פריט קיים, בעוד "
"'תכנותי' מאפשר לכלי ליצור ולנהל פריטים."

#: lti_xblock.py:417
msgid "LTI Passport ID"
msgstr "מזהה דרכון LTI"

#: lti_xblock.py:419
msgid ""
"Select the LTI passport ID for this tool. This is the ID of the LTI passport"
" that you created on Advanced Settings page."
msgstr ""
"בחר את מזהה הדרכון של LTI עבור הכלי. זהו המזהה של דרכון LTI שיצרת בדף "
"ההגדרות המתקדמות."

#: lti_xblock.py:426
msgid "LTI URL"
msgstr "כתובת URL של LTI"

#: lti_xblock.py:428
msgid ""
"Enter the launch URL for this tool. For LTI 1.1/1.2, this is the URL Open "
"edX uses to launch the tool."
msgstr ""
"הזן את כתובת ההשקה של הכלי. עבור LTI 1.1/1.2, זו הכתובת שבה Open edX משתמשת "
"כדי להשיק את הכלי."

#: lti_xblock.py:436
msgid "Custom Parameters"
msgstr "משתנים בהתאמה אישית"

#: lti_xblock.py:438
msgid ""
"Enter key-value pairs to send with each launch e.g. [\"page=1\", "
"\"color=white\"]."
msgstr "הזן זוגות מפתח-ערך לשליחה עם כל השקה, למשל [\"page=1\", \"color=white\"]."

#: lti_xblock.py:443
msgid "Open tool in"
msgstr "פתח את הכלי ב"

#: lti_xblock.py:445
msgid ""
"Choose how the tool opens for learners: inline in the page, in a modal, or "
"in a new window."
msgstr "בחר כיצד הכלי נפתח עבור התלמידים: בתוך הדף, במודאל, או בחלון חדש."

#: lti_xblock.py:456
msgid "Launch Button Text"
msgstr "טקסט כפתור ההשקה"

#: lti_xblock.py:458
msgid ""
"Enter the label shown on the launch button when the tool opens in a modal or"
" new window."
msgstr ""
"הזן את התווית אשר תופיע על כפתור ההשקה כאשר הכלי נפתח במודאל או בחלון חדש."

#: lti_xblock.py:464
msgid "Inline Height (px)"
msgstr "גובה מוטמע (פיקסלים)"

#: lti_xblock.py:466
msgid "Enter the height of the inline iframe in pixels."
msgstr "הזן את הגובה של ה-iframe המוטמע בפיקסלים."

#: lti_xblock.py:472
msgid "Modal Height (%)"
msgstr "גובה מודאל (%)"

#: lti_xblock.py:474
msgid "Enter the modal height as a percentage of the browser window."
msgstr "הזן את גובה המודאל כאחוז מגודל חלון הדפדפן."

#: lti_xblock.py:480
msgid "Modal Width (%)"
msgstr "רוחב מודאל (%)"

#: lti_xblock.py:482
msgid "Enter the modal width as a percentage of the browser window."
msgstr "הזן את רוחב המודאל כאחוז מגודל חלון הדפדפן."

#: lti_xblock.py:488
msgid "This activity is graded"
msgstr "פעילות זו נמדדת"

#: lti_xblock.py:489
msgid "Enable this if the tool sends a numeric score back to Open edX."
msgstr "אפשר זאת אם הכלי שולח ציון מספרי חזרה ל-Open edX."

#: lti_xblock.py:494
msgid "Grade Weight"
msgstr "משקל ציון"

#: lti_xblock.py:496
msgid "Enter the maximum number of points for this component."
msgstr "הזן את מספר הנקודות המקסימלי עבור רכיב זה."

#: lti_xblock.py:503
msgid ""
"The score kept in the xblock KVS -- duplicate of the published score in "
"django DB"
msgstr "הציון נשמר ב-xblock KVS -- שכפל את הציון שפורסם ב-django DB"

#: lti_xblock.py:508
msgid "Comment as returned from grader, LTI2.0 spec"
msgstr "הערה כפי שחזרה ממעניק הציון, LTI2.0 spec"

#: lti_xblock.py:513
msgid "Hide External Tool"
msgstr "הסתר כלי חיצוני"

#: lti_xblock.py:515
msgid ""
"Enable this to hide launch button and iframe so you use the component for "
"grade sync etc."
msgstr ""
"אפשר זאת כדי להסתיר את כפתור ההשקה וה-iframe, וכך להשתמש ברכיב לסנכרון "
"ציונים וכדומה."

#: lti_xblock.py:521
msgid "Accept grades after due date"
msgstr "קבל ציונים לאחר תאריך היעד"

#: lti_xblock.py:522
msgid ""
"Enable this to allow the tool to send grades after the due date has passed."
msgstr "אפשר זאת כדי לאפשר לכלי לשלוח ציונים לאחר תום תאריך היעד."

#: lti_xblock.py:530
msgid "Share Username"
msgstr "שתף שם משתמש"

#. Translators: This is used to request the user's username for a third party
#. service.
#: lti_xblock.py:532
msgid "Enable this to send the learner’s username to the tool."
msgstr "אפשר זאת כדי לשלוח את שם המשתמש של התלמיד לכלי."

#: lti_xblock.py:537
msgid "Share Full name"
msgstr "שתף שם מלא"

#. Translators: This is used to request the user's full name for a third party
#. service.
#: lti_xblock.py:539
msgid "Enable this to send the learner’s full name to the tool."
msgstr "אפשר זאת כדי לשלוח את השם המלא של התלמיד לכלי."

#: lti_xblock.py:544
msgid "Share Email"
msgstr "שתף אימייל"

#. Translators: This is used to request the user's email for a third party
#. service.
#: lti_xblock.py:546
msgid "Enable this to send the learner’s email address to the tool."
msgstr "אפשר זאת כדי לשלוח את כתובת הדוא״ל של התלמיד לכלי."

#: lti_xblock.py:552
msgid "Send extra parameters"
msgstr "שלח פרמטרים נוספים"

#: lti_xblock.py:553
msgid ""
"Enable this to send extra parameters (may contain PII). Consult site admin "
"for details."
msgstr ""
"אפשר זאת כדי לשלוח פרמטרים נוספים (עלולים להכיל מידע אישי). התייעץ עם מנהל "
"האתר לפרטים."

#: lti_xblock.py:627
msgid "Custom Parameters must be a list"
msgstr "פרמטרים מותאמים אישית חייבים להיות רשימה"

#: lti_xblock.py:634
msgid "Custom Parameters should be strings in \"x=y\" format."
msgstr "פרמטרים מותאמים אישית צריכים להיות מחרוזות בפורמט &quot;x=y&quot;."

#: lti_xblock.py:644
msgid ""
"Reusable configuration ID must be set when using external config (Example: "
"\"x:y\")."
msgstr ""
"יש להגדיר מזהה תצורה לשימוש חוזר בעת שימוש בתצורה חיצונית (דוגמה: "
"&quot;x:y&quot;)."

#: lti_xblock.py:668
msgid ""
"The specified LTI ID is not configured in this course's Advanced Settings."
msgstr "מזהה ה-LTI שצוין אינו מוגדר בהגדרות המתקדמות של קורס זה."

#: lti_xblock.py:802 lti_xblock.py:1119
msgid "Could not get user data for current request"
msgstr "לא ניתן היה לקבל נתוני משתמש עבור הבקשה הנוכחית"

#: lti_xblock.py:842
msgid ""
"Could not parse LTI passport: {lti_passport!r}. Should be \"id:key:secret\" "
"string."
msgstr ""
"לא ניתן לנתח דרכון LTI: {lti_passport!r}. צריכה להיות מחרוזת "
"&quot;id:key:secret&quot;."

#: lti_xblock.py:860 lti_xblock.py:874 lti_xblock.py:890
msgid "Could not get user id for current request"
msgstr "לא ניתן היה לקבל מזהה משתמש עבור הבקשה הנוכחית"

#: lti_xblock.py:1052
msgid ""
"Could not parse custom parameter: {custom_parameter!r}. Should be \"x=y\" "
"string."
msgstr ""
"לא ניתן לנתח פרמטר מותאם אישית: {custom_parameter!r}. צריכה להיות מחרוזת "
"&quot;x=y&quot;."

#: lti_xblock.py:1507
msgid "[LTI]: Real user not found against anon_id: {}"
msgstr "[LTI]: משתמש אמיתי לא נמצא נגד anon_id: {}"

#: models.py:61
msgid "Platform's generated Private key. Keep this value secret."
msgstr "המפתח הפרטי שנוצר על ידי הפלטפורמה. שמור את הערך הזה בסוד."

#: models.py:67
msgid "Platform's generated Private key ID"
msgstr "מזהה המפתח הפרטי שנוצר על ידי הפלטפורמה"

#: models.py:72
msgid "Platform's generated JWK keyset."
msgstr "ערכת מפתחות JWK שנוצרה בפלטפורמה."

#: models.py:78
msgid "Client ID used by LTI tool"
msgstr "מזהה לקוח בשימוש בכלי LTI"

#: models.py:159
msgid ""
"LTI Configuration stored on the model for LTI 1.3 must have a value for one "
"of lti_1p3_tool_public_key or lti_1p3_tool_keyset_url."
msgstr ""
"תצורת LTI המאוחסנת בדגם עבור LTI 1.3 חייבת להיות בעלת ערך אחד של "
"lti_1p3_tool_public_key או lti_1p3_tool_keyset_url."

#: models.py:203
msgid "Configuration Stored on XBlock fields"
msgstr "תצורה מאוחסנת בשדות XBlock"

#: models.py:204
msgid "Configuration Stored on this model"
msgstr "תצורה מאוחסנת בדגם זה"

#: models.py:205
msgid "Configuration Stored on external service"
msgstr "תצורה מאוחסנת בשירות חיצוני"

#: models.py:239
msgid "LTI configuration data."
msgstr "נתוני תצורת LTI."

#: models.py:246
msgid "The URL of the external tool that initiates the launch."
msgstr "כתובת האתר של הכלי החיצוני שמתחיל את ההשקה."

#: models.py:251
msgid "Client key provided by the LTI tool provider."
msgstr "מפתח לקוח מסופק על ידי ספק כלי ה-LTI."

#: models.py:257
msgid "Client secret provided by the LTI tool provider."
msgstr "סוד הלקוח מסופק על ידי ספק כלי ה-LTI."

#: models.py:346
msgid "LTI Configuration stores on XBlock needs a block location set."
msgstr "חנויות LTI Configuration ב-XBlock צריכות ערכת מיקום בלוק."

#: models.py:351
msgid ""
"LTI Configuration using reusable configuration needs a external ID in "
"\"x:y\" format."
msgstr ""
"תצורת LTI באמצעות תצורה ניתנת לשימוש חוזר זקוקה למזהה חיצוני בפורמט "
"&quot;x:y&quot;."

#: models.py:356
msgid "LTI Configuration for 1.3 requires passport to be set."
msgstr "הגדרות LTI עבור 1.3 דורשות הגדרת דרכון."

#: models.py:361
msgid ""
"CONFIG_ON_XBLOCK and CONFIG_EXTERNAL are not supported for LTI 1.3 "
"Proctoring Services."
msgstr ""
"CONFIG_ON_XBLOCK ו-CONFIG_EXTERNAL אינם נתמכים עבור שירותי LTI 1.3 "
"Proctoring."

#: models.py:369
msgid "Invalid LTI configuration."
msgstr "תצורת LTI לא חוקית."

#: plugin/views.py:620
msgid "The selected content type is not supported by Open edX."
