#: templates/edit.html:8
msgid "Display Name"
msgstr "Nazwa wyświetlana"

#: templates/edit.html:11
msgid "This name appears in the horizontal navigation at the top of the page"
msgstr "Ta nazwa pojawia się w poziomym pasku nawigacyjnym u góry strony"

#: templates/edit.html:16
msgid "Weight"
msgstr "Waga"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Określa wartość całkowitą reprezentującą wagę tego zadania"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Maksymalna liczba prób"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Określa wartość całkowitą reprezentującą maksymalną liczbę prób, jakie "
"student może podjąć przy rozwiązaniu zadania"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Etykieta odpowiedzi studenta"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "Etykieta pola tekstowego zawierającego odpowiedź studenta"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Etykieta odpowiedzi eksperta"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Etykieta odpowiedzi 'eksperta'"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Etykieta przycisku zatwierdzania"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Etykieta przycisku zatwierdzania"

#: templates/edit.html:56
msgid "Definition"
msgstr "Definicja"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "Definicja XML dla pytania i odpowiedzi eksperta"

#: templates/edit.html:69
msgid "Save"
msgstr "Zapisz"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Anuluj"

#: views.py:223
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Podpowiedź ({number} z {total}): {hint}"

#: views.py:244
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Użyłeś {count_attempts} z {max_attempts} zgłoszenie"
msgstr[1] "Użyłeś {count_attempts} z {max_attempts} zgłoszenia"
msgstr[2] "Użyłeś {count_attempts} z {max_attempts} zgłoszeń"
msgstr[3] "Użyłeś {count_attempts} z {max_attempts} zgłoszeń"

#: views.py:287
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} punkt możliwy"
msgstr[1] "{weight} punkty możliwe"
msgstr[2] "{weight} punktów możliwych"
msgstr[3] "{weight} punktów możliwych"

#: views.py:299
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
