#: templates/edit.html:8
msgid "Display Name"
msgstr "Nome visualizzato"

#: templates/edit.html:11
msgid "This name appears in the horizontal navigation at the top of the page"
msgstr "Questo nome appare nella navigazione orizzontale in cima alla pagina"

#: templates/edit.html:16
msgid "Weight"
msgstr "Peso"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr ""
"Questo assegna un valore intero che rappresenta il peso di questo problema"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Tentativi massimi"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Questo assegna un valore intero che rappresenta il numero massimo di volte "
"in cui uno studente può tentare il problema"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Etichetta per la risposta dello studente"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "Etichetta per l'area di testo contenente la risposta dello studente"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Etichetta per la risposta dell'esperto"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Etichetta per la risposta 'esperto'"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Etichetta per il pulsante di invio"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Etichetta per il pulsante di invio"

#: templates/edit.html:56
msgid "Definition"
msgstr "Definizione"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "La definizione XML per la domanda e la risposta dell'esperto"

#: templates/edit.html:69
msgid "Save"
msgstr "Salva"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Annulla"

#: views.py:223
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Suggerimento ({number} di {total}): {hint}"

#: views.py:244
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Hai usato {count_attempts} di {max_attempts} invio"
msgstr[1] "Hai usato {count_attempts} di {max_attempts} invii"

#: views.py:287
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} punto possibile"
msgstr[1] "{weight} punti possibili"

#: views.py:299
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} punto"
msgstr[1] "/{weight} punti"
