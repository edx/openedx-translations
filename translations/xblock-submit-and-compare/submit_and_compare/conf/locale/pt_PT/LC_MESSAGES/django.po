#: templates/edit.html:8
msgid "Display Name"
msgstr "Nome de Exibição"

#: templates/edit.html:11
msgid "This name appears in the horizontal navigation at the top of the page"
msgstr "Este nome aparece na navegação horizontal no topo da página"

#: templates/edit.html:16
msgid "Weight"
msgstr "Peso"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Isto atribui um valor inteiro que representa o peso deste problema"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Tentativas Máximas"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Isto atribui um valor inteiro que representa o número máximo de vezes que um"
" aluno pode tentar o problema"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Rótulo para Resposta do Aluno"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "Rótulo para a área de texto que contém a resposta do aluno"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Rótulo para Resposta de Especialista"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Rótulo para a resposta do 'especialista'"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Rótulo para o Botão de Envio"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Rótulo para o botão de envio"

#: templates/edit.html:56
msgid "Definition"
msgstr "Definição"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "A definição XML para a questão e resposta de especialista"

#: templates/edit.html:69
msgid "Save"
msgstr "Guardar"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Cancelar"

#: views.py:223
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Dica ({number} de {total}): {hint}"

#: views.py:244
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Utilizaste {count_attempts} de {max_attempts} tentativa"
msgstr[1] "Utilizaste {count_attempts} de {max_attempts} tentativas"

#: views.py:287
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} ponto possível"
msgstr[1] "{weight} pontos possíveis"

#: views.py:299
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} ponto"
msgstr[1] "/{weight} pontos"
