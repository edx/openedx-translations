#: templates/edit.html:8
msgid "Display Name"
msgstr "Anzeigename"

#: templates/edit.html:11
msgid "This name appears in the horizontal navigation at the top of the page"
msgstr ""
"Dieser Name erscheint in der horizontalen Navigation am oberen Rand der "
"Seite"

#: templates/edit.html:16
msgid "Weight"
msgstr "Gewicht"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr ""
"Dies weist einen ganzzahligen Wert zu, der das Gewicht dieses Problems "
"repräsentiert"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Maximale Versuche"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Dies weist einen ganzzahligen Wert zu, der die maximale Anzahl an Versuchen "
"eines Schülers bei dieser Aufgabe darstellt"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Beschriftung für die Schülerantwort"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "Beschriftung für das Textfeld, das die Antwort des Schülers enthält"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Beschriftung für die Expertenantwort"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Beschriftung für die 'Experten'-Antwort"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Beschriftung für die Schaltfläche zum Absenden"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Bezeichnung für die Schaltfläche zum Absenden"

#: templates/edit.html:56
msgid "Definition"
msgstr "Definition"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "Die XML-Definition für die Frage und die Expertenantwort"

#: templates/edit.html:69
msgid "Save"
msgstr "Speichern"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Abbrechen"

#: views.py:223
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Hinweis ({number} von {total}): {hint}"

#: views.py:244
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Sie haben {count_attempts} von {max_attempts} Einreichung genutzt"
msgstr[1] ""
"Sie haben {count_attempts} von {max_attempts} Einreichungen genutzt"

#: views.py:287
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} Punkt möglich"
msgstr[1] "{weight} Punkte möglich"

#: views.py:299
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} Punkt"
