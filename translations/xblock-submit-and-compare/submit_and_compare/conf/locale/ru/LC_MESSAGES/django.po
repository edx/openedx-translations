#: templates/edit.html:8
msgid "Display Name"
msgstr "Имя для отображения"

#: templates/edit.html:11
msgid "This name appears in the horizontal navigation at the top of the page"
msgstr ""
"Это имя отображается в горизонтальной навигации в верхней части страницы"

#: templates/edit.html:16
msgid "Weight"
msgstr "Вес"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr ""
"Это устанавливает целочисленное значение, представляющее вес данной задачи"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Максимальное число попыток"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Это устанавливает целочисленное значение, определяющее максимальное "
"количество попыток, доступных студенту для решения задачи"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Метка для ответа студента"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "Метка для текстового поля, содержащего ответ студента"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Метка для ответа эксперта"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Метка для ответа «эксперта»"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Метка для кнопки отправки"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Метка для кнопки отправки"

#: templates/edit.html:56
msgid "Definition"
msgstr "Определение"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "XML-описание для вопроса и ответа эксперта"

#: templates/edit.html:69
msgid "Save"
msgstr "Сохранить"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Отмена"

#: views.py:223
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Подсказка ({number} из {total}): {hint}"

#: views.py:244
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Вы использовали {count_attempts} из {max_attempts} попытку"
msgstr[1] "Вы использовали {count_attempts} из {max_attempts} попытки"
msgstr[2] "Вы использовали {count_attempts} из {max_attempts} попыток"

#: views.py:287
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} балл возможен"
msgstr[1] "{weight} балла возможны"
msgstr[2] "{weight} баллов возможны"

#: views.py:299
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} балл"
msgstr[1] "/{weight} балла"
msgstr[2] "/{weight} баллов"
