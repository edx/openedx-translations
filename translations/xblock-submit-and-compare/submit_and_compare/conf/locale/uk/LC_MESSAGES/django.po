#: templates/edit.html:8
msgid "Display Name"
msgstr "Відображуване ім'я"

#: templates/edit.html:11
msgid "This name appears in the horizontal navigation at the top of the page"
msgstr ""
"Це ім'я відображається в горизонтальній навігації у верхній частині сторінки"

#: templates/edit.html:16
msgid "Weight"
msgstr "Вага"

#: templates/edit.html:19
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Це задає ціле число, що представляє вагу цієї задачі"

#: templates/edit.html:24
msgid "Max Attempts"
msgstr "Максимальна кількість спроб"

#: templates/edit.html:27
msgid ""
"This assigns an integer value representing the maximum number of times a "
"student can attempt the problem"
msgstr ""
"Це задає ціле число, що визначає максимальну кількість спроб, які студент "
"може зробити для вирішення задачі"

#: templates/edit.html:32
msgid "Label for Student Answer"
msgstr "Мітка для відповіді студента"

#: templates/edit.html:35
msgid "Label for the text area containing the student's answer"
msgstr "Мітка для текстової області, що містить відповідь студента"

#: templates/edit.html:40
msgid "Label for Expert Answer"
msgstr "Мітка для відповіді експерта"

#: templates/edit.html:43
msgid "Label for the 'expert' answer"
msgstr "Мітка для «експертної» відповіді"

#: templates/edit.html:48
msgid "Label for Submit Button"
msgstr "Мітка для кнопки відправки"

#: templates/edit.html:51
msgid "Label for the submit button"
msgstr "Мітка для кнопки відправки"

#: templates/edit.html:56
msgid "Definition"
msgstr "Визначення"

#: templates/edit.html:57
msgid "The XML definition for the question and expert answer"
msgstr "XML-опис для запитання та відповіді експерта"

#: templates/edit.html:69
msgid "Save"
msgstr "Зберегти"

#: templates/edit.html:72
msgid "Cancel"
msgstr "Скасувати"

#: views.py:223
#, python-brace-format
msgid "Hint ({number} of {total}): {hint}"
msgstr "Підказка ({number} з {total}): {hint}"

#: views.py:244
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Ви використали {count_attempts} з {max_attempts} спробу"
msgstr[1] "Ви використали {count_attempts} з {max_attempts} спроби"
msgstr[2] "Ви використали {count_attempts} з {max_attempts} спроб"

#: views.py:287
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} бал"
msgstr[1] "{weight} бали"
msgstr[2] "{weight} балів"

#: views.py:299
#, python-brace-format
msgid "/{weight} point"
msgid_plural "/{weight} points"
msgstr[0] "/{weight} бал"
msgstr[1] "/{weight} бали"
msgstr[2] "/{weight} балів"
