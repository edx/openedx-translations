#: models.py:24
msgid "Display Name:"
msgstr "표시 이름:"

#: models.py:28
msgid "This name appears in the horizontal navigation at the top of the page."
msgstr "이 이름은 페이지 상단의 가로 네비게이션에 표시됩니다."

#: models.py:33
msgid "Link Text:"
msgstr "링크 텍스트:"

#: models.py:36
msgid "This is the text that will link to your survey."
msgstr "이 텍스트는 설문조사로 연결되는 링크입니다."

#: models.py:39
msgid "Message:"
msgstr "메시지:"

#: models.py:43
msgid "This is the text that will be displayed above the link to your survey."
msgstr "설문조사 링크 위에 표시되는 텍스트입니다."

#: models.py:48
msgid "Param Name:"
msgstr "매개변수 이름:"

#: models.py:52
msgid ""
"This is the name for the User ID parameter in the url. If blank, User ID is "
"ommitted from the url."
msgstr "이것은 URL 내 User ID 매개변수의 이름입니다. 비워둘 경우, URL에서 User ID가 생략됩니다."

#: models.py:57
msgid "Survey ID:"
msgstr "설문조사 ID:"

#: models.py:61
msgid ""
"This is the ID that Qualtrics uses for the survey, which can include numbers"
" and letters, and should be entered in the following format: "
"SV_###############"
msgstr ""
"이것은 Qualtrics가 설문조사에 사용하는 ID로, 숫자와 문자를 포함할 수 있으며, 다음 형식으로 입력되어야 합니다: "
"SV_###############"

#: models.py:67
msgid "Your University:"
msgstr "귀하의 대학:"

#: models.py:70
msgid "This is the name of your university."
msgstr "이것은 귀하의 대학 이름입니다."
