#: models.py:24
msgid "Display Name:"
msgstr "Nom affiché :"

#: models.py:28
msgid "This name appears in the horizontal navigation at the top of the page."
msgstr "Ce nom apparaît dans la navigation horizontale en haut de la page."

#: models.py:33
msgid "Link Text:"
msgstr "Texte du lien :"

#: models.py:36
msgid "This is the text that will link to your survey."
msgstr "Ceci est le texte qui mènera à votre sondage."

#: models.py:39
msgid "Message:"
msgstr "Message :"

#: models.py:43
msgid "This is the text that will be displayed above the link to your survey."
msgstr ""
"Ceci est le texte qui sera affiché au-dessus du lien vers votre sondage."

#: models.py:48
msgid "Param Name:"
msgstr "Nom du paramètre :"

#: models.py:52
msgid ""
"This is the name for the User ID parameter in the url. If blank, User ID is "
"ommitted from the url."
msgstr ""
"Ceci est le nom du paramètre d'identification utilisateur dans l'URL. Si "
"laissé vide, l'ID utilisateur est omis de l'URL."

#: models.py:57
msgid "Survey ID:"
msgstr "ID du sondage :"

#: models.py:61
msgid ""
"This is the ID that Qualtrics uses for the survey, which can include numbers"
" and letters, and should be entered in the following format: "
"SV_###############"
msgstr ""
"C'est l'ID que Qualtrics utilise pour le sondage, qui peut inclure des "
"chiffres et des lettres, et il doit être saisi dans le format suivant : "
"SV_###############"

#: models.py:67
msgid "Your University:"
msgstr "Votre université :"

#: models.py:70
msgid "This is the name of your university."
msgstr "Ceci est le nom de votre université."
