msgid "Random number generated for p. -1 if uninitialized"
msgstr "p için üretilen rastgele sayı (başlatılmamışsa -1)"

#: feedback.py:89
msgid "How user voted. -1 if didn't vote"
msgstr "Kullanıcının oy verme şekli. Oy vermediyse -1"

#: feedback.py:95
msgid "What percent of the time should this show?"
msgstr "Bu, zamanın yüzde kaçında gösterilmeli?"

#: feedback.py:105
msgid "A list of user votes"
msgstr "Kullanıcı oylarının listesi"

#: feedback.py:109
msgid "Feedback"
msgstr "Geri bildirim"

#: feedback.py:112
msgid "Display Name"
msgstr "Görünen İsim"

#: feedback.py:113
msgid "Provide Feedback"
msgstr "Geri bildirim ver"

#: feedback.py:118 templates/html/studio_view.html:17
msgid "Voting message"
msgstr "Oy mesajı"

#: feedback.py:119
msgid "Thank you for voting!"
msgstr "Oy verdiğiniz için teşekkürler!"

#: feedback.py:124 templates/html/studio_view.html:25
msgid "Feedback message"
msgstr "Geri bildirim mesajı"

#: feedback.py:125
msgid "Thank you for your feedback!"
msgstr "Geri bildiriminiz için teşekkürler!"

#: feedback.py:130
msgid "Show aggregate to students"
msgstr "Öğrencilere toplu raporu göster"

#: feedback.py:159
msgid "Please reflect on this course material"
msgstr "Lütfen bu ders materyali üzerine düşünün"

#: feedback.py:160
msgid ""
"Please take time to meaningfully reflect on your experience with this course"
" material."
msgstr ""
"Lütfen bu ders materyali ile deneyiminizi anlamlı bir şekilde değerlendirmek"
" için zaman ayırın."

#: feedback.py:163
msgid "Please rate your overall experience"
msgstr "Lütfen genel deneyiminizi değerlendirin"

#: feedback.py:170
msgid "Please take a moment to thoughtfully reflect."
msgstr "Lütfen bir an durup düşünün."

#: feedback.py:387
msgid "Please vote!"
msgstr "Lütfen oy verin!"

