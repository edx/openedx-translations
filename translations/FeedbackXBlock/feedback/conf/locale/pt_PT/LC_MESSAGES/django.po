#: feedback.py:160
msgid ""
"Please take time to meaningfully reflect on your experience with this course"
" material."
msgstr ""
"Tira um tempo para refletir de forma significativa sobre a tua experiência "
"com este material do curso."

#: feedback.py:163
msgid "Please rate your overall experience"
msgstr "Por favor, classifica a tua experiência global"

#: feedback.py:170
msgid "Please take a moment to thoughtfully reflect."
msgstr "Tira um momento para refletir de forma ponderada."

