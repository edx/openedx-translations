msgid "Excellent"
msgstr "Excelente"

#: feedback.py:43 feedback.py:165
msgid "Good"
msgstr "Bom"

#: feedback.py:43 feedback.py:166
msgid "Average"
msgstr "Médio"

#: feedback.py:43 feedback.py:167
msgid "Fair"
msgstr "Razoável"

#: feedback.py:43 feedback.py:168
msgid "Poor"
msgstr "Fraco"

