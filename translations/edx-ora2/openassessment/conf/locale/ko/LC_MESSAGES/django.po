#: xblock/utils/data_conversion.py:315
msgid "You must provide options selected in the assessment."
msgstr "평가에서 선택된 옵션을 제공해야 합니다."

#: xblock/utils/data_conversion.py:318
msgid "You must provide overall feedback in the assessment."
msgstr "평가에서 전체 피드백을 제공해야 합니다."

#: xblock/utils/data_conversion.py:321
msgid "You must provide feedback for criteria in the assessment."
msgstr "평가 기준에 대한 피드백을 제공해야 합니다."

#: xblock/utils/resolve_dates.py:52
#, python-brace-format
msgid ""
"'{date}' is an invalid date format. Make sure the date is formatted as YYYY-"
"MM-DDTHH:MM:SS."
msgstr "'{date}' 형식은 올바르지 않습니다. 날짜는 YYYY-MM-DDTHH:MM:SS 형식으로 작성되어야 합니다."

#: xblock/utils/resolve_dates.py:57
#, python-brace-format
msgid "'{date}' must be a date string or datetime"
msgstr "'{date}'는 날짜 문자열 또는 datetime이어야 합니다"

#: xblock/utils/resolve_dates.py:210
#, python-brace-format
msgid ""
"This step's start date '{start}' cannot be earlier than the previous step's "
"start date '{prev}'."
msgstr "이 단계의 시작 날짜 '{start}'는 이전 단계의 시작 날짜 '{prev}'보다 앞설 수 없습니다."

#: xblock/utils/resolve_dates.py:218
#, python-brace-format
msgid ""
"This step's due date '{due}' cannot be later than the next step's due date "
"'{prev}'."
msgstr "이 단계의 마감 날짜 '{due}'는 다음 단계의 마감 날짜 '{prev}'보다 늦을 수 없습니다."

#: xblock/utils/resolve_dates.py:234
#, python-brace-format
msgid "The start date '{start}' cannot be later than the due date '{due}'"
msgstr "시작 날짜 '{start}'는 마감 날짜 '{due}'보다 늦을 수 없습니다"

#: xblock/utils/validation.py:120
msgid "This problem must include at least one assessment."
msgstr "이 문제에는 최소 한 개 이상의 평가가 포함되어야 합니다."

#: xblock/utils/validation.py:124
msgid "The assessment order you selected is invalid."
msgstr "선택한 평가 순서가 올바르지 않습니다."

#: xblock/utils/validation.py:134
msgid "In peer assessment, the \"Must Grade\" value must be a positive integer."
msgstr "동료 평가에서 '필수 평가' 값은 양의 정수여야 합니다."

#: xblock/utils/validation.py:137
msgid "In peer assessment, the \"Graded By\" value must be a positive integer."
msgstr "동료 평가에서 '평가자 수' 값은 양의 정수여야 합니다."

#: xblock/utils/validation.py:141
msgid ""
"In peer assessment, the \"Must Grade\" value must be greater than or equal "
"to the \"Graded By\" value."
msgstr "동료 평가에서 '필수 평가' 값은 '평가자 수' 값보다 크거나 같아야 합니다."

#: xblock/utils/validation.py:150
msgid "You must provide at least one example response for learner training."
msgstr "학습자 교육을 위해 최소한 한 개 이상의 예제 응답을 제공해야 합니다."

#: xblock/utils/validation.py:153
msgid "Each example response for learner training must be unique."
msgstr "학습자 교육을 위한 각 예제 응답은 고유해야 합니다."

#: xblock/utils/validation.py:160
msgid "The \"required\" value must be true if staff assessment is the only step."
msgstr "스태프 평가만 있는 경우, '필수' 값은 true여야 합니다."

#: xblock/utils/validation.py:164
msgid ""
"The number of assessments cannot be changed after the problem has been "
"released."
msgstr "문제가 공개된 후에는 평가 개수를 변경할 수 없습니다."

#: xblock/utils/validation.py:169
msgid ""
"The assessment type cannot be changed after the problem has been released."
msgstr "문제가 공개된 후에는 평가 유형을 변경할 수 없습니다."

#: xblock/utils/validation.py:176
msgid ""
"The grading strategy for peer assessments cannot be changed after the "
"problem has been released."
msgstr "문제가 공개된 후에는 동료 평가의 채점 전략을 변경할 수 없습니다."

#: xblock/utils/validation.py:200
msgid "This rubric definition is not valid."
msgstr "이 기준표 정의가 유효하지 않습니다."

#: xblock/utils/validation.py:203
msgid "You must provide at least one prompt."
msgstr "최소 한 개 이상의 문제 설명을 제공해야 합니다."

#: xblock/utils/validation.py:209
#, python-brace-format
msgid "Options in '{criterion}' have duplicate name(s): {duplicates}"
msgstr "'{criterion}'의 옵션에 중복된 이름이 있습니다: {duplicates}"

#: xblock/utils/validation.py:217
msgid "Criteria with no options must require written feedback."
msgstr "옵션이 없는 평가 기준에는 서면 피드백이 필수여야 합니다."

#: xblock/utils/validation.py:226
msgid "Prompts cannot be created or deleted after a problem is released."
msgstr "문제가 공개된 후에는 문제 설명을 생성하거나 삭제할 수 없습니다."

#: xblock/utils/validation.py:230
msgid "The number of criteria cannot be changed after a problem is released."
msgstr "문제가 공개된 후에는 평가 기준의 수를 변경할 수 없습니다."

#: xblock/utils/validation.py:243
msgid "Criteria names cannot be changed after a problem is released"
msgstr "문제가 공개된 후에는 평가 기준의 이름을 변경할 수 없습니다"

#: xblock/utils/validation.py:248
msgid "The number of options cannot be changed after a problem is released."
msgstr "문제가 공개된 후에는 옵션의 수를 변경할 수 없습니다."

#: xblock/utils/validation.py:253
msgid "Point values cannot be changed after a problem is released."
msgstr "문제가 공개된 후에는 점수 값을 변경할 수 없습니다."

#: xblock/utils/validation.py:304
msgid "Learner training must have at least one training example."
msgstr "학습자 교육에는 최소 한 개 이상의 교육 예제가 있어야 합니다."

#: xblock/utils/validation.py:369
msgid "Leaderboard number is invalid."
msgstr "리더보드 번호가 올바르지 않습니다."

#: xblock/utils/validation.py:392
msgid "The submission format is invalid."
msgstr "제출 형식이 유효하지 않습니다."
