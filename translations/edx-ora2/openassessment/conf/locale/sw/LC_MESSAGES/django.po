msgstr "Schema"

#: templates/legacy/edit/oa_edit_header_and_validation.html:29
msgid "Assessment steps"
msgstr "Bedömningssteg"

#: templates/legacy/edit/oa_edit_header_and_validation.html:36
msgid "Settings"
msgstr "Inställningar"

#: templates/legacy/edit/oa_edit_option.html:5
msgid "Option"
msgstr "Alternativ"

#: templates/legacy/edit/oa_edit_option.html:16
