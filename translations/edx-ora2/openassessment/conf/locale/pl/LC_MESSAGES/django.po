msgstr "Opcja, którą wybrałeś, nie jest tą samą, którą wybrał instruktor."

#: templates/legacy/student_training/student_training.html:144
msgid "We could not check your assessment"
msgstr "Nie udało się sprawdzić Twojej oceny"

