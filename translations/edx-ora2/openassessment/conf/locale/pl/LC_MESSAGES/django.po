msgstr ""
"Termin tego kroku '{due}' nie może być późniejszy niż termin następnego "
"kroku '{prev}'."

#: xblock/utils/resolve_dates.py:234
#, python-brace-format
msgid "The start date '{start}' cannot be later than the due date '{due}'"
msgstr "Data rozpoczęcia '{start}' nie może być późniejsza niż termin '{due}'"

#: xblock/utils/validation.py:120
msgid "This problem must include at least one assessment."
msgstr "To zadanie musi zawierać przynajmniej jedną ocenę."

#: xblock/utils/validation.py:124
msgid "The assessment order you selected is invalid."
msgstr "Wybrana kolejność ocen jest nieprawidłowa."

#: xblock/utils/validation.py:134
msgid "In peer assessment, the \"Must Grade\" value must be a positive integer."
msgstr ""
"W ocenianiu rówieśniczym wartość \"Musi ocenić\" musi być dodatnią liczbą "
"całkowitą."

#: xblock/utils/validation.py:137
msgid "In peer assessment, the \"Graded By\" value must be a positive integer."
msgstr ""
"W ocenianiu rówieśniczym wartość \"Ocenieni przez\" musi być dodatnią liczbą"
" całkowitą."

#: xblock/utils/validation.py:141
msgid ""
"In peer assessment, the \"Must Grade\" value must be greater than or equal "
"to the \"Graded By\" value."
msgstr ""
"W ocenianiu rówieśniczym wartość \"Musi ocenić\" musi być większa lub równa "
"wartości \"Ocenieni przez\"."

#: xblock/utils/validation.py:150
msgid "You must provide at least one example response for learner training."
msgstr ""
"Musisz podać przynajmniej jeden przykład odpowiedzi do treningu uczniów."

#: xblock/utils/validation.py:153
msgid "Each example response for learner training must be unique."
msgstr "Każdy przykładowy odpowiedź do treningu uczniów musi być unikalny."

#: xblock/utils/validation.py:160
msgid "The \"required\" value must be true if staff assessment is the only step."
msgstr ""
"Wartość \"wymagane\" musi być ustawiona na true, jeśli ocena personelu jest "
"jedynym krokiem."

#: xblock/utils/validation.py:164
msgid ""
"The number of assessments cannot be changed after the problem has been "
"released."
msgstr "Liczby ocen nie można zmieniać po publikacji zadania."

#: xblock/utils/validation.py:169
msgid ""
"The assessment type cannot be changed after the problem has been released."
msgstr "Typ oceny nie może być zmieniony po publikacji zadania."

#: xblock/utils/validation.py:176
msgid ""
"The grading strategy for peer assessments cannot be changed after the "
"problem has been released."
msgstr ""
"Strategia oceniania ocen rówieśniczych nie może być zmieniona po publikacji "
"zadania."

#: xblock/utils/validation.py:200
msgid "This rubric definition is not valid."
msgstr "Definicja tej rubryki jest nieprawidłowa."

#: xblock/utils/validation.py:203
msgid "You must provide at least one prompt."
msgstr "Musisz podać przynajmniej jeden temat."

#: xblock/utils/validation.py:209
#, python-brace-format
msgid "Options in '{criterion}' have duplicate name(s): {duplicates}"
msgstr "W opcjach w '{criterion}' występują zduplikowane nazwy: {duplicates}"

#: xblock/utils/validation.py:217
msgid "Criteria with no options must require written feedback."
msgstr "Kryteria bez opcji muszą wymagać opinii pisemnej."

#: xblock/utils/validation.py:226
msgid "Prompts cannot be created or deleted after a problem is released."
msgstr "Tematy nie mogą być tworzone ani usuwane po publikacji zadania."

#: xblock/utils/validation.py:230
msgid "The number of criteria cannot be changed after a problem is released."
msgstr "Liczby kryteriów nie można zmieniać po publikacji zadania."

