msgstr ""
"Data rozpoczęcia tego kroku '{start}' nie może być wcześniejsza niż data "
"rozpoczęcia poprzedniego kroku '{prev}'."

#: xblock/utils/resolve_dates.py:218
#, python-brace-format
msgid ""
"This step's due date '{due}' cannot be later than the next step's due date "
