msgid "Your highest score is {score}"
msgstr "La teva puntuació més alta és {score}"

#: utils.py:122
#, python-brace-format
msgid "Final attempt was used, highest score is {score}"
msgstr "S'ha utilitzat l'intent final, la puntuació més alta és {score}"

