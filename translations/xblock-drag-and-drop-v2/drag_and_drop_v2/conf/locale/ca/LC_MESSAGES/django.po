msgstr[1] "{misplaced_count} elements mal col·locats"

#: utils.py:152
#, python-brace-format
msgid ""
"Misplaced {misplaced_count} item (misplaced item was returned to the item "
"bank)"
msgid_plural ""
"Misplaced {misplaced_count} items (misplaced items were returned to the item"
" bank)"
msgstr[0] ""
"{misplaced_count} element mal col·locat (l'element mal col·locat s'ha "
"retornat al banc d'elements)"
msgstr[1] ""
"{misplaced_count} elements mal col·locats (els elements mal col·locats s'han"
" retornat al banc d'elements)"

#: utils.py:163
#, python-brace-format
msgid "Did not place {missing_count} required item"
msgid_plural "Did not place {missing_count} required items"
msgstr[0] "No s'ha col·locat {missing_count} element requerit"
msgstr[1] "No s'han col·locat {missing_count} elements requerits"

#: public/js/drag_and_drop.js:48 public/js/drag_and_drop.js:399
msgid "Submitting"
msgstr "S'està enviant"

#: public/js/drag_and_drop.js:162
msgid "Unknown Zone"
msgstr "Zona desconeguda"

#: public/js/drag_and_drop.js:166
msgid "Placed in: {zone_title}"
msgstr "Situat a: {zone_title}"

#: public/js/drag_and_drop.js:170
msgid "Correctly placed in: {zone_title}"
msgstr "Situat correctament a: {zone_title}"

#: public/js/drag_and_drop.js:182
msgid ", draggable, grabbed"
msgstr ", arrossegable, agafat"

#: public/js/drag_and_drop.js:182
msgid ", draggable"
msgstr ", arrossegable"

#: public/js/drag_and_drop.js:259
msgid "No items placed here"
msgstr "Cap element col·locat aquí"

#: public/js/drag_and_drop.js:265
msgid "Items placed here: "
msgstr "Elements col·locats aquí: "

#: public/js/drag_and_drop.js:297
msgid ", dropzone"
msgstr ", zona de deixada"

#: public/js/drag_and_drop.js:300
msgid "droppable"
msgstr "deixable"

#: public/js/drag_and_drop.js:321 public/js/drag_and_drop.js:325
msgid "Feedback"
msgstr "Retroalimentació"

#: public/js/drag_and_drop.js:336 public/js/drag_and_drop.js:341
msgid "Explanation"
msgstr "Explicació"

#: public/js/drag_and_drop.js:357 public/js/drag_and_drop.js:547
msgid "Close"
msgstr "Tanca"

#: public/js/drag_and_drop.js:360 public/js/drag_and_drop.js:595
msgid "Keyboard Help"
msgstr "Ajuda de teclat"

#: public/js/drag_and_drop.js:363
msgid "This is a screen reader-friendly problem."
msgstr "Aquest és un problema accessible per a usuaris de lector de pantalla."

#: public/js/drag_and_drop.js:364
msgid ""
"Drag and Drop problems consist of draggable items and dropzones. Users "
"should select a draggable item with their keyboard and then navigate to an "
"appropriate dropzone to drop it."
msgstr ""
"Els problemes d'arrossegar i deixar anar consisteixen en elements "
"arrossegables i zones de deixada. Els usuaris han de seleccionar un element "
"arrossegable amb el teclat i, a continuació, navegar fins a una zona "
"adequada per deixar-lo."

#: public/js/drag_and_drop.js:365
msgid ""
"You can complete this problem using only your keyboard by following the "
"guidance below:"
msgstr ""
"Pots completar aquest problema utilitzant només el teclat seguint les "
"instruccions següents:"

#: public/js/drag_and_drop.js:367
msgid ""
"Use only TAB and SHIFT+TAB to navigate between draggable items and drop "
"zones."
msgstr ""
"Utilitza només TAB i SHIFT+TAB per navegar entre els elements arrossegables "
"i les zones de deixada."

#: public/js/drag_and_drop.js:368
msgid "Press CTRL+M to select a draggable item (effectively picking it up)."
msgstr ""
"Prem CTRL+M per seleccionar un element arrossegable (és a dir, per agafar-"
"lo)."

#: public/js/drag_and_drop.js:369
msgid ""
"Navigate using TAB and SHIFT+TAB to the appropriate dropzone and press "
"CTRL+M once more to drop it here."
msgstr ""
"Navega amb TAB i SHIFT+TAB fins a la zona de deixada adequada i prem CTRL+M "
"una vegada més per deixar-lo aquí."

#: public/js/drag_and_drop.js:370
msgid ""
"Press ESC if you want to cancel the drop operation (for example, to select a"
" different item)."
msgstr ""
"Prem ESC si vols cancel·lar l'operació de deixar anar (per exemple, per "
"seleccionar un altre element)."

#: public/js/drag_and_drop.js:371
msgid ""
"TAB back to the list of draggable items and repeat this process until all of"
" the draggable items have been placed on their respective dropzones."
msgstr ""
"Prem TAB per tornar a la llista d'elements arrossegables i repeteix aquest "
"procés fins que tots els elements hagin estat col·locats en les seves "
"respectives zones de deixada."

#: public/js/drag_and_drop.js:389
msgid "You have used {used} of {total} attempts."
msgstr "Has utilitzat {used} de {total} intents."

#: public/js/drag_and_drop.js:412
msgid "Submit"
msgstr "Envia"

#: public/js/drag_and_drop.js:453
msgid "Show Answer"
msgstr "Mostra la resposta"

#: public/js/drag_and_drop.js:466
msgid "Go to Beginning"
msgstr "Vés al principi"

#: public/js/drag_and_drop.js:472
msgid "Reset"
msgstr "Restableix"

#: public/js/drag_and_drop.js:506 public/js/drag_and_drop.js:1244
msgid "Some of your answers were not correct."
msgstr "Algunes de les teves respostes no eren correctes."

#: public/js/drag_and_drop.js:507 public/js/drag_and_drop.js:1247
msgid "Hints:"
msgstr "Pistes:"

#: public/js/drag_and_drop.js:577
msgid "Correct"
msgstr "Correcte"

#: public/js/drag_and_drop.js:577
msgid "Incorrect"
msgstr "Incorrecte"

#. Translators: {earned} is the number of points earned. {possible} is the
#. total number of points (examples: 0/1, 1/1, 2/3, 5/10). The total number of
#. points will always be at least 1. We pluralize based on the total number of
#. points (example: 0/1 point; 1/2 points).
#: public/js/drag_and_drop.js:610
msgid "{earned}/{possible} point (graded)"
msgid_plural "{earned}/{possible} points (graded)"
msgstr[0] "{earned}/{possible} punt (qualificat)"
msgstr[1] "{earned}/{possible} punts (qualificats)"

#. Translators: {earned} is the number of points earned. {possible} is the
#. total number of points (examples: 0/1, 1/1, 2/3, 5/10). The total number of
#. points will always be at least 1. We pluralize based on the total number of
#. points (example: 0/1 point; 1/2 points).
#: public/js/drag_and_drop.js:617
msgid "{earned}/{possible} point (ungraded)"
msgid_plural "{earned}/{possible} points (ungraded)"
msgstr[0] "{earned}/{possible} punt (sense qualificació)"
msgstr[1] "{earned}/{possible} punts (sense qualificació)"

#. Translators: {possible} is the number of points possible (examples: 1, 3,
#. 10).
#: public/js/drag_and_drop.js:627
msgid "{possible} point possible (graded)"
