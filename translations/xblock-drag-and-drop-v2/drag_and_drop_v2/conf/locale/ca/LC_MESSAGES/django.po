#: default_data.py:5
msgid ""
"An isosceles triangle with three layers of similar height. It is shown "
"upright, so the widest layer is located at the bottom, and the narrowest "
"layer is located at the top."
msgstr ""
"Un triangle isòsceles amb tres capes d'alçada similar. Es mostra en posició "
"vertical, de manera que la capa més ampla es troba a la part inferior i la "
"capa més estreta a la part superior."

#: default_data.py:14
msgid "The Top Zone"
msgstr "La Zona Superior"

#: default_data.py:15
msgid "The Middle Zone"
msgstr "La Zona del Mig"

#: default_data.py:16
msgid "The Bottom Zone"
msgstr "La Zona Inferior"

#: default_data.py:18
msgid "Use this zone to associate an item with the top layer of the triangle."
msgstr ""
"Utilitza aquesta zona per associar un element amb la capa superior del "
"triangle."

#: default_data.py:19
msgid ""
"Use this zone to associate an item with the middle layer of the triangle."
msgstr ""
"Utilitza aquesta zona per associar un element amb la capa del mig del "
"triangle."

#: default_data.py:20
msgid ""
"Use this zone to associate an item with the bottom layer of the triangle."
msgstr ""
"Utilitza aquesta zona per associar un element amb la capa inferior del "
"triangle."

#: default_data.py:22
msgid "Correct! This one belongs to The Top Zone."
msgstr "Correcte! Aquest pertany a la Zona Superior."

#: default_data.py:23
msgid "Correct! This one belongs to The Middle Zone."
msgstr "Correcte! Aquest pertany a la Zona del Mig."

#: default_data.py:24
msgid "Correct! This one belongs to The Bottom Zone."
msgstr "Correcte! Aquest pertany a la Zona Inferior."

#: default_data.py:25
msgid "No, this item does not belong here. Try again."
msgstr "No, aquest element no pertany aquí. Torna-ho a provar."

#: default_data.py:26
msgid "You silly, there are no zones for this one."
msgstr "Quina tonteria, no hi ha zones per a aquest element."

#: default_data.py:27
msgid "Of course it goes here! It goes anywhere!"
msgstr "Per descomptat que va aquí! Va a qualsevol lloc!"

#: default_data.py:29
msgid "Goes to the top"
msgstr "Va cap a dalt"

#: default_data.py:30
msgid "Goes to the middle"
msgstr "Va al mig"

#: default_data.py:31
msgid "Goes to the bottom"
msgstr "Va cap a baix"

#: default_data.py:32
msgid "Goes anywhere"
msgstr "Va a qualsevol lloc"

#: default_data.py:33
msgid "I don't belong anywhere"
msgstr "No pertanyo a cap lloc"

#: default_data.py:35
msgid "Drag the items onto the image above."
msgstr "Arrossega els elements sobre la imatge de dalt."

#: default_data.py:36
msgid "Good work! You have completed this drag and drop problem."
msgstr ""
"Bon treball! Has completat aquest problema d'arrossegar i deixar anar."

#: drag_and_drop_v2.py:82
msgid "Title"
msgstr "Títol"

#: drag_and_drop_v2.py:83
msgid ""
"The title of the drag and drop problem. The title is displayed to learners."
msgstr ""
"El títol del problema d'arrossegar i deixar anar. El títol es mostra als "
"estudiants."

#: drag_and_drop_v2.py:85
msgid "Drag and Drop"
msgstr "Arrossega i Deixa Anar"

#: drag_and_drop_v2.py:90
msgid "Mode"
msgstr "Mode"

#: drag_and_drop_v2.py:92
msgid ""
"Standard mode: the problem provides immediate feedback each time a learner "
"drops an item on a target zone. Assessment mode: the problem provides "
"feedback only after a learner drops all available items on target zones."
msgstr ""
"Mode estàndard: el problema ofereix retroalimentació immediata cada vegada "
"que un estudiant deixa anar un element sobre una zona objectiu. Mode "
"d'avaluació: el problema proporciona retroalimentació només després que "
"l'estudiant hagi deixat anar tots els elements disponibles a les zones "
"objectiu."

#: drag_and_drop_v2.py:99
msgid "Standard"
msgstr "Estàndard"

#: drag_and_drop_v2.py:100
msgid "Assessment"
msgstr "Avaluació"

#: drag_and_drop_v2.py:107
msgid "Maximum attempts"
msgstr "Nombre màxim d'intents"

#: drag_and_drop_v2.py:109
msgid ""
"Defines the number of times a student can try to answer this problem. If the"
" value is not set, infinite attempts are allowed."
msgstr ""
"Defineix el nombre de vegades que un estudiant pot intentar respondre aquest"
" problema. Si no es defineix, es permeten intents infinits."

#: drag_and_drop_v2.py:118
msgid "Show title"
msgstr "Mostra el títol"

#: drag_and_drop_v2.py:119
msgid "Display the title to the learner?"
msgstr "Mostrar el títol a l'estudiant?"

#: drag_and_drop_v2.py:126
msgid "Problem text"
msgstr "Text del problema"

#: drag_and_drop_v2.py:127
msgid "The description of the problem or instructions shown to the learner."
msgstr ""
"La descripció del problema o les instruccions que es mostren a l'estudiant."

#: drag_and_drop_v2.py:134
msgid "Show \"Problem\" heading"
msgstr "Mostra el títol \"Problema\""

#: drag_and_drop_v2.py:135
msgid "Display the heading \"Problem\" above the problem text?"
msgstr "Mostrar el títol \"Problema\" per sobre del text del problema?"

#: drag_and_drop_v2.py:141
msgid "Show answer"
msgstr "Mostra la resposta"

#: drag_and_drop_v2.py:142
msgid ""
"Defines when to show the answer to the problem. A default value can be set "
"in Advanced Settings. To revert setting a custom value, choose the 'Default'"
" option."
msgstr ""
"Defineix quan mostrar la resposta del problema. Es pot establir un valor per"
" defecte a Configuració avançada. Per restablir el valor personalitzat, tria"
" l'opció 'Per defecte'."

#: drag_and_drop_v2.py:148
msgid "Default"
msgstr "Per defecte"

#: drag_and_drop_v2.py:149
msgid "Always"
msgstr "Sempre"

#: drag_and_drop_v2.py:150
msgid "Answered"
msgstr "Respost"

#: drag_and_drop_v2.py:151
msgid "Attempted or Past Due"
msgstr "Intentat o Expirat"

#: drag_and_drop_v2.py:152
msgid "Closed"
msgstr "Tancat"

#: drag_and_drop_v2.py:153
msgid "Finished"
msgstr "Finalitzat"

#: drag_and_drop_v2.py:154
msgid "Correct or Past Due"
msgstr "Correcte o Expirat"

#: drag_and_drop_v2.py:155
msgid "Past Due"
msgstr "Expirat"

#: drag_and_drop_v2.py:156
msgid "Never"
msgstr "Mai"

#: drag_and_drop_v2.py:157
msgid "After All Attempts"
msgstr "Després de tots els intents"

#: drag_and_drop_v2.py:158
msgid "After All Attempts or Correct"
msgstr "Després de tots els intents o quan sigui correcte"

#: drag_and_drop_v2.py:159
msgid "Attempted"
msgstr "Intentat"

#: drag_and_drop_v2.py:165
msgid "Problem Weight"
msgstr "Pes del problema"

#: drag_and_drop_v2.py:166
msgid "Defines the number of points the problem is worth."
msgstr "Defineix el nombre de punts que val el problema."

#: drag_and_drop_v2.py:173
msgid "Item background color"
msgstr "Color de fons de l'element"

#: drag_and_drop_v2.py:174
msgid ""
"The background color of draggable items in the problem (example: 'blue' or "
"'#0000ff')."
msgstr ""
"El color de fons dels elements arrossegables en el problema (exemple: 'blue'"
" o '#0000ff')."

#: drag_and_drop_v2.py:181
msgid "Item text color"
msgstr "Color del text de l'element"

#: drag_and_drop_v2.py:182
msgid "Text color to use for draggable items (example: 'white' or '#ffffff')."
msgstr ""
"Color del text que s'utilitza pels elements arrossegables (exemple: 'white' "
"o '#ffffff')."

#: drag_and_drop_v2.py:189
msgid "Maximum items per zone"
msgstr "Màxim d'elements per zona"

#: drag_and_drop_v2.py:190
msgid ""
"This setting limits the number of items that can be dropped into a single "
"zone."
msgstr ""
"Aquesta configuració limita el nombre d'elements que es poden deixar anar en"
" una única zona."

#: drag_and_drop_v2.py:197
msgid "Problem data"
msgstr "Dades del problema"

#: drag_and_drop_v2.py:199
msgid ""
"Information about zones, items, feedback, explanation and background image "
"for this problem. This information is derived from the input that a course "
"author provides via the interactive editor when configuring the problem."
msgstr ""
"Informació sobre zones, elements, retroalimentació, explicació i imatge de "
"fons per a aquest problema. Aquesta informació es deriva de les dades que "
"proporciona l'autor del curs a través de l'editor interactiu en configurar "
"el problema."

#: drag_and_drop_v2.py:209
msgid ""
"Information about current positions of items that a learner has dropped on "
"the target image."
msgstr ""
"Informació sobre les posicions actuals dels elements que un estudiant ha "
"deixat anar a la imatge objectiu."

#: drag_and_drop_v2.py:216
msgid "Number of attempts learner used"
msgstr "Nombre d'intents utilitzats per l'estudiant"

#: drag_and_drop_v2.py:223
msgid "Indicates whether a learner has completed the problem at least once"
msgstr "Indica si un estudiant ha completat el problema almenys una vegada"

#: drag_and_drop_v2.py:230
msgid ""
"DEPRECATED. Keeps maximum score achieved by student as a weighted value."
msgstr ""
"OBSOLET. Manté la puntuació màxima aconseguida per l'estudiant com a valor "
"ponderat."

#: drag_and_drop_v2.py:236
msgid ""
"Keeps maximum score achieved by student as a raw value between 0 and 1."
msgstr ""
"Manté la puntuació màxima aconseguida per l'estudiant com a valor brut "
"compres entre 0 i 1."

#: drag_and_drop_v2.py:243
msgid "Maximum score available of the problem as a raw value between 0 and 1."
msgstr ""
"Puntuació màxima disponible del problema com a valor brut compres entre 0 i "
"1."

#: drag_and_drop_v2.py:566
#, python-brace-format
msgid "Unknown DnDv2 mode {mode} - course is misconfigured"
msgstr "Mode DnDv2 desconegut {mode} - el curs està mal configurat"

#: drag_and_drop_v2.py:641
msgid "show_answer handler should only be called for assessment mode"
msgstr "El controlador show_answer només s'ha de trucar en mode d'avaluació"

#: drag_and_drop_v2.py:646
msgid "The answer is unavailable"
msgstr "La resposta no està disponible"

#: drag_and_drop_v2.py:832
msgid "do_attempt handler should only be called for assessment mode"
msgstr "El controlador do_attempt només s'ha de trucar en mode d'avaluació"

#: drag_and_drop_v2.py:837 drag_and_drop_v2.py:955
msgid "Max number of attempts reached"
msgstr "S'ha assolit el nombre màxim d'intents"

#: drag_and_drop_v2.py:842
msgid "Submission deadline has passed."
msgstr "La data límit de lliurament ha passat."

#: templates/html/drag_and_drop.html:4
msgid "Loading drag and drop problem."
msgstr "S'està carregant el problema d'arrossegar i deixar anar."

