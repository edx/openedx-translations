msgid_plural "Correctly placed {correct_count} items"
msgstr[0] "Prawidłowo umieszczono {correct_count} element"
msgstr[1] "Prawidłowo umieszczono {correct_count} elementy"
msgstr[2] "Prawidłowo umieszczono {correct_count} elementów"
msgstr[3] "Prawidłowo umieszczono {correct_count} elementów"

#: utils.py:141
#, python-brace-format
msgid "Misplaced {misplaced_count} item"
