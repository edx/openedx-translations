msgstr "이미지에 영역 경계를 표시"

#: templates/html/drag_and_drop_edit.html:215
msgid "Display zone borders when dragging an item"
msgstr "항목을 드래그할 때 영역 경계를 표시"

#: templates/html/drag_and_drop_edit.html:220
