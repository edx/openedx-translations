#: default_data.py:5
msgid ""
"An isosceles triangle with three layers of similar height. It is shown "
"upright, so the widest layer is located at the bottom, and the narrowest "
"layer is located at the top."
msgstr ""
"Segitiga sama kaki dengan tiga lapisan yang memiliki ketinggian serupa. "
"Ditampilkan secara tegak, sehingga lapisan terlebar berada di bagian bawah, "
"dan lapisan tersempit berada di bagian atas."

#: default_data.py:14
msgid "The Top Zone"
msgstr "Zona Atas"

#: default_data.py:15
msgid "The Middle Zone"
msgstr "Zona Tengah"

#: default_data.py:16
msgid "The Bottom Zone"
msgstr "Zona Bawah"

#: default_data.py:18
msgid "Use this zone to associate an item with the top layer of the triangle."
msgstr ""
"Gunakan zona ini untuk mengaitkan sebuah item dengan lapisan atas segitiga."

#: default_data.py:19
msgid ""
"Use this zone to associate an item with the middle layer of the triangle."
msgstr ""
"Gunakan zona ini untuk mengaitkan sebuah item dengan lapisan tengah "
"segitiga."

#: default_data.py:20
msgid ""
"Use this zone to associate an item with the bottom layer of the triangle."
msgstr ""
"Gunakan zona ini untuk mengaitkan sebuah item dengan lapisan bawah segitiga."

#: default_data.py:22
msgid "Correct! This one belongs to The Top Zone."
msgstr "Benar! Item ini termasuk dalam Zona Atas."

#: default_data.py:23
msgid "Correct! This one belongs to The Middle Zone."
msgstr "Benar! Item ini termasuk dalam Zona Tengah."

#: default_data.py:24
msgid "Correct! This one belongs to The Bottom Zone."
msgstr "Benar! Item ini termasuk dalam Zona Bawah."

#: default_data.py:25
msgid "No, this item does not belong here. Try again."
msgstr "Tidak, item ini tidak termasuk di sini. Coba lagi."

#: default_data.py:26
msgid "You silly, there are no zones for this one."
msgstr "Kamu konyol, tidak ada zona untuk item ini."

#: default_data.py:27
msgid "Of course it goes here! It goes anywhere!"
msgstr ""
"Tentu saja, item ini seharusnya di sini! Sebenarnya, item ini bisa "
"diletakkan di mana saja!"

#: default_data.py:29
msgid "Goes to the top"
msgstr "Menuju Zona Atas"

#: default_data.py:30
msgid "Goes to the middle"
msgstr "Menuju Zona Tengah"

#: default_data.py:31
msgid "Goes to the bottom"
msgstr "Menuju Zona Bawah"

#: default_data.py:32
msgid "Goes anywhere"
msgstr "Bisa diletakkan di mana saja"

#: default_data.py:33
msgid "I don't belong anywhere"
msgstr "Saya tidak cocok diletakkan di mana pun"

#: default_data.py:35
msgid "Drag the items onto the image above."
msgstr "Seret item-item tersebut ke gambar di atas."

#: default_data.py:36
msgid "Good work! You have completed this drag and drop problem."
msgstr "Kerja bagus! Kamu telah menyelesaikan soal drag and drop ini."

#: drag_and_drop_v2.py:82
msgid "Title"
msgstr "Judul"

#: drag_and_drop_v2.py:83
msgid ""
"The title of the drag and drop problem. The title is displayed to learners."
msgstr ""
"Judul dari soal drag and drop. Judul ini ditampilkan kepada peserta didik."

#: drag_and_drop_v2.py:85
msgid "Drag and Drop"
msgstr "Seret dan Lepas"

#: drag_and_drop_v2.py:90
msgid "Mode"
msgstr "Mode"

#: drag_and_drop_v2.py:92
msgid ""
"Standard mode: the problem provides immediate feedback each time a learner "
"drops an item on a target zone. Assessment mode: the problem provides "
"feedback only after a learner drops all available items on target zones."
msgstr ""
"Mode standar: soal ini memberikan umpan balik langsung setiap kali peserta "
"menempatkan item pada zona target. Mode penilaian: soal hanya memberikan "
"umpan balik setelah peserta menempatkan semua item yang tersedia ke zona "
"target."

#: drag_and_drop_v2.py:99
msgid "Standard"
msgstr "Standar"

#: drag_and_drop_v2.py:100
msgid "Assessment"
msgstr "Penilaian"

#: drag_and_drop_v2.py:107
msgid "Maximum attempts"
msgstr "Maksimal percobaan"

#: drag_and_drop_v2.py:109
msgid ""
"Defines the number of times a student can try to answer this problem. If the"
" value is not set, infinite attempts are allowed."
msgstr ""
"Mengatur jumlah kali seorang siswa dapat mencoba menjawab soal ini. Jika "
"nilai tidak diatur, percobaan tak terbatas diizinkan."

#: drag_and_drop_v2.py:118
msgid "Show title"
msgstr "Tampilkan judul"

#: drag_and_drop_v2.py:119
msgid "Display the title to the learner?"
msgstr "Tampilkan judul kepada peserta didik?"

#: drag_and_drop_v2.py:126
msgid "Problem text"
msgstr "Teks soal"

#: drag_and_drop_v2.py:127
msgid "The description of the problem or instructions shown to the learner."
msgstr "Deskripsi soal atau petunjuk yang ditampilkan kepada peserta didik."

#: drag_and_drop_v2.py:134
msgid "Show \"Problem\" heading"
msgstr "Tampilkan judul \"Soal\""

#: drag_and_drop_v2.py:135
msgid "Display the heading \"Problem\" above the problem text?"
msgstr "Tampilkan judul \"Soal\" di atas teks soal?"

#: drag_and_drop_v2.py:141
msgid "Show answer"
msgstr "Tampilkan jawaban"

#: drag_and_drop_v2.py:142
msgid ""
"Defines when to show the answer to the problem. A default value can be set "
"in Advanced Settings. To revert setting a custom value, choose the 'Default'"
" option."
msgstr ""
"Mengatur kapan jawaban soal ditampilkan. Nilai default dapat diatur pada "
"Pengaturan Lanjutan. Untuk mengembalikan ke nilai default, pilih opsi "
"'Default'."

#: drag_and_drop_v2.py:148
msgid "Default"
msgstr "Default"

#: drag_and_drop_v2.py:149
msgid "Always"
msgstr "Selalu"

#: drag_and_drop_v2.py:150
msgid "Answered"
msgstr "Sudah dijawab"

#: drag_and_drop_v2.py:151
msgid "Attempted or Past Due"
msgstr "Dicoba atau Waktu Habis"

#: drag_and_drop_v2.py:152
msgid "Closed"
msgstr "Ditutup"

#: drag_and_drop_v2.py:153
msgid "Finished"
msgstr "Selesai"

#: drag_and_drop_v2.py:154
msgid "Correct or Past Due"
msgstr "Benar atau Waktu Habis"

#: drag_and_drop_v2.py:155
msgid "Past Due"
msgstr "Waktu Habis"

#: drag_and_drop_v2.py:156
msgid "Never"
msgstr "Tidak Pernah"

#: drag_and_drop_v2.py:157
msgid "After All Attempts"
msgstr "Setelah Semua Percobaan"

#: drag_and_drop_v2.py:158
msgid "After All Attempts or Correct"
msgstr "Setelah Semua Percobaan atau Benar"

#: drag_and_drop_v2.py:159
msgid "Attempted"
msgstr "Dicoba"

#: drag_and_drop_v2.py:165
msgid "Problem Weight"
msgstr "Bobot Soal"

#: drag_and_drop_v2.py:166
msgid "Defines the number of points the problem is worth."
msgstr "Mengatur jumlah poin yang didapatkan dari soal ini."

#: drag_and_drop_v2.py:173
msgid "Item background color"
msgstr "Warna latar belakang item"

#: drag_and_drop_v2.py:174
msgid ""
"The background color of draggable items in the problem (example: 'blue' or "
"'#0000ff')."
msgstr ""
"Warna latar belakang item yang dapat diseret dalam soal (contoh: 'blue' atau"
" '#0000ff')."

#: drag_and_drop_v2.py:181
msgid "Item text color"
msgstr "Warna teks item"

#: drag_and_drop_v2.py:182
msgid "Text color to use for draggable items (example: 'white' or '#ffffff')."
msgstr ""
"Warna teks yang digunakan untuk item yang dapat diseret (contoh: 'white' "
"atau '#ffffff')."

#: drag_and_drop_v2.py:189
msgid "Maximum items per zone"
msgstr "Maksimal item per zona"

#: drag_and_drop_v2.py:190
msgid ""
"This setting limits the number of items that can be dropped into a single "
"zone."
msgstr ""
"Pengaturan ini membatasi jumlah item yang dapat ditempatkan dalam satu zona."

#: drag_and_drop_v2.py:197
msgid "Problem data"
msgstr "Data Soal"

#: drag_and_drop_v2.py:199
msgid ""
"Information about zones, items, feedback, explanation and background image "
"for this problem. This information is derived from the input that a course "
"author provides via the interactive editor when configuring the problem."
msgstr ""
"Informasi tentang zona, item, umpan balik, penjelasan, dan gambar latar "
"untuk soal ini. Informasi ini didasarkan pada input yang diberikan pengajar "
"melalui editor interaktif saat mengonfigurasi soal."

#: drag_and_drop_v2.py:209
msgid ""
"Information about current positions of items that a learner has dropped on "
"the target image."
msgstr ""
"Informasi tentang posisi item saat ini yang telah ditempatkan oleh peserta "
"pada gambar target."

#: drag_and_drop_v2.py:216
msgid "Number of attempts learner used"
msgstr "Jumlah percobaan yang digunakan peserta"

#: drag_and_drop_v2.py:223
msgid "Indicates whether a learner has completed the problem at least once"
msgstr "Menunjukkan apakah peserta telah menyelesaikan soal setidaknya sekali"

#: drag_and_drop_v2.py:230
msgid ""
"DEPRECATED. Keeps maximum score achieved by student as a weighted value."
msgstr ""
"TIDAK DIGUNAKAN. Menyimpan skor tertinggi yang dicapai oleh siswa sebagai "
"nilai berbobot."

#: drag_and_drop_v2.py:236
msgid ""
"Keeps maximum score achieved by student as a raw value between 0 and 1."
msgstr ""
"Menyimpan skor tertinggi yang dicapai oleh siswa sebagai nilai mentah antara"
" 0 dan 1."

#: drag_and_drop_v2.py:243
msgid "Maximum score available of the problem as a raw value between 0 and 1."
msgstr ""
"Skor maksimal yang tersedia untuk soal sebagai nilai mentah antara 0 dan 1."

#: drag_and_drop_v2.py:566
#, python-brace-format
msgid "Unknown DnDv2 mode {mode} - course is misconfigured"
msgstr "Mode DnDv2 {mode} tidak dikenal - kursus dikonfigurasi secara salah"

#: drag_and_drop_v2.py:641
msgid "show_answer handler should only be called for assessment mode"
msgstr "Handler show_answer hanya boleh dipanggil untuk mode penilaian."

#: drag_and_drop_v2.py:646
msgid "The answer is unavailable"
msgstr "Jawaban tidak tersedia."

#: drag_and_drop_v2.py:832
msgid "do_attempt handler should only be called for assessment mode"
msgstr "Handler do_attempt hanya boleh dipanggil untuk mode penilaian."

#: drag_and_drop_v2.py:837 drag_and_drop_v2.py:955
msgid "Max number of attempts reached"
msgstr "Jumlah maksimal percobaan telah tercapai."

#: drag_and_drop_v2.py:842
msgid "Submission deadline has passed."
msgstr "Batas waktu pengumpulan telah berlalu."

