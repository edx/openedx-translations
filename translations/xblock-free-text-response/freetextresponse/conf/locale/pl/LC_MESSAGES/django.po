#: models.py:39
msgid "Display Correctness?"
msgstr "Wyświetlać poprawność?"

#: models.py:41
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"To jest flaga, która wskazuje, czy ikona wskaźnika powinna być wyświetlana "
"po wprowadzeniu odpowiedzi przez ucznia."

#: models.py:49
msgid "Display Other Student Responses"
msgstr "Wyświetl odpowiedzi innych uczniów"

#: models.py:51
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr ""
"Po przesłaniu odpowiedzi przez ucznia zostaną wyświetlone odpowiedzi innych "
"uczniów."

#: models.py:60
msgid "System selected answers to give to students"
msgstr "Odpowiedzi wybrane przez system do przekazania uczniom"

#: models.py:63
msgid "Display Name"
msgstr "Nazwa wyświetlana"

#: models.py:65
msgid "This is the title for this question type"
msgstr "To jest tytuł tego typu pytania"

#: models.py:71
msgid "Full-Credit Key Phrases"
msgstr "Frazy kluczowe dla pełnej oceny"

#: models.py:73
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"Jest to lista słów lub wyrażeń, z których przynajmniej jedno musi być "
"obecne, aby odpowiedź ucznia otrzymała pełną punktację."

#: models.py:81
msgid "Half-Credit Key Phrases"
msgstr "Frazy kluczowe dla uzyskania połowy punktów"

#: models.py:83
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"Jest to lista słów lub wyrażeń, z których przynajmniej jedno musi być "
"obecne, aby odpowiedź ucznia otrzymała połowę punktów."

#: models.py:91
msgid "Maximum Number of Attempts"
msgstr "Maksymalna liczba prób"

#: models.py:93
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr ""
"Jest to maksymalna liczba prób, jakie uczeń może podjąć przy rozwiązywaniu "
"zadania."

#: models.py:101
msgid "Maximum Word Count"
msgstr "Maksymalna liczba słów"

#: models.py:103
msgid "This is the maximum number of words allowed for this question"
msgstr "Jest to maksymalna liczba słów dozwolona w tym pytaniu."

#: models.py:111
msgid "Minimum Word Count"
msgstr "Minimalna liczba słów"

#: models.py:113
msgid "This is the minimum number of words required for this question"
msgstr "Jest to minimalna liczba słów wymagana dla tego pytania."

#: models.py:121
msgid "Prompt"
msgstr "Polecenie"

#: models.py:123
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr ""
"To jest polecenie, które uczniowie zobaczą, gdy będą proszeni o wprowadzenie"
" odpowiedzi."

#: models.py:131
msgid "Submission Received Message"
msgstr "Komunikat o otrzymaniu odpowiedzi"

#: models.py:133
msgid "This is the message students will see upon submitting their response"
msgstr "Jest to komunikat, który uczniowie zobaczą po przesłaniu odpowiedzi."

#: models.py:140
msgid "Weight"
msgstr "Waga"

#: models.py:142
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Określa wartość całkowitą reprezentującą wagę tego zadania."

#: models.py:150
msgid "Draft Received Message"
msgstr "Komunikat o otrzymaniu wersji roboczej"

#: models.py:152
msgid "This is the message students will see upon submitting a draft response"
msgstr ""
"Jest to komunikat, który uczniowie zobaczą po przesłaniu wersji roboczej "
"odpowiedzi."

#: templates/view.html:15
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr ""
"Pozwól, aby moja odpowiedź mogła być widoczna dla innych uczniów po jej "
"przesłaniu."

#: templates/view.html:21 templates/view.html:24
msgid "Checking..."
msgstr "Sprawdzanie..."

#: templates/view.html:21 templates/view.html:22
msgid "Submit"
msgstr "Prześlij"

#: templates/view.html:24 templates/view.html:25
msgid "Save"
msgstr "Zapisz"

#: templates/view.html:34
msgid "Hide"
msgstr "Ukryj"

#: templates/view.html:35
msgid "Show"
msgstr "Pokaż"

#: templates/view.html:36
msgid "peer responses"
msgstr "odpowiedzi rówieśników"

#: templates/view.html:38
msgid "Submissions by others"
msgstr "Odpowiedzi przesłane przez innych"

#: templates/view.html:39 templates/view.html:43
msgid "No responses to show at this time"
msgstr "Brak odpowiedzi do wyświetlenia w tym momencie"

#: views.py:126
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} punkt możliwy"
msgstr[1] "{weight} punkty możliwe"
msgstr[2] "{weight} punktów możliwych"
msgstr[3] "{weight} punktów możliwych"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string}/{weight} punkt możliwy"
msgstr[1] "{score_string}/{weight} punkty możliwe"
msgstr[2] "{score_string}/{weight} punktów możliwych"
msgstr[3] "{score_string}/{weight} punktów możliwych"

#: views.py:147
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Użyłeś {count_attempts} z {max_attempts} zgłoszenie"
msgstr[1] "Użyłeś {count_attempts} z {max_attempts} zgłoszenia"
msgstr[2] "Użyłeś {count_attempts} z {max_attempts} zgłoszeń"
msgstr[3] "Użyłeś {count_attempts} z {max_attempts} zgłoszeń"

#: views.py:171
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "Twoja odpowiedź musi zawierać od {min} do {max} słowo."
msgstr[1] "Twoja odpowiedź musi zawierać od {min} do {max} słowa."
msgstr[2] "Twoja odpowiedź musi zawierać od {min} do {max} słów."
msgstr[3] "Twoja odpowiedź musi zawierać od {min} do {max} słów."

#: views.py:267
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "Nieprawidłowa liczba słów. {word_count_message}"
