#: models.py:39
msgid "Display Correctness?"
msgstr "Tampilkan Ketepatan?"

#: models.py:41
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"Ini adalah penanda yang menunjukkan apakah ikon indikator harus ditampilkan "
"setelah siswa memasukkan jawabannya"

#: models.py:49
msgid "Display Other Student Responses"
msgstr "Tampilkan Respons Siswa Lain"

#: models.py:51
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr ""
"Ini akan menampilkan respons siswa lain kepada siswa setelah mereka "
"mengirimkan jawabannya."

#: models.py:60
msgid "System selected answers to give to students"
msgstr "Jawaban yang dipilih sistem untuk diberikan kepada siswa"

#: models.py:63
msgid "Display Name"
msgstr "Tampilkan Nama"

#: models.py:65
msgid "This is the title for this question type"
msgstr "Ini adalah judul untuk jenis pertanyaan ini"

#: models.py:71
msgid "Full-Credit Key Phrases"
msgstr "Frasa Kunci Kredit Penuh"

#: models.py:73
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"Ini adalah daftar kata atau frasa, salah satunya harus ada agar jawaban "
"siswa mendapatkan kredit penuh"

#: models.py:81
msgid "Half-Credit Key Phrases"
msgstr "Frasa Kunci Kredit Setengah"

#: models.py:83
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"Ini adalah daftar kata atau frasa, salah satunya harus ada agar jawaban "
"siswa mendapatkan kredit setengah"

#: models.py:91
msgid "Maximum Number of Attempts"
msgstr "Jumlah Maksimal Percobaan"

#: models.py:93
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr ""
"Ini adalah jumlah maksimal kali yang diizinkan bagi siswa untuk mencoba "
"masalah tersebut"

#: models.py:101
msgid "Maximum Word Count"
msgstr "Jumlah Kata Maksimum"

#: models.py:103
msgid "This is the maximum number of words allowed for this question"
msgstr ""
"Ini adalah jumlah maksimal kata yang diperbolehkan untuk pertanyaan ini"

#: models.py:111
msgid "Minimum Word Count"
msgstr "Jumlah Kata Minimum"

#: models.py:113
msgid "This is the minimum number of words required for this question"
msgstr "Ini adalah jumlah minimal kata yang diperlukan untuk pertanyaan ini"

#: models.py:121
msgid "Prompt"
msgstr "Petunjuk"

#: models.py:123
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr ""
"Ini adalah petunjuk yang akan dilihat siswa saat diminta untuk memasukkan "
"jawaban mereka"

#: models.py:131
msgid "Submission Received Message"
msgstr "Pesan Penerimaan Kiriman"

#: models.py:133
msgid "This is the message students will see upon submitting their response"
msgstr ""
"Ini adalah pesan yang akan dilihat siswa setelah mengirimkan jawaban mereka"

#: models.py:140
msgid "Weight"
msgstr "Bobot"

#: models.py:142
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Ini menetapkan nilai bilangan bulat yang mewakili bobot dari soal ini"

#: models.py:150
msgid "Draft Received Message"
msgstr "Pesan Penerimaan Draf"

#: models.py:152
msgid "This is the message students will see upon submitting a draft response"
msgstr ""
"Ini adalah pesan yang akan dilihat siswa setelah mengirimkan draf jawaban "
"mereka"

#: templates/view.html:15
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr ""
"Izinkan jawaban saya mungkin dapat dilihat oleh pelajar lain setelah "
"mengirimkan jawaban mereka"

#: templates/view.html:21 templates/view.html:24
msgid "Checking..."
msgstr "Memeriksa..."

#: templates/view.html:21 templates/view.html:22
msgid "Submit"
msgstr "Kirim"

#: templates/view.html:24 templates/view.html:25
msgid "Save"
msgstr "Simpan"

#: templates/view.html:34
msgid "Hide"
msgstr "Sembunyikan"

#: templates/view.html:35
msgid "Show"
msgstr "Tampilkan"

#: templates/view.html:36
msgid "peer responses"
msgstr "respons teman"

#: templates/view.html:38
msgid "Submissions by others"
msgstr "Kiriman dari orang lain"

#: templates/view.html:39 templates/view.html:43
msgid "No responses to show at this time"
msgstr "Tidak ada respons untuk ditampilkan saat ini"

#: views.py:126
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} points possible"
msgstr[1] ""

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string}/{weight} points"
msgstr[1] ""

#: views.py:147
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "You have used {count_attempts} of {max_attempts} submissions"
msgstr[1] ""

#: views.py:171
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "Your response must be between {min} and {max} words."
msgstr[1] ""

#: views.py:267
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "Jumlah Kata Tidak Valid. {word_count_message}"
