#: models.py:39
msgid "Display Correctness?"
msgstr "Mostrar correcció?"

#: models.py:41
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"Aquest és un indicador que indica si s'ha de mostrar la icona d'indicació "
"després que un estudiant introdueixi la seva resposta"

#: models.py:49
msgid "Display Other Student Responses"
msgstr "Mostrar altres respostes d'estudiants"

#: models.py:51
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr ""
"Això mostrarà altres respostes d'estudiants a l'estudiant després que aquest"
" hagi enviat la seva resposta"

#: models.py:60
msgid "System selected answers to give to students"
msgstr "Respostes seleccionades pel sistema per donar als estudiants"

#: models.py:63
msgid "Display Name"
msgstr "Mostrar nom"

#: models.py:65
msgid "This is the title for this question type"
msgstr "Aquest és el títol per a aquest tipus de pregunta"

#: models.py:71
msgid "Full-Credit Key Phrases"
msgstr "Frases clau per a crèdit complet"

#: models.py:73
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"Això és una llista de paraules o frases, una de les quals ha d'estar present"
" perquè la resposta de l'estudiant rebi crèdit complet"

#: models.py:81
msgid "Half-Credit Key Phrases"
msgstr "Frases clau per a mig crèdit"

#: models.py:83
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"Això és una llista de paraules o frases, una de les quals ha d'estar present"
" perquè la resposta de l'estudiant rebi mig crèdit"

#: models.py:91
msgid "Maximum Number of Attempts"
msgstr "Nombre màxim d'intents"

#: models.py:93
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr ""
"Aquest és el nombre màxim de vegades que un estudiant pot intentar resoldre "
"el problema"

#: models.py:101
msgid "Maximum Word Count"
msgstr "Nombre màxim de paraules"

#: models.py:103
msgid "This is the maximum number of words allowed for this question"
msgstr "Aquest és el nombre màxim de paraules permeses per a aquesta pregunta"

#: models.py:111
msgid "Minimum Word Count"
msgstr "Nombre mínim de paraules"

#: models.py:113
msgid "This is the minimum number of words required for this question"
msgstr ""
"Aquest és el nombre mínim de paraules requerides per a aquesta pregunta"

#: models.py:121
msgid "Prompt"
msgstr "Enunciat"

#: models.py:123
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr ""
"Aquest és l'enunciat que els estudiants veuran quan se'ls demani que "
"introdueixin la seva resposta"

#: models.py:131
msgid "Submission Received Message"
msgstr "Missatge de recepció d'enviament"

#: models.py:133
msgid "This is the message students will see upon submitting their response"
msgstr ""
"Aquest és el missatge que els estudiants veuran en enviar la seva resposta"

#: models.py:140
msgid "Weight"
msgstr "Pes"

#: models.py:142
msgid "This assigns an integer value representing the weight of this problem"
msgstr "Aquest assigna un valor enter que representa el pes d'aquest problema"

#: models.py:150
msgid "Draft Received Message"
msgstr "Missatge de recepció de l'esborrany"

#: models.py:152
msgid "This is the message students will see upon submitting a draft response"
msgstr ""
"Aquest és el missatge que els estudiants veuran en enviar una resposta "
"d'esborrany"

#: templates/view.html:15
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr ""
"Permet que la meva resposta es pugui veure per altres estudiants després "
"d'enviar-la"

#: templates/view.html:21 templates/view.html:24
msgid "Checking..."
msgstr "Comprovant..."

#: templates/view.html:21 templates/view.html:22
msgid "Submit"
msgstr "Envia"

#: templates/view.html:24 templates/view.html:25
msgid "Save"
msgstr "Desa"

#: templates/view.html:34
msgid "Hide"
msgstr "Amaga"

#: templates/view.html:35
msgid "Show"
msgstr "Mostra"

#: templates/view.html:36
msgid "peer responses"
msgstr "Respostes dels companys"

#: templates/view.html:38
msgid "Submissions by others"
msgstr "Enviaments d'altres estudiants"

#: templates/view.html:39 templates/view.html:43
msgid "No responses to show at this time"
msgstr "No hi ha respostes per mostrar en aquest moment"

#: views.py:126
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} punt possible"
msgstr[1] "{weight} punts possibles"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string}/{weight} punt"
msgstr[1] "{score_string}/{weight} punts"

#: views.py:147
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Has utilitzat {count_attempts} de {max_attempts} intent"
msgstr[1] "Has utilitzat {count_attempts} de {max_attempts} intents"

#: views.py:171
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "La teva resposta ha de tenir entre {min} i {max} paraula"
msgstr[1] "La teva resposta ha de tenir entre {min} i {max} paraules"

#: views.py:267
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "Nombre de paraules no vàlid. {word_count_message}"
