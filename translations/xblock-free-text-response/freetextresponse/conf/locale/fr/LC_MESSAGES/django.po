#: models.py:39
msgid "Display Correctness?"
msgstr "Afficher la correction ?"

#: models.py:41
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"Ceci est un indicateur qui détermine si l’icône d’indication doit être "
"affichée après qu’un étudiant a saisi sa réponse."

#: models.py:49
msgid "Display Other Student Responses"
msgstr "Afficher les réponses des autres étudiants"

#: models.py:51
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr ""
"Cela affichera les réponses d’autres étudiants à l’étudiant après la "
"soumission de sa réponse."

#: models.py:60
msgid "System selected answers to give to students"
msgstr "Réponses sélectionnées par le système à fournir aux étudiants"

#: models.py:63
msgid "Display Name"
msgstr "Nom affiché"

#: models.py:65
msgid "This is the title for this question type"
msgstr "Ceci est le titre de ce type de question"

#: models.py:71
msgid "Full-Credit Key Phrases"
msgstr "Expressions clés pour crédit complet"

#: models.py:73
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"Il s’agit d’une liste de mots ou d’expressions, dont l’un au moins doit être"
" présent pour que la réponse de l’étudiant reçoive la note maximale."

#: models.py:81
msgid "Half-Credit Key Phrases"
msgstr "Expressions clés pour demi-crédit"

#: models.py:83
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"Il s’agit d’une liste de mots ou d’expressions, dont l’un au moins doit être"
" présent pour que la réponse de l’étudiant reçoive un demi-crédit."

#: models.py:91
msgid "Maximum Number of Attempts"
msgstr "Nombre maximal de tentatives"

#: models.py:93
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr ""
"Ceci est le nombre maximal de fois qu’un étudiant est autorisé à tenter le "
"problème."

#: models.py:101
msgid "Maximum Word Count"
msgstr "Nombre maximal de mots"

#: models.py:103
msgid "This is the maximum number of words allowed for this question"
msgstr "Ceci est le nombre maximal de mots autorisé pour cette question."

#: models.py:111
msgid "Minimum Word Count"
msgstr "Nombre minimal de mots"

#: models.py:113
msgid "This is the minimum number of words required for this question"
msgstr "Ceci est le nombre minimal de mots requis pour cette question."

#: models.py:121
msgid "Prompt"
msgstr "Consigne"

#: models.py:123
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr ""
"Ceci est la consigne que les étudiants verront lorsqu’ils seront invités à "
"saisir leur réponse."

#: models.py:131
msgid "Submission Received Message"
msgstr "Message de réception de la soumission"

#: models.py:133
msgid "This is the message students will see upon submitting their response"
msgstr ""
"Ceci est le message que les étudiants verront après avoir soumis leur "
"réponse."

#: models.py:140
msgid "Weight"
msgstr "Poids"

#: models.py:142
msgid "This assigns an integer value representing the weight of this problem"
msgstr ""
"Cela attribue une valeur entière représentant le poids de ce problème."

#: models.py:150
msgid "Draft Received Message"
msgstr "Message de réception de brouillon"

#: models.py:152
msgid "This is the message students will see upon submitting a draft response"
msgstr ""
"Ceci est le message que les étudiants verront après avoir soumis une ébauche"
" de réponse."

#: templates/view.html:15
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr ""
"Autoriser potentiellement la visibilité de ma réponse par d’autres "
"apprenants après sa soumission."

#: templates/view.html:21 templates/view.html:24
msgid "Checking..."
msgstr "Vérification en cours..."

#: templates/view.html:21 templates/view.html:22
msgid "Submit"
msgstr "Soumettre"

#: templates/view.html:24 templates/view.html:25
msgid "Save"
msgstr "Enregistrer"

#: templates/view.html:34
msgid "Hide"
msgstr "Masquer"

#: templates/view.html:35
msgid "Show"
msgstr "Afficher"

#: templates/view.html:36
msgid "peer responses"
msgstr "réponses des pairs"

#: templates/view.html:38
msgid "Submissions by others"
msgstr "Soumissions par d’autres"

#: templates/view.html:39 templates/view.html:43
msgid "No responses to show at this time"
msgstr "Aucune réponse à afficher pour le moment"

#: views.py:126
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} point possible"
msgstr[1] "{weight} points possibles"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string}/{weight} point"
msgstr[1] "{score_string}/{weight} points"

#: views.py:147
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] "Vous avez utilisé {count_attempts} sur {max_attempts} tentative"
msgstr[1] "Vous avez utilisé {count_attempts} sur {max_attempts} tentatives"

#: views.py:171
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] "Votre réponse doit comporter entre {min} et {max} mot"
msgstr[1] "Votre réponse doit comporter entre {min} et {max} mots"

#: views.py:267
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "Nombre de mots invalide. {word_count_message}"
