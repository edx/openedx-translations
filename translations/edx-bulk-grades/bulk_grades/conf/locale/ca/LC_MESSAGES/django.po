msgid "Grade must be a number"
msgstr "La qualificació ha de ser un número."

#: api.py:388
msgid "Grade must not be negative"
msgstr "La qualificació no pot ser negativa."

#: api.py:642
msgid "score must be positive"
msgstr "La puntuació ha de ser positiva."
