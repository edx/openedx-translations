#: static/html/superset.html:9
msgid ""
"Superset is not configured properly. Please contact your system "
"administrator."
msgstr ""
"Superset no està configurat correctament. Poseu-vos en contacte amb "
"l'administrador del sistema."

#: static/html/superset_student.html:4
msgid ""
"Superset is only visible to course staff and instructors. Please contact "
"your system administrator."
msgstr ""
"Superset només és visible pel personal del curs i els instructors. Poseu-vos"
" en contacte amb l'administrador del sistema."

