msgstr "Hakuna dashibodi kwa aina ya kipande: '{block_type}'"

#: xblock.py:48 xblock.py:49
msgid "Display name"
msgstr "Jina la kuonyesha"

#: xblock.py:50
msgid "Superset Dashboard"
msgstr "Dashibodi ya Superset"

#: xblock.py:55
msgid "Dashboard UUID"
msgstr "UUID ya dashibodi"

#: xblock.py:57
msgid ""
"The ID of the dashboard to embed. Available in the Superset embed dashboard "
"UI."
msgstr ""
"Kitambulisho cha dashibodi cha kujumuisha. Kinapatikana katika UI ya "
"kujumuisha dashibodi ya Superset."

#: xblock.py:64
msgid "Filters"
msgstr "Vichungi"

#: xblock.py:66
msgid ""
"List of SQL filters to apply to the\n"
"               dashboard. E.g: [\"org='edX'\", \"country in ('us', 'co')\"]\n"
"               The fields used here must be available on every dataset used by the dashboard.\n"
"               "
msgstr ""
"Orodha ya vichungi vya SQL vya kutumika kwenye\n"
"               dashibodi. Mfano: [\"org='edX'\", \"country in ('us', 'co')\"]\n"
"               Sehemu zilizotumika hapa lazima zipatikane kwenye kila seti ya data inayotumika na dashibodi.\n"
"               "
