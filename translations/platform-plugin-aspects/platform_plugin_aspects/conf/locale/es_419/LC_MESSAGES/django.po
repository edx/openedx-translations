#: static/html/superset.html:9
msgid ""
"Superset is not configured properly. Please contact your system "
"administrator."
msgstr ""
"Superset no está configurado correctamente. Por favor, contacte a su "
"administrador del sistema."

#: static/html/superset_student.html:4
msgid ""
"Superset is only visible to course staff and instructors. Please contact "
"your system administrator."
msgstr ""
"Superset solo es visible para el personal del curso y los instructores. Por "
"favor, contacte a su administrador del sistema."

