#: apps/badges/admin.py
msgid "No rules specified."
msgstr "No se especificaron reglas."

#: apps/badges/admin.py
msgid "Badge templates were successfully updated."
msgstr "Las plantillas de insignia se actualizaron correctamente."

#: apps/badges/admin.py
msgid "API key"
msgstr "Clave API"

#: apps/badges/admin.py
msgid "Pre-configured from the environment."
msgstr "Preconfigurado desde el entorno."

#: apps/badges/admin.py
msgid ""
"\n"
"                    WARNING: avoid configuration updates on activated badges.\n"
"                    Active badge templates are continuously processed and learners may already have progress on them.\n"
"                    Any changes in badge template requirements (including data rules) will affect learners' experience!\n"
"                    "
msgstr ""
"\n"
"                    ADVERTENCIA: evite las actualizaciones de configuración en las insignias activadas.\n"
"                    Las plantillas de insignia activas se procesan continuamente y los estudiantes pueden ya haber progresado en ellas.\n"
"                    ¡Cualquier cambio en los requisitos de las plantillas de insignia (incluidas las reglas de datos) afectará la experiencia de los estudiantes!\n"
"                    "

