#: apps/badges/admin.py
msgid "No rules specified."
msgstr "Não foram especificadas regras."

#: apps/badges/admin.py
msgid "Badge templates were successfully updated."
msgstr "Os modelos de distintivo foram atualizados com sucesso."

#: apps/badges/admin.py
msgid "API key"
msgstr "Chave da API"

#: apps/badges/admin.py
msgid "Pre-configured from the environment."
msgstr "Pré-configurado a partir do ambiente."

#: apps/badges/admin.py
msgid ""
"\n"
"                    WARNING: avoid configuration updates on activated badges.\n"
"                    Active badge templates are continuously processed and learners may already have progress on them.\n"
"                    Any changes in badge template requirements (including data rules) will affect learners' experience!\n"
"                    "
msgstr ""
"\n"
"                    AVISO: evite atualizações de configuração em distintivos ativados.\n"
"                    Os modelos de distintivo ativos são processados continuamente e os aprendentes podem já ter progresso neles.\n"
"                    Quaisquer alterações nos requisitos do modelo de distintivo (incluindo regras de dados) afetarão a experiência dos aprendentes!\n"
"                    "

