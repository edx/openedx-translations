#: apps/badges/admin.py
msgid "No rules specified."
msgstr "कोई नियम निर्दिष्ट नहीं किए गए।"

#: apps/badges/admin.py
msgid "Badge templates were successfully updated."
msgstr "बैज टेम्प्लेट सफलतापूर्वक अपडेट किए गए।"

#: apps/badges/admin.py
msgid "API key"
msgstr "एपीआई कुंजी"

#: apps/badges/admin.py
msgid "Pre-configured from the environment."
msgstr "पर्यावरण से पूर्व-कॉन्फ़िगर किया गया।"

#: apps/badges/admin.py
msgid ""
"\n"
"                    WARNING: avoid configuration updates on activated badges.\n"
"                    Active badge templates are continuously processed and learners may already have progress on them.\n"
"                    Any changes in badge template requirements (including data rules) will affect learners' experience!\n"
"                    "
msgstr ""
"\n"
"                    चेतावनी: सक्रिय बैजों पर कॉन्फ़िगरेशन अपडेट से बचें।\n"
"                    सक्रिय बैज टेम्प्लेट लगातार संसाधित होते हैं और शिक्षार्थियों की प्रगति पहले से ही हो सकती है।\n"
"                    बैज टेम्प्लेट आवश्यकताओं (डेटा नियम सहित) में किसी भी परिवर्तन से शिक्षार्थियों के अनुभव पर प्रभाव पड़ सकता है!\n"
"                    "

#: apps/badges/admin.py
msgid "Active badge template cannot be deleted."
msgstr "सक्रिय बैज टेम्प्लेट को हटाया नहीं जा सकता।"

#: apps/badges/admin.py
msgid "Active badge templates cannot be deleted."
msgstr "सक्रिय बैज टेम्प्लेट्स को हटाया नहीं जा सकता।"

#: apps/badges/admin.py
msgid "icon"
msgstr "आइकन"

