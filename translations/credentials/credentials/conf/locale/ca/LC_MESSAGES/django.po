#: apps/badges/admin.py
msgid "No rules specified."
msgstr "No s'han especificat regles."

#: apps/badges/admin.py
msgid "Badge templates were successfully updated."
msgstr "Les plantilles de distintius s'han actualitzat amb èxit."

#: apps/badges/admin.py
msgid "API key"
msgstr "Clau API"

#: apps/badges/admin.py
msgid "Pre-configured from the environment."
msgstr "Preconfigurat des de l'entorn."

#: apps/badges/admin.py
msgid ""
"\n"
"                    WARNING: avoid configuration updates on activated badges.\n"
"                    Active badge templates are continuously processed and learners may already have progress on them.\n"
"                    Any changes in badge template requirements (including data rules) will affect learners' experience!\n"
"                    "
msgstr ""
"ADVERTIMENT: eviteu actualitzacions de configuració en distintius activats.\n"
"Les plantilles de distintius actius es processen de manera contínua i els alumnes ja poden tenir progrés sobre ells.\n"
"Qualsevol canvi en els requisits de la plantilla de distintius (incloent-hi les regles de dades) afectarà l'experiència dels alumnes!"

#: apps/badges/admin.py
msgid "Active badge template cannot be deleted."
msgstr "La plantilla de distintiu activat no es pot esborrar."

#: apps/badges/admin.py
msgid "Active badge templates cannot be deleted."
msgstr "Les plantilles de distintius activats no es poden esborrar."

#: apps/badges/admin.py
msgid "icon"
msgstr "icona"

