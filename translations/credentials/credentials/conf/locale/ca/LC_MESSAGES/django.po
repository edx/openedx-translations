#: apps/badges/admin.py
msgid "No rules specified."
msgstr "No s'han especificat regles."

#: apps/badges/admin.py
msgid "Badge templates were successfully updated."
msgstr "Les plantilles d'insígnies s'han actualitzat correctament."

#: apps/badges/admin.py
msgid "API key"
msgstr "Clau API"

#: apps/badges/admin.py
msgid "Pre-configured from the environment."
msgstr "Preconfigurat des de l'entorn."

#: apps/badges/admin.py
msgid ""
"\n"
"                    WARNING: avoid configuration updates on activated badges.\n"
"                    Active badge templates are continuously processed and learners may already have progress on them.\n"
"                    Any changes in badge template requirements (including data rules) will affect learners' experience!\n"
"                    "
msgstr ""
"AVÍS: eviteu actualitzacions de configuració en insígnies activades.\n"
"Les plantilles d'insígnies actives es processen de forma contínua i els estudiants ja poden tenir progressos en elles.\n"
"Qualsevol canvi en els requisits de la plantilla d'insígnia (incloent les regles de dades) afectarà l'experiència dels estudiants!"

#: apps/badges/admin.py
msgid "Active badge template cannot be deleted."
msgstr "La plantilla d'insígnia activa no es pot eliminar."

#: apps/badges/admin.py
