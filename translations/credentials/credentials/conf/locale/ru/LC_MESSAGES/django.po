#: apps/badges/admin.py
msgid "No rules specified."
msgstr "Правила не заданы."

#: apps/badges/admin.py
msgid "Badge templates were successfully updated."
msgstr "Шаблоны значков успешно обновлены."

#: apps/badges/admin.py
msgid "API key"
msgstr "API-ключ"

#: apps/badges/admin.py
msgid "Pre-configured from the environment."
msgstr "Предварительно настроено из среды."

#: apps/badges/admin.py
msgid ""
"\n"
"                    WARNING: avoid configuration updates on activated badges.\n"
"                    Active badge templates are continuously processed and learners may already have progress on them.\n"
"                    Any changes in badge template requirements (including data rules) will affect learners' experience!\n"
"                    "
msgstr ""
"\n"
"                    ПРЕДУПРЕЖДЕНИЕ: избегайте обновления конфигурации для активированных значков.\n"
"                    Активные шаблоны значков постоянно обрабатываются, и учащиеся могут уже иметь прогресс по ним.\n"
"                    Любые изменения в требованиях к шаблонам значков (включая правила данных) повлияют на опыт учащихся!\n"
"                    "

