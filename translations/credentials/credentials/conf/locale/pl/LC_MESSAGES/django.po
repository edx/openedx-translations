#: apps/badges/admin.py
msgid "No rules specified."
msgstr "Nie określono zasad."

#: apps/badges/admin.py
msgid "Badge templates were successfully updated."
msgstr "Szablony odznak zostały pomyślnie zaktualizowane."

#: apps/badges/admin.py
msgid "API key"
msgstr "Klucz API"

#: apps/badges/admin.py
msgid "Pre-configured from the environment."
msgstr "Wstępnie skonfigurowano na podstawie środowiska."

#: apps/badges/admin.py
msgid ""
"\n"
"                    WARNING: avoid configuration updates on activated badges.\n"
"                    Active badge templates are continuously processed and learners may already have progress on them.\n"
"                    Any changes in badge template requirements (including data rules) will affect learners' experience!\n"
"                    "
msgstr ""
"\n"
"                    UWAGA: unikaj aktualizacji konfiguracji dla aktywowanych odznak.\n"
"                    Aktywne szablony odznak są stale przetwarzane, a użytkownicy mogą już mieć z nimi powiązany postęp.\n"
"                    Wszelkie zmiany w wymaganiach szablonów odznak (włącznie z regułami danych) wpłyną na doświadczenie użytkowników!\n"
"                    "

